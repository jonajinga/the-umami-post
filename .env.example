# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored; never commit real keys.
#
# All values are optional for a local build — the site will render
# but service integrations (forms, analytics, comments, newsletter)
# will be no-ops until you provide real keys.

# Site identity
SITE_URL=https://example.com
SITE_EMAIL=hello@example.com

# Web3Forms — contact/submission form backend (https://web3forms.com)
WEB3FORMS_ACCESS_KEY=

# Umami — privacy-friendly analytics (https://umami.is)
UMAMI_WEBSITE_ID=
UMAMI_SRC=https://cloud.umami.is/script.js
UMAMI_DASHBOARD_URL=

# Cusdis — lightweight comment system (https://cusdis.com)
CUSDIS_APP_ID=

# Buttondown — newsletter (https://buttondown.com)
BUTTONDOWN_USERNAME=

# Tipping / reader support (all optional — override CMS values to keep URLs out of repo)
KOFI_URL=
BMAC_URL=
PATREON_URL=
