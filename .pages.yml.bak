          - { name: description, type: string, label: "Description" }
      - { name: body, type: rich-text, label: "Article Body" }

  - name: arts-culture
    label: Arts & Culture
    path: src/content/arts-culture
    type: collection
    filename: "{fields.title|slugify}.md"
    fields:
      - { name: layout, type: string, default: article, hidden: true }
