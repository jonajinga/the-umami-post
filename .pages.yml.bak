# Pages CMS Configuration
# https://pagescms.org/docs/configuration/
#
# This file defines all content collections editable via Pages CMS. Each
# collection maps to a folder under src/content/ (articles) or a top-level
# project folder (glossary, bookshelf, thought-experiments, trials, library).
#
# For forks: change the `author` default value (jon-ajinga) to match
# a slug in src/authors-data/ — or remove the default and make it required.

media:
  input: src/assets/img
  output: /assets/img

content:
  # ── Group 1: Site Setup ──────────────────────────────────────────────────────
  # Configure these first before adding any content.

  - name: site-settings
    label: Site Settings
    path: src/_data/site-settings.json
    type: file
    format: json
    fields:
      - { name: title, type: string, required: true, label: "Publication Name" }
      - { name: description, type: text, required: true, label: "Site Description (shown in SEO and social previews)" }
      - { name: tagline, type: text, label: "Tagline (shown below publication name in the footer)" }
      - { name: author, type: string, required: true, label: "Publication Byline (used in RSS, JSON-LD, etc.)" }
      - { name: email, type: string, label: "Contact Email Address" }
      - { name: founded, type: number, label: "Year Founded" }
      - { name: footerByline, type: string, label: "Footer Byline (overrides the auto-generated 'Founded X. Tagline' text)" }
      - { name: gtranslate, type: boolean, label: "Enable Google Translate Widget" }
      - name: tipping
        type: object
        label: "Reader Support Links (Ko-fi, BMAC, or Patreon — first non-empty wins)"
        fields:
          - { name: kofi, type: string, label: "Ko-fi URL" }
          - { name: bmac, type: string, label: "Buy Me A Coffee URL" }
          - { name: patreon, type: string, label: "Patreon URL" }
      - name: newsletter
        type: object
        label: "Newsletter (Buttondown)"
        fields:
          - { name: provider, type: string, label: "Provider (enter: buttondown)" }
          - { name: username, type: string, label: "Buttondown Username" }
      - name: social
        type: object
        label: "Social Media Links"
        fields:
          - { name: twitter, type: string, label: "Twitter / X URL" }
          - { name: mastodon, type: string, label: "Mastodon URL" }
          - { name: rss, type: string, label: "RSS Feed Path (default: /feed.xml)" }
      - name: subscribe
        type: object
        label: "Newsletter Subscribe Block Copy"
        fields:
          - { name: eyebrow,       type: string, label: "Eyebrow Line (inline newsletter block)" }
          - { name: heading,       type: string, label: "Heading (inline newsletter block)" }
          - { name: body,          type: text,   label: "Body Copy (inline newsletter block)" }
          - { name: notice,        type: string, label: "Notice Line (below the signup form)" }
          - { name: sidebarBody,   type: string, label: "Sidebar Widget Copy" }
          - { name: footerHeading, type: string, label: "Footer Block Heading" }
          - { name: footerBody,    type: string, label: "Footer Block Body Copy" }
      - { name: contactSubjects, type: string, list: true, label: "Contact Form Subject Options" }

  - name: authors
    label: Authors
    path: src/authors-data
    type: collection
    extension: yml
    filename: "{fields.slug}"
    fields:
      - { name: slug, type: string, required: true, label: "Slug (e.g. jane-doe — used in articles and author page URL)" }
      - { name: name, type: string, required: true, label: "Display Name" }
      - { name: role, type: string, label: "Role (e.g. Founding Editor, Staff Reporter)" }
      - { name: title, type: string, label: "Professional Title" }
      - { name: location, type: string, label: "Location (e.g. Denver, Colorado)" }
      - { name: bio, type: text, label: "Short Bio (shown in byline tooltips)" }
      - { name: bioLong, type: rich-text, label: "Full Bio (shown on author page)" }
      - { name: photo, type: image, label: "Author Photo" }
      - name: social
        type: object
        label: "Social Media Links"
        fields:
          - { name: x, type: string, label: "X / Twitter URL" }
          - { name: bluesky, type: string, label: "Bluesky URL" }
          - { name: mastodon, type: string, label: "Mastodon URL" }
          - { name: linkedin, type: string, label: "LinkedIn URL" }
          - { name: github, type: string, label: "GitHub URL" }
          - { name: threads, type: string, label: "Threads URL" }
          - { name: instagram, type: string, label: "Instagram URL" }
          - { name: website, type: string, label: "Personal Website URL" }
          - { name: email, type: string, label: "Public Email Address" }
      - name: tipping
        type: object
        label: "Support / Donation Links"
        fields:
          - { name: kofi, type: string, label: "Ko-fi URL" }
          - { name: bmac, type: string, label: "Buy Me A Coffee URL" }
          - { name: patreon, type: string, label: "Patreon URL" }

  - name: nav
    label: Main Navigation
    path: src/_data/nav.json
    type: file
    format: json
    list: true
    fields:
      - { name: label, type: string, required: true, label: "Link Label" }
      - { name: url, type: string, required: true, label: "URL" }
      - { name: key, type: string, required: true, label: "Unique Key (slug, no spaces — used for dropdown IDs)" }
      - { name: collection, type: string, label: "Eleventy Collection Name (e.g. news, opinion) — enables section dropdown" }
      - { name: type, type: string, label: "Special Type: 'more' (mega-menu) or 'library'" }

  - name: footerLinks
    label: Footer Navigation
    path: src/_data/footerLinks.json
    type: file
    format: json
    list: true
    fields:
      - { name: heading, type: string, required: true, label: "Column Heading" }
      - { name: headingUrl, type: string, label: "Heading URL (optional — makes the heading a link)" }
      - name: links
        type: object
        list: true
        label: "Links"
        fields:
          - { name: label, type: string, required: true, label: "Link Text" }
          - { name: url, type: string, required: true, label: "URL" }
          - { name: title, type: string, label: "Tooltip (title attribute)" }

  - name: megaMenu
    label: '"More" Mega Menu'
    path: src/_data/megaMenu.json
    type: file
    format: json
    list: true
    fields:
      - { name: heading, type: string, required: true, label: "Column Heading" }
      - name: links
        type: object
        list: true
        label: "Links"
        fields:
          - { name: title, type: string, required: true, label: "Link Title" }
          - { name: url, type: string, required: true, label: "URL" }
          - { name: desc, type: string, required: true, label: "Short Description (shown below the link title)" }

  - name: drawerLinks
    label: Mobile Drawer Navigation
    path: src/_data/drawerLinks.json
    type: file
    format: json
    list: true
    fields:
      - { name: heading, type: string, label: "Section Heading (leave blank for no heading)" }
      - { name: showSupportBadgeAfter, type: boolean, label: "Show Support Badge After This Group" }
      - { name: small, type: boolean, label: "Use Small Link Style" }
      - name: links
        type: object
        list: true
        label: "Links"
        fields:
          - { name: label, type: string, required: true, label: "Link Text" }
          - { name: url, type: string, required: true, label: "URL" }

  # ── Group 2: Write Articles ──────────────────────────────────────────────────
  #
  # Field reference for all article sections:
  #   edition     — which print/web edition this belongs to
  #   location    — dateline shown in byline (e.g. "Denver, Colorado")
  #   responseTo  — URL of the article this responds to
  #   series      — series title for multi-part articles
  #   seriesPart  — part number within the series
  #   corrections — post-publication corrections log
  #   profile     — content format (standard, interview, longread, etc.)
  #   status      — editorial workflow: draft → review → published
  #   draft       — when true, excluded from live site
  #   featured    — shown in featured slots when true
  #   emailOnly   — newsletter only, no public page

  - name: news
    label: News
    path: src/content/news
    type: collection
    filename: "{fields.title|slugify}.md"
    fields:
      - { name: layout, type: string, default: article, hidden: true }
      - { name: section, type: string, default: News, hidden: true }
      - { name: title, type: string, required: true, label: "Title" }
      - { name: description, type: text, required: true, label: "Description (shown in search results and social previews)" }
      - { name: author, type: string, default: jon-ajinga, label: "Author Slug (must match an entry in Authors)" }
      - { name: authorName, type: string, default: "Jon Ajinga", label: "Author Display Name" }
      - { name: date, type: date, required: true, label: "Publish Date" }
      - { name: updated, type: date, label: "Last Updated Date (optional)" }
      - { name: image, type: image, label: "Cover Image" }
      - { name: imageAlt, type: string, label: "Image Alt Text (required for accessibility)" }
      - { name: tags, type: string, list: true, label: "Tags" }
      - { name: profile, type: select, options: [standard, interview, longread, photoessay, podcast, datavisualization, brief, explainer], default: standard, label: "Content Format" }
      - { name: audioUrl, type: string, label: "Audio URL (podcast format only)" }
      - { name: embedUrl, type: string, label: "Embed URL (data visualisation format only)" }
      - { name: series, type: string, label: "Series Title (optional)" }
      - { name: seriesPart, type: number, label: "Part Number in Series" }
      - { name: location, type: string, label: "Dateline (e.g. Denver, Colorado)" }
      - { name: edition, type: number, label: "Edition Number" }
      - { name: featured, type: boolean, default: false, label: "Featured" }
      - { name: draft, type: boolean, default: true, label: "Draft" }
      - { name: status, type: select, options: [draft, review, published], default: draft, label: "Status" }
      - { name: responseTo, type: string, label: "Response To (URL of the article this replies to)" }
      - { name: emailOnly, type: boolean, default: false, label: "Email Only (newsletter — no public page)" }
      - { name: assignedTo, type: string, label: "Assigned To (author slug)" }
      - { name: dueDate, type: date, label: "Due Date" }
      - name: corrections
        type: object
        list: true
        label: "Corrections"
        fields:
          - { name: description, type: text, required: true, label: "What Was Corrected" }
          - { name: date, type: date, required: true, label: "Correction Date" }
      - name: attachments
        type: object
        list: true
        label: "File Attachments"
        fields:
          - { name: name, type: string, required: true, label: "File Name" }
          - { name: path, type: string, required: true, label: "File Path or URL" }
          - { name: description, type: string, label: "Description" }
      - { name: body, type: rich-text, label: "Article Body" }

  - name: opinion
    label: Opinion
    path: src/content/opinion
    type: collection
    filename: "{fields.title|slugify}.md"
    fields:
      - { name: layout, type: string, default: article, hidden: true }
      - { name: section, type: string, default: Opinion, hidden: true }
      - { name: title, type: string, required: true, label: "Title" }
      - { name: description, type: text, required: true, label: "Description (shown in search results and social previews)" }
      - { name: author, type: string, default: jon-ajinga, label: "Author Slug (must match an entry in Authors)" }
      - { name: authorName, type: string, default: "Jon Ajinga", label: "Author Display Name" }
      - { name: date, type: date, required: true, label: "Publish Date" }
      - { name: updated, type: date, label: "Last Updated Date (optional)" }
      - { name: image, type: image, label: "Cover Image" }
      - { name: imageAlt, type: string, label: "Image Alt Text (required for accessibility)" }
      - { name: tags, type: string, list: true, label: "Tags" }
      - { name: profile, type: select, options: [standard, interview, longread, photoessay, podcast, datavisualization, brief, explainer], default: standard, label: "Content Format" }
      - { name: audioUrl, type: string, label: "Audio URL (podcast format only)" }
      - { name: embedUrl, type: string, label: "Embed URL (data visualisation format only)" }
      - { name: series, type: string, label: "Series Title (optional)" }
      - { name: seriesPart, type: number, label: "Part Number in Series" }
      - { name: location, type: string, label: "Dateline (e.g. Denver, Colorado)" }
      - { name: edition, type: number, label: "Edition Number" }
      - { name: featured, type: boolean, default: false, label: "Featured" }
      - { name: draft, type: boolean, default: true, label: "Draft" }
      - { name: status, type: select, options: [draft, review, published], default: draft, label: "Status" }
      - { name: responseTo, type: string, label: "Response To (URL of the article this replies to)" }
      - { name: emailOnly, type: boolean, default: false, label: "Email Only (newsletter — no public page)" }
      - { name: assignedTo, type: string, label: "Assigned To (author slug)" }
      - { name: dueDate, type: date, label: "Due Date" }
      - name: corrections
        type: object
        list: true
        label: "Corrections"
        fields:
          - { name: description, type: text, required: true, label: "What Was Corrected" }
          - { name: date, type: date, required: true, label: "Correction Date" }
      - name: attachments
        type: object
        list: true
        label: "File Attachments"
        fields:
          - { name: name, type: string, required: true, label: "File Name" }
          - { name: path, type: string, required: true, label: "File Path or URL" }
          - { name: description, type: string, label: "Description" }
      - { name: body, type: rich-text, label: "Article Body" }

  - name: analysis
    label: Analysis
    path: src/content/analysis
    type: collection
    filename: "{fields.title|slugify}.md"
    fields:
      - { name: layout, type: string, default: article, hidden: true }
      - { name: section, type: string, default: Analysis, hidden: true }
      - { name: title, type: string, required: true, label: "Title" }
      - { name: description, type: text, required: true, label: "Description (shown in search results and social previews)" }
      - { name: author, type: string, default: jon-ajinga, label: "Author Slug (must match an entry in Authors)" }
      - { name: authorName, type: string, default: "Jon Ajinga", label: "Author Display Name" }
      - { name: date, type: date, required: true, label: "Publish Date" }
      - { name: updated, type: date, label: "Last Updated Date (optional)" }
      - { name: image, type: image, label: "Cover Image" }
      - { name: imageAlt, type: string, label: "Image Alt Text (required for accessibility)" }
      - { name: tags, type: string, list: true, label: "Tags" }
      - { name: profile, type: select, options: [standard, interview, longread, photoessay, podcast, datavisualization, brief, explainer], default: standard, label: "Content Format" }
      - { name: audioUrl, type: string, label: "Audio URL (podcast format only)" }
      - { name: embedUrl, type: string, label: "Embed URL (data visualisation format only)" }
      - { name: series, type: string, label: "Series Title (optional)" }
      - { name: seriesPart, type: number, label: "Part Number in Series" }
      - { name: location, type: string, label: "Dateline (e.g. Denver, Colorado)" }
      - { name: edition, type: number, label: "Edition Number" }
      - { name: featured, type: boolean, default: false, label: "Featured" }
      - { name: draft, type: boolean, default: true, label: "Draft" }
      - { name: status, type: select, options: [draft, review, published], default: draft, label: "Status" }
      - { name: responseTo, type: string, label: "Response To (URL of the article this replies to)" }
      - { name: emailOnly, type: boolean, default: false, label: "Email Only (newsletter — no public page)" }
      - { name: assignedTo, type: string, label: "Assigned To (author slug)" }
      - { name: dueDate, type: date, label: "Due Date" }
      - name: corrections
        type: object
        list: true
        label: "Corrections"
        fields:
          - { name: description, type: text, required: true, label: "What Was Corrected" }
