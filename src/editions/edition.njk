---
layout: base
pagination:
  data: collections.editionList
  size: 1
  alias: editionNum
permalink: /editions/{{ editionNum }}/
eleventyComputed:
  title: "Edition {{ editionNum }}"
  description: "Edition {{ editionNum }} of The Freethinking Times, a curated bundle of articles published together."
---

{% set edArts = collections.allContent | editionArticles(editionNum) %}

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  {# ── Print header (screen: hidden; print: visible) ── #}
  <div class="print-header">
    <span class="print-header__title">{{ site.title }}</span>
    <span>Edition No. {{ editionNum }}{% if edArts.length %} &middot; {{ edArts[0].date | readableDate }}{% endif %} &middot; {{ edArts.length }} article{% if edArts.length != 1 %}s{% endif %}</span>
  </div>

  {# ── Print-only cover page (hidden on screen via CSS) ── #}
  <div class="print-cover" aria-hidden="true">
    <div class="print-cover__head">
      <p class="print-cover__eyebrow">A reader compilation from</p>
      <h1 class="print-cover__publication">{{ site.title }}</h1>
      <p class="print-cover__line">{{ site.url }}</p>
    </div>
    <div class="print-cover__body">
      <h2 class="print-cover__heading">Edition No. {{ editionNum }}</h2>
      {% if edArts.length %}
      <p class="print-cover__lede">{{ edArts.length }} article{% if edArts.length != 1 %}s{% endif %} &middot; {{ edArts[0].date | readableDate }}</p>
      {% endif %}
      {% if edArts.length %}
      <ol class="print-cover__list">
        {% for item in edArts %}
        <li>
          <span class="print-cover__title">{{ item.data.title }}</span>
          <span class="print-cover__counts">
            {% if item.data.section %}{{ item.data.section }}{% endif %}
            {% if item.data.author %} &middot; By {{ item.data.author }}{% endif %}
          </span>
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </div>
    <div class="print-cover__foot">
      <p class="print-cover__date">Edition No. {{ editionNum }} &middot; {{ site.url }}/editions/{{ editionNum }}/</p>
      <p class="print-cover__note">Articles released under <a href="{{ site.url }}/license/">CC BY-NC-ND 4.0</a>. Republish with attribution and a link back to the canonical URL.</p>
    </div>
  </div>

  <header class="edition-header">
    <a href="/editions/" class="edition-back">← All editions</a>
    <p class="edition-header__number">No. {{ editionNum }}</p>
    {% if edArts.length %}
    <p class="edition-header__date">{{ edArts[0].date | readableDate }}</p>
    {% endif %}
    <h1 class="edition-header__title">Edition {{ editionNum }}</h1>
    <div style="display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap;">
      <p class="edition-header__count" style="margin: 0;">{{ edArts.length }} article{% if edArts.length != 1 %}s{% endif %} in this edition</p>
      <button id="edition-print-btn" type="button" style="display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-muted); background: none; border: 1px solid var(--color-rule); border-radius: var(--radius-sm); padding: var(--space-2) var(--space-3); cursor: pointer;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print / Save PDF
      </button>
    </div>
  </header>

  <div class="edition-rule"></div>

  {% if edArts.length %}

  {# Lead article #}
  {% set leadArt = edArts[0] %}
  <div style="padding-bottom: var(--space-10); border-bottom: 1px solid var(--color-rule); margin-bottom: var(--space-10);">
    {% set article = leadArt %}
    {% set size = "lg" %}
    {% set showImage = true %}
    {% include "partials/article-card.njk" %}
  </div>

  {# Remaining articles in a list #}
  {% if edArts.length > 1 %}
  <ul class="article-list" role="list">
    {% for item in edArts %}
    {% if not loop.first %}
    <li class="article-list__item">
      {% set article = item %}
      {% set size = "sm" %}
      {% include "partials/article-card.njk" %}
    </li>
    {% endif %}
    {% endfor %}
  </ul>
  {% endif %}

  {% else %}
  <p style="color: var(--color-ink-faint); font-style: italic;">No articles found for this edition.</p>
  {% endif %}

  {# ── Full article text, print only ── #}
  {% if edArts.length %}
  <div class="edition-print-articles" aria-hidden="true">
    {% for item in edArts %}
    <div class="edition-print-article">
      <p class="edition-print-article__eyebrow">
        {% if item.data.section %}{{ item.data.section }} &middot; {% endif %}{{ item.date | readableDate }}
      </p>
      <h2 class="edition-print-article__title">{{ item.data.title }}</h2>
      {% if item.data.description %}
      <p class="edition-print-article__dek">{{ item.data.description }}</p>
      {% endif %}
      {% if item.data.author %}
      <p class="edition-print-article__byline">By {{ item.data.author }}</p>
      {% endif %}
      <div class="edition-print-article__body">
        {{ item.templateContent | safe }}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# ── Print footer ── #}
  <footer class="print-footer" aria-hidden="true">
    <span>{{ site.title }}, Edition {{ editionNum }}</span>
    <span>{{ site.url }}/editions/{{ editionNum }}/</span>
  </footer>

  <div class="edition-nav">
    {% if editionNum > (collections.editionList | last) %}
    <a class="edition-nav__link" href="/editions/{{ editionNum - 1 }}/">← Edition {{ editionNum - 1 }}</a>
    {% else %}
    <span></span>
    {% endif %}
    {% if editionNum < (collections.editionList | first) %}
    <a class="edition-nav__link" href="/editions/{{ editionNum + 1 }}/">Edition {{ editionNum + 1 }} →</a>
    {% endif %}
  </div>

</div>

{% block scripts %}
<script>
  document.getElementById('edition-print-btn').addEventListener('click', function () {
    window.print();
  });
</script>
{% endblock %}
