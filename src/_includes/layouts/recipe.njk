---
layout: layouts/base.njk
isReadingPage: true
---

{% block head %}
{% if tags %}<meta name="news_keywords" content="{{ tags | join(', ') }}">{% endif %}
{% include "partials/recipe-jsonld.njk" %}
{% endblock %}

{# Pagefind metadata #}
<div aria-hidden="true" style="display:none">
  <span data-pagefind-meta="section">Recipes</span>
  <span data-pagefind-filter="section">recipes</span>
  {% if author %}
  <span data-pagefind-meta="author">{{ authors[author].name or authorName or author }}</span>
  <span data-pagefind-filter="author">{{ authors[author].name or authorName or author }}</span>
  {% endif %}
  {% if course %}<span data-pagefind-filter="course">{{ course }}</span>{% endif %}
  {% if cuisine %}<span data-pagefind-filter="cuisine">{{ cuisine }}</span>{% endif %}
  {% for d in diet %}<span data-pagefind-filter="diet">{{ d }}</span>{% endfor %}
  {% for s in seasonality %}<span data-pagefind-filter="season">{{ s }}</span>{% endfor %}
  {% if difficulty %}<span data-pagefind-filter="difficulty">{{ difficulty }}</span>{% endif %}
  {% if totalTime %}<span data-pagefind-meta="totalTime">{{ totalTime | duration }}</span>{% endif %}
  {% if tags %}
  {% for tag in tags %}{% if tag != "recipes" %}<span data-pagefind-filter="topic">{{ tag }}</span>{% endif %}{% endfor %}
  {% endif %}
</div>

{# Context for annotations.js #}
<div id="annotations-context" data-page-slug="{{ page.fileSlug }}" data-page-url="{{ page.url }}" data-page-title="{{ title | escape }}" hidden></div>

<div class="reading-progress" aria-hidden="true"></div>

<div class="print-header" aria-hidden="true">
  <span class="print-header__title">{{ site.title }}</span>
  <span class="print-header__url">{{ site.url }}</span>
</div>

<article class="recipe container" data-recipe-slug="{{ page.fileSlug }}" data-pagefind-body>

  <header class="recipe-hero">
    <span class="recipe-hero__eyebrow">Recipe{% if course %} &middot; {{ course }}{% endif %}{% if cuisine %} &middot; {{ cuisine }}{% endif %}</span>
    <h1 class="recipe-hero__title">{{ title }}</h1>
    {% if dek %}<p class="recipe-hero__dek">{{ dek }}</p>{% endif %}
    {% if hero %}
    <figure class="recipe-hero__photo">
      <img src="{{ hero }}" alt="{{ heroAlt or title }}" loading="eager" fetchpriority="high">
      {% if heroCaption %}<figcaption>{{ heroCaption }}</figcaption>{% endif %}
    </figure>
    {% endif %}
    <p class="recipe-hero__byline">
      {% if author %}By <a href="/author/{{ author | slugify }}/">{{ authors[author].name or authorName or author }}</a>{% endif %}
      &middot; {{ page.date | readableDate }}
      {% if updated %} &middot; Updated {{ updated | readableDate }}{% endif %}
    </p>
  </header>

  {% include "partials/recipe-meta-bar.njk" %}

  <div class="recipe-body">
    <aside class="recipe-body__ingredients">
      <h2>Ingredients</h2>
      {% include "partials/ingredient-list.njk" %}
      {% if equipment and equipment.length %}
      <h2 style="margin-top: var(--space-8);">Equipment</h2>
      <ul style="list-style:none;padding:0;margin:0;">
        {% for tool in equipment %}
        <li style="padding: var(--space-2) 0; border-bottom: 1px solid var(--color-rule); font-family: var(--font-body);">{{ tool }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </aside>

    <section class="recipe-body__instructions">
      <h2>Instructions</h2>
      {% include "partials/instruction-list.njk" %}

      {% if notes %}
      <aside class="recipe-notes">
        <h2>Cook's notes</h2>
        {{ notes | safe }}
      </aside>
      {% endif %}

      {% if nutrition %}
      <aside class="recipe-notes" style="border-color: var(--color-food-science);">
        <h2>Nutrition (per serving)</h2>
        <p>
          {% if nutrition.calories %}<strong>Calories:</strong> {{ nutrition.calories }}&nbsp;&middot;&nbsp;{% endif %}
          {% if nutrition.protein %}<strong>Protein:</strong> {{ nutrition.protein }}&nbsp;&middot;&nbsp;{% endif %}
          {% if nutrition.carbs %}<strong>Carbs:</strong> {{ nutrition.carbs }}&nbsp;&middot;&nbsp;{% endif %}
          {% if nutrition.fat %}<strong>Fat:</strong> {{ nutrition.fat }}{% endif %}
        </p>
        <p style="font-size: var(--text-xs); color: var(--color-ink-faint); margin-top: var(--space-2);">Estimated. Actual values vary with substitutions.</p>
      </aside>
      {% endif %}

      {% if source %}
      <p style="margin-top: var(--space-8); font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-ink-faint);">
        <strong>Source:</strong> {{ source | safe }}
      </p>
      {% endif %}

      <div class="article-body" style="margin-top: var(--space-10);">
        {{ content | safe }}
      </div>
    </section>
  </div>

  <button type="button" class="cooking-mode__exit" onclick="document.body.classList.remove('cooking-mode');history.pushState({},'',location.pathname);">Exit cooking mode</button>

</article>

{% include "partials/reader-chrome.njk" %}

{% block scripts %}
<script src="/assets/js/serving-scaler.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/ingredient-checklist.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/cooking-mode.js?v={{ buildTime }}" defer></script>
{% endblock %}
