    <div id="article-panel-cite-inline" class="library-panel__section" aria-hidden="true">
      <p class="library-panel__section-head">Cite this article</p>
      <p class="library-panel__section-lede">Pre-formatted citations in the most common academic styles, ready to copy.</p>
      {# Inline citation formats, rendered below by cite-inline.js #}
    </div>
    {% if site.repo and site.repo.owner %}
    <div id="article-panel-history" class="library-panel__section" aria-hidden="true">
      <p class="library-panel__section-head">Revision history</p>
      <p class="library-panel__section-lede">Every edit to this article, from the Git history behind the publication.</p>
      {# Revision history, rendered below on first activation by revision-history.js #}
    </div>
    {% endif %}
    <div id="article-panel-related" class="library-panel__section" aria-hidden="true" data-print-label="Related">
      <p class="library-panel__section-head">Related reading</p>
      <p class="library-panel__section-lede">Other articles connected by tag, section, or subject matter.</p>
      {% set relatedList = collections.allContent | relatedArticles({ tags: tags, section: section, title: title }, page.url, 4) %}
      {% if relatedList.length > 0 %}
      <ul style="list-style:none;padding:0;margin:0;">
        {% for item in relatedList %}
        {% if item.url != page.url %}
        <li style="padding:var(--space-3) 0;border-bottom:1px solid var(--color-rule);">
          <a href="{{ item.url }}" style="font-family:var(--font-headline);font-size:var(--text-sm);font-weight:600;color:var(--color-ink);text-decoration:none;display:block;line-height:var(--leading-snug);">{{ item.data.title }}</a>
          {% if item.data.section %}<div style="margin-top:6px;font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">{{ item.data.section }}</div>{% endif %}
          {% set listenUrl = item.url %}{% set listenTitle = item.data.title %}{% set listenSize = "sm" %}
          {% set _itemAud = audioManifest[item.url] %}
          {% if _itemAud %}<div style="margin-top:8px;">{% include "partials/listen-button.njk" %}</div>{% endif %}
        </li>
        {% endif %}
        {% endfor %}
      </ul>
      {% else %}
      <p style="font-size:var(--text-xs);color:var(--color-ink-faint);font-style:italic;">No related articles found.</p>
      {% endif %}
    </div>
  </div>

</aside>

{# Annotation toolbar — shared across article + library reading layouts. #}
{% set readerPanelId = "article-notes-panel" %}
{% set readerToggleClass = "article-notes-toggle" %}
{% include "partials/annotation-toolbar.njk" %}

{# Republish license + grab-code modal — hosted at top level so its
   fixed-position rendering escapes .article-header's stacking context
   and paints above the masthead and annotation toolbar. The toggle
   trigger is #ann-republish-btn in the toolbar; the toggle handler
   lives in base.njk. #}
{% include "partials/republish.njk" %}

{% block scripts %}

<script src="/assets/js/reading-list.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/download.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/annotations.js?v={{ buildTime }}" defer></script>
{% endblock %}
