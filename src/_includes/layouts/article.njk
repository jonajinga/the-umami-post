---
layout: layouts/base.njk
isReadingPage: true
---

{% block head %}
{% if tags %}<meta name="news_keywords" content="{{ tags | join(', ') }}">{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ title | dump | safe }},
  "description": {{ (description or "") | dump | safe }},
  "datePublished": "{{ page.date | isoDate }}",
  "dateModified": "{{ (lastUpdated or page.date) | isoDate }}",
  "author": {
    "@type": "Person",
    "name": {{ (authors[author].name or authorName or author or "") | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}"
  },
  "url": "{{ site.url }}{{ page.url }}",
  "license": "https://creativecommons.org/licenses/by-nc-nd/4.0/"{% if image %},
  "image": "{{ site.url }}{{ image }}"{% endif %}
}
</script>
{% endblock %}

{# Context for annotations.js #}
<div id="annotations-context" data-page-slug="{{ page.fileSlug }}" data-page-url="{{ page.url }}" data-page-title="{{ title | escape }}" hidden></div>

<div class="reading-progress" aria-hidden="true"></div>

<div class="print-header" aria-hidden="true">
  <span class="print-header__title">{{ site.title }}</span>
  <span class="print-header__url">{{ site.url }}</span>
</div>

{# Pagefind metadata, hidden, used by search index #}
<div aria-hidden="true" style="display:none">
  {% if section %}
  <span data-pagefind-meta="section">{{ section }}</span>
  <span data-pagefind-filter="section">{{ section }}</span>
  {% endif %}
  {% if author %}
  <span data-pagefind-meta="author">{{ authors[author].name or authorName or author }}</span>
  <span data-pagefind-filter="author">{{ authors[author].name or authorName or author }}</span>
  {% endif %}
  <span data-pagefind-filter="year">{{ page.date | htmlDateString | truncate(4, false, '') }}</span>
  {% if tags %}
  <span data-pagefind-meta="tags">{% for tag in tags %}{% if tag != "post" %}{{ tag }}{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}</span>
  {% for tag in tags %}{% if tag != "post" %}<span data-pagefind-filter="topic">{{ tag }}</span>{% endif %}{% endfor %}
  {% endif %}
</div>

<div class="container article-layout">
  <div class="article-layout__inner">

    {# ── Article Body ── #}
    <div class="article-layout__body" data-pagefind-body>

      {# Hidden author/byline text so Pagefind indexes it as searchable
         content. The visible byline block below is data-pagefind-ignore'd,
         so without this readers who search for an author name would only
         get the /author/ page itself, not the articles. #}
      {% if author %}
      <span class="visually-hidden">
        Written by {{ authors[author].name or authorName or author }}
        {% if authorName and authors[author] and authorName != authors[author].name %}({{ authorName }}){% endif %}
        for {{ site.title }}.
      </span>
      {% endif %}

      {# Article Header — meta sections (eyebrow / byline / stats / topics)
         start collapsed by default so the title + dek read cleanly. The
         toolbar `i` button toggles `data-meta-collapsed` and persists the
         preference site-wide in localStorage as `tft-article-meta-expanded`. #}
      <header class="article-header" data-meta-collapsed="true">
        <div class="article-header__eyebrow">
          {% if section %}
          <a href="/{{ section | slugify }}/"
             class="section-badge section-badge--{{ section | slugify }}">
            {{ section }}
          </a>
          {% endif %}
          {% if subsection %}
          {% if section %}
          <a href="/{{ section | slugify }}/?s={{ subsection | slugify }}" class="dateline dateline--link" aria-label="Filter {{ section }} to {{ subsection }}">{{ subsection }}</a>
          {% else %}
          <span class="dateline">{{ subsection }}</span>
          {% endif %}
          {% endif %}
          {% if edition %}
          <a href="/editions/{{ edition }}/" class="edition-badge">Edition {{ edition }}</a>
          {% endif %}
          {% set profileKey = profile or "standard" %}
          {% if profiles[profileKey] and profiles[profileKey].badge %}
          <span class="profile-badge" data-profile="{{ profileKey }}" title="{{ profiles[profileKey].description }}">{{ profiles[profileKey].badge }}</span>
          {% endif %}
        </div>

        {# Article topics — moved up beneath the eyebrow so the
           categorisation cluster (section / subsection / edition →
           topics) reads as one group ahead of the title. #}
        {% if tags %}
        {% set _hasTopics = false %}
        {% for tag in tags %}{% if tag != "post" %}{% set _hasTopics = true %}{% endif %}{% endfor %}
        {% if _hasTopics %}
        <nav class="article-topics" aria-label="Topics" data-pagefind-ignore>
          <a class="article-topics__label" href="/topics/">Topics</a>
          <ul class="article-topics__list" role="list">
            {% for tag in tags %}{% if tag != "post" %}<li><a href="/topics/{{ tag | slugify }}/">{{ tag }}</a></li>{% endif %}{% endfor %}
          </ul>
        </nav>
        {% endif %}
        {% endif %}

        <h1 class="article-header__headline">{{ title }}</h1>

        {% if description %}
        <p class="article-header__dek">{{ description }}</p>
        {% endif %}

        <div class="article-header__byline-block" data-pagefind-ignore>
          {# Two-row byline: author + (location) on one line, published
             + updated dates on a second line. The pipe-separator rules
             target each row independently so each row's items separate
             cleanly from each other but author doesn't get a pipe before
             the dates row. #}
          <div class="article-header__byline-meta article-header__byline-row">
            {% if author %}
            <a class="article-header__author" href="/author/{{ author | slugify }}/"
              {% if authors[author] and authors[author].bio %}data-tippy-content="{{ authors[author].bio }}" data-tippy-theme="author-bio"{% endif %}>
              By {{ authors[author].name or authorName or author }}
            </a>
            {% endif %}
            {% if location %}
            <span class="dateline">{{ location }}</span>
            {% endif %}
          </div>

          <div class="article-header__byline-meta article-header__byline-row article-header__byline-row--dates">
            {% set sameDateArticles = collections.allContent | sameDate(page.date, page.url) %}
            <span class="date-popover-wrap">
              <a class="article-header__date" href="/archives/#{{ page.date | htmlDateString }}">
                <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
              </a>
              {% if sameDateArticles.length %}
              <span class="date-popover" role="tooltip">
                <span class="date-popover__label">Also published this day</span>
                <ul class="date-popover__list">
                  {% for item in sameDateArticles %}
                  <li><a href="{{ item.url }}">{{ item.data.title }}</a></li>
                  {% endfor %}
                </ul>
              </span>
              {% endif %}
            </span>
            {% set updatedDate = updated or lastUpdated %}
            {% if updatedDate %}
            <span class="article-header__updated">Updated: <time datetime="{{ updatedDate | htmlDateString }}">{{ updatedDate | readableDate }}</time></span>
            {% endif %}
            {# Republish badge has moved to the bottom annotation toolbar
               (see "Republish" in article.njk's toolbar block). The
               license panel below is still toggled by that button. #}
          </div>

          {# Republish modal lives at the top level of the document
             (rendered after the toolbar) so it escapes .article-header's
             stacking context (z-index: 10) and can paint above the
             masthead (z-100) and annotation toolbar (z-200). #}
        </div>

        <div class="article-header__meta-row" data-pagefind-ignore>
          <span class="article-meta-item article-meta-item--length">{{ content | wordCount }}</span>
          <span class="article-meta-item article-meta-item--time">{{ content | readingTime }}</span>
          {% set _stats = articleStats[page.url] %}
          {% if _stats %}
            {% if _stats.views %}<span class="article-meta-item article-meta-item--stat" title="Pageviews from Umami">{{ _stats.views | numberFmt }} {{ "view" if _stats.views == 1 else "views" }}</span>{% endif %}
            {% if _stats.shares %}<span class="article-meta-item article-meta-item--stat" title="Tracked share-button clicks">{{ _stats.shares | numberFmt }} {{ "share" if _stats.shares == 1 else "shares" }}</span>{% endif %}
            {% if _stats.likes %}<span class="article-meta-item article-meta-item--stat" title="Reader likes">{{ _stats.likes | numberFmt }} {{ "like" if _stats.likes == 1 else "likes" }}</span>{% endif %}
          {% endif %}
        </div>
        {# Topics row was moved up directly under the eyebrow so the
           categorisation cluster reads as one group ahead of the
           title — duplicate block here removed. #}

        {# Listen pill is now rendered inline in the byline support
           row above (next to "How We're Funded" / "Republish" /
           "Add as Preferred"), so it's smaller and integrated rather
           than a full-width card. See partials/article-audio.njk. #}

        {# Responses to this piece — sits right below the tags so readers
           know up-front which other articles respond to this one. Only
           renders when at least one response exists. #}
        {% set responses = collections.allContent | responsesTo(page.url) %}
        {% if responses.length %}
        <aside class="responses-section responses-section--header">
          <p class="responses-section__title">Responses to this piece</p>
          <ul class="responses-section__list">
            {% for resp in responses %}
            <li class="responses-section__item">
              {% if resp.data.section %}
              <span class="responses-section__section">{{ resp.data.section }}</span>
              {% endif %}
              <a class="responses-section__link" href="{{ resp.url }}">{{ resp.data.title }}</a>
              <time class="responses-section__date">{{ resp.date | readableDate }}</time>
            </li>
            {% endfor %}
          </ul>
        </aside>
        {% endif %}

        <div class="article-header__actions" data-pagefind-ignore>

          {# 1. Reader panel #}
          <button class="article-action-btn article-notes-toggle" type="button"
            aria-label="Reader"
            aria-expanded="false"
            aria-controls="article-notes-panel">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
          </button>

          {# 2. Save to reading list #}
          <button class="article-action-btn bookmark-btn" id="bookmark-btn" type="button" aria-label="Save to reading list"
            data-url="{{ page.url }}"
            data-title="{{ title | escape }}"
            data-section="{{ section or '' }}"
            data-date="{{ page.date | htmlDateString }}"
            data-mins="{{ content | readingMins }}">
            <svg class="bookmark-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <span class="btn-label">Save</span>
          </button>

          {# 2a. Like / heart #}
          <button class="article-action-btn like-btn" id="like-btn" type="button"
            aria-label="Like this article" aria-pressed="false"
            data-url="{{ page.url }}"
            data-umami-event="article-like">
            <svg class="like-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="btn-label">Like</span>
          </button>

          {# 2b. Mark as read — manual toggle, separate from auto-scroll progress #}
          <button class="article-action-btn mark-read-btn" id="mark-read-btn" type="button"
            aria-label="Mark this article as read" aria-pressed="false"
            data-url="{{ page.url }}"
            data-title="{{ title | escape }}"
            data-section="{{ section or '' }}"
            data-umami-event="mark-read">
            <svg class="mark-read-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="btn-label mark-read-btn__label">Mark as read</span>
          </button>

          {# 2c. Add to PDF basket — collects articles for combined print #}
          <button class="article-action-btn pdf-basket-btn" id="pdf-basket-btn" type="button"
            aria-label="Add to print basket" aria-pressed="false" title="Add to print basket"
            data-url="{{ page.url }}"
            data-title="{{ title | escape }}"
            data-section="{{ section or '' }}"
            data-date="{{ page.date | htmlDateString }}"
            data-author="{{ authors[author].name or authorName or author or '' }}"
            data-umami-event="pdf-basket-add">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 7h18l-2 12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2L3 7z"/>
              <path d="M8 7V5a4 4 0 0 1 8 0v2"/>
            </svg>
          </button>

          {# Listen affordance lives in the article-header meta-row
             (left of word count). Toolbar Listen button has been
             retired so there is exactly one Listen surface per
             article page — no duplicate buttons. #}

          {# 2. Share (panel with social + copy + email) #}
          <div class="share-wrap">
            <button class="article-action-btn" id="share-btn" type="button"
              aria-label="Share this article" aria-expanded="false" aria-controls="share-panel"
              data-title="{{ title | escape }}"
              data-url="{{ site.url }}{{ page.url }}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              <span class="btn-label">Share</span>
            </button>
            <div id="share-panel" class="share-panel" hidden role="menu">
              <a class="share-panel__item" id="share-twitter" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X / Twitter
              </a>
              <a class="share-panel__item" id="share-facebook" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a class="share-panel__item" id="share-linkedin" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a class="share-panel__item" id="share-reddit" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
                Reddit
              </a>
              <a class="share-panel__item" id="share-bluesky" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 568 501" fill="currentColor" aria-hidden="true"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.209C491.866-1.611 568-28.906 568 57.947c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 323.8 536.444 388.56 473.333 453.32c-119.86 122.992-172.272-30.859-185.702-70.281-2.462-7.227-3.614-10.608-3.631-7.733-.017-2.875-1.169.506-3.631 7.733-13.43 39.422-65.842 193.273-185.702 70.281-63.111-64.76-33.889-129.52 80.653-149.07-65.72 11.185-139.6-7.295-159.875-79.748C9.945 203.66 0 75.293 0 57.947 0-28.906 76.135-1.611 123.121 33.664z"/></svg>
                Bluesky
              </a>
              <a class="share-panel__item" id="share-mastodon" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 74 79" fill="currentColor" aria-hidden="true"><path d="M73.7014 17.4323C72.5616 9.05152 65.1774 2.4469 56.424 1.1671C54.9472 0.950843 49.3518 0.163185 36.3901 0.163185H36.2933C23.3281 0.163185 20.5465 0.950843 19.0697 1.1671C10.56 2.41145 2.78877 8.34604 0.903306 16.826C-0.00357854 21.0022 -0.100361 25.6322 0.068224 29.8793C0.308274 35.9699 0.354113 42.0498 0.91436 48.1158C1.30054 52.1309 1.94863 56.1158 2.85116 60.0428C4.38616 66.6564 11.3077 72.2018 18.1071 74.674C25.3658 77.2579 33.2044 77.7447 40.7259 76.0832C41.5504 75.8995 42.3649 75.6935 43.1693 75.4654C44.9192 74.9477 46.8901 74.3625 48.5903 73.4578L48.5903 73.4578C48.5903 73.4578 48.5903 73.4578 48.5903 73.4578C50.5512 72.4484 52.6405 71.6906 54.8072 71.1972C60.5459 69.8936 63.5516 68.2696 65.5728 63.8064C68.1284 58.0558 69.4851 51.8392 69.5624 45.5509C69.5754 44.3821 70.1476 28.3366 70.1476 26.9658C70.1542 22.4227 71.5994 21.3484 73.7014 17.4323Z"/><path fill="white" d="M61.0244 25.5705V46.8777H52.3878V26.2006C52.3878 21.7833 50.7207 19.5372 47.3566 19.5372C43.6516 19.5372 41.7942 21.9943 41.7942 26.8522V37.4655H33.2089V26.8522C33.2089 21.9943 31.3515 19.5372 27.6465 19.5372C24.2824 19.5372 22.6154 21.7833 22.6154 26.2006V46.8777H13.9788V25.5705C13.9788 21.1568 15.1415 17.6392 17.4705 15.0235C19.8744 12.4078 23.0184 11.0734 26.9101 11.0734C31.4145 11.0734 34.8321 12.7486 37.116 16.0991L39.5018 20.0767L41.8877 16.0991C44.1716 12.7486 47.5892 11.0734 52.0936 11.0734C55.9853 11.0734 59.1293 12.4078 61.5332 15.0235C63.8622 17.6392 65.0249 21.1568 65.0249 25.5705H61.0244V25.5705Z"/></svg>
                Mastodon
              </a>
              <hr class="share-panel__divider" aria-hidden="true">
              <button class="share-panel__item" id="share-copy" type="button" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
                Copy link
              </button>
              <a class="share-panel__item" id="share-email" href="#" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
                Email
              </a>
            </div>
          </div>

          {# Reading settings moved into the global display-settings panel
             accessible from the masthead. Article-only controls (reading
             ruler, paragraph numbers, auto-scroll) appear there only on
             pages with an .article-body. #}
          {% if false %}
          <div class="reading-settings-wrap">
            <button class="article-action-btn" id="reading-settings-btn" type="button"
              aria-label="Reading settings"
              aria-expanded="false"
              aria-controls="reading-settings-panel">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
                <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
                <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
              </svg>
              <span class="btn-label">Reading</span>
            </button>
            <div id="reading-settings-panel" class="reading-settings-panel" hidden>
              <button class="rs-panel-close" type="button" aria-label="Close reading settings" onclick="this.parentElement.hidden=true;var b=document.getElementById('reading-settings-btn');if(b)b.setAttribute('aria-expanded','false');">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
              <div class="rs-group">
                <label class="rs-label" for="rs-font-size">Text size</label>
                <div class="rs-size-row">
                  <span class="rs-size-a rs-small" aria-hidden="true">A</span>
                  <input type="range" class="rs-slider" id="rs-font-size" min="14" max="24" step="1" value="18" aria-label="Font size in pixels">
                  <span class="rs-size-a rs-large" aria-hidden="true">A</span>
                </div>
              </div>
              <div class="rs-group">
                <label class="rs-label" for="rs-font-select">Font</label>
                <select id="rs-font-select" class="rs-select">
                  <optgroup label="Site fonts">
                    <option value="serif">Source Serif (default)</option>
                    <option value="sans">DM Sans</option>
                    <option value="lora">Lora</option>
                    <option value="playfair">Playfair Display</option>
                  </optgroup>
                  <optgroup label="Serif">
                    <option value="georgia">Georgia</option>
                    <option value="palatino">Palatino</option>
                    <option value="times">Times New Roman</option>
                    <option value="garamond">Garamond</option>
                    <option value="bookman">Bookman Old Style</option>
                  </optgroup>
                  <optgroup label="Sans-serif">
                    <option value="system">System default</option>
                    <option value="arial">Arial / Helvetica</option>
                    <option value="verdana">Verdana</option>
                    <option value="trebuchet">Trebuchet MS</option>
                    <option value="tahoma">Tahoma</option>
                    <option value="century">Century Gothic</option>
                  </optgroup>
                  <optgroup label="Monospace">
                    <option value="mono">SF Mono / Consolas</option>
                    <option value="courier">Courier New</option>
                    <option value="lucida">Lucida Console</option>
                  </optgroup>
                  <optgroup label="Web fonts (loaded on demand)">
                    <option value="inter">Inter</option>
                    <option value="merriweather">Merriweather</option>
                    <option value="roboto">Roboto</option>
                    <option value="opensans">Open Sans</option>
                    <option value="baskerville">Libre Baskerville</option>
                    <option value="crimson">Crimson Pro</option>
                    <option value="ibmplex">IBM Plex Serif</option>
                    <option value="literata">Literata</option>
                    <option value="atkinson">Atkinson Hyperlegible</option>
                  </optgroup>
                </select>
              </div>
              <div class="rs-group">
                <p class="rs-label" id="rs-spacing-label">Line spacing</p>
                <div class="rs-btngroup" role="group" aria-labelledby="rs-spacing-label">
                  <button class="rs-btn rs-icon-btn" data-rs-spacing="tight" type="button" title="Tight" aria-label="Tight">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="11" x2="21" y2="11"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="3" y1="19" x2="21" y2="19"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn is-active" data-rs-spacing="normal" type="button" title="Normal" aria-label="Normal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="5" x2="21" y2="5"/><line x1="3" y1="11" x2="21" y2="11"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn" data-rs-spacing="relaxed" type="button" title="Relaxed" aria-label="Relaxed">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="4" x2="21" y2="4"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn" data-rs-spacing="loose" type="button" title="Loose" aria-label="Loose">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="3" x2="21" y2="3"/><line x1="3" y1="13" x2="21" y2="13"/></svg>
                  </button>
                </div>
              </div>
              <div class="rs-group">
                <p class="rs-label" id="rs-width-label">Text width</p>
                <div class="rs-btngroup" role="group" aria-labelledby="rs-width-label">
                  <button class="rs-btn rs-icon-btn" data-rs-width="narrow" type="button" title="Narrow" aria-label="Narrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="7" y1="4" x2="17" y2="4"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="14" x2="17" y2="14"/><line x1="7" y1="19" x2="13" y2="19"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn is-active" data-rs-width="normal" type="button" title="Normal" aria-label="Normal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="4"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="14" x2="20" y2="14"/><line x1="4" y1="19" x2="14" y2="19"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn" data-rs-width="wide" type="button" title="Wide" aria-label="Wide">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="2" y1="4" x2="22" y2="4"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="2" y1="14" x2="22" y2="14"/><line x1="2" y1="19" x2="16" y2="19"/></svg>
                  </button>
                </div>
              </div>
              <div class="rs-group">
                <p class="rs-label" id="rs-word-spacing-label">Word spacing</p>
                <div class="rs-btngroup" role="group" aria-labelledby="rs-word-spacing-label">
                  <button class="rs-btn rs-icon-btn is-active" data-rs-wordspace="normal" type="button" title="Normal" aria-label="Normal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="2" y="7" width="9" height="10" rx="1"/><rect x="13" y="7" width="9" height="10" rx="1"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn" data-rs-wordspace="wide" type="button" title="Wide" aria-label="Wide">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="1" y="7" width="8" height="10" rx="1"/><rect x="13" y="7" width="8" height="10" rx="1"/></svg>
                  </button>
                  <button class="rs-btn rs-icon-btn" data-rs-wordspace="wider" type="button" title="Wider" aria-label="Wider">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="1" y="7" width="7" height="10" rx="1"/><rect x="14" y="7" width="7" height="10" rx="1"/></svg>
                  </button>
                </div>
              </div>
              <div class="rs-group rs-toggles">
                <label class="rs-toggle">
                  <input type="checkbox" id="rs-ruler" class="rs-toggle__input">
                  <span class="rs-toggle__label">Reading ruler</span>
                </label>
                <div id="rs-ruler-options" hidden style="margin-top:var(--space-2);padding-left:var(--space-1);">
                  <div style="margin-bottom:var(--space-2);">
                    <label style="font-size:var(--text-xs);color:var(--color-ink-faint);display:block;margin-bottom:var(--space-1);">Thickness</label>
                    <input type="range" class="rs-slider" id="rs-ruler-thick" min="1" max="8" step="1" value="2" aria-label="Ruler thickness">
                  </div>
                  <div style="margin-bottom:var(--space-2);">
                    <label style="font-size:var(--text-xs);color:var(--color-ink-faint);display:block;margin-bottom:var(--space-1);">Color</label>
                    <div class="rs-btngroup" role="group">
                      <button class="rs-swatch is-active" data-rs-ruler-color="accent" type="button" style="background:var(--color-accent);" title="Accent" aria-label="Accent"></button>
                      <button class="rs-swatch" data-rs-ruler-color="red" type="button" style="background:#e53e3e;" title="Red" aria-label="Red"></button>
                      <button class="rs-swatch" data-rs-ruler-color="blue" type="button" style="background:#3182ce;" title="Blue" aria-label="Blue"></button>
                      <button class="rs-swatch" data-rs-ruler-color="green" type="button" style="background:#38a169;" title="Green" aria-label="Green"></button>
                      <button class="rs-swatch" data-rs-ruler-color="yellow" type="button" style="background:#d69e2e;" title="Yellow" aria-label="Yellow"></button>
                      <button class="rs-swatch" data-rs-ruler-color="black" type="button" style="background:#111;" title="Black" aria-label="Black"></button>
                      <button class="rs-swatch" data-rs-ruler-color="white" type="button" style="background:#eee;border:1px solid var(--color-rule);" title="White" aria-label="White"></button>
                    </div>
                  </div>
                  <div>
                    <label style="font-size:var(--text-xs);color:var(--color-ink-faint);display:block;margin-bottom:var(--space-1);">Style</label>
                    <div class="rs-btngroup" role="group">
                      <button class="rs-btn rs-icon-btn is-active" data-rs-ruler-style="solid" type="button" title="Solid" aria-label="Solid">
                        <svg width="16" height="2" viewBox="0 0 16 2"><line x1="0" y1="1" x2="16" y2="1" stroke="currentColor" stroke-width="2"/></svg>
                      </button>
                      <button class="rs-btn rs-icon-btn" data-rs-ruler-style="dashed" type="button" title="Dashed" aria-label="Dashed">
                        <svg width="16" height="2" viewBox="0 0 16 2"><line x1="0" y1="1" x2="16" y2="1" stroke="currentColor" stroke-width="2" stroke-dasharray="4 2"/></svg>
                      </button>
                      <button class="rs-btn rs-icon-btn" data-rs-ruler-style="dotted" type="button" title="Dotted" aria-label="Dotted">
                        <svg width="16" height="2" viewBox="0 0 16 2"><line x1="0" y1="1" x2="16" y2="1" stroke="currentColor" stroke-width="2" stroke-dasharray="1 2"/></svg>
                      </button>
                      <button class="rs-btn rs-icon-btn" data-rs-ruler-style="glow" type="button" title="Glow" aria-label="Glow">
                        <svg width="16" height="6" viewBox="0 0 16 6"><line x1="0" y1="3" x2="16" y2="3" stroke="currentColor" stroke-width="2" filter="url(#glow)"/><defs><filter id="glow"><feGaussianBlur stdDeviation="1" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs></svg>
                      </button>
                    </div>
                  </div>
                </div>
                <label class="rs-toggle">
                  <input type="checkbox" id="rs-para-nums" class="rs-toggle__input">
                  <span class="rs-toggle__label">Paragraph numbers</span>
                </label>
              </div>
              <div class="rs-group" id="rs-autoscroll-group">
                <label class="rs-toggle">
                  <input type="checkbox" id="rs-autoscroll" class="rs-toggle__input">
                  <span class="rs-toggle__label">Auto-scroll</span>
                </label>
                <div id="rs-autoscroll-speed" hidden style="margin-top:var(--space-2);">
                  <input type="range" class="rs-slider" id="rs-scroll-speed" min="1" max="10" step="1" value="3" aria-label="Scroll speed">
                  <div style="display:flex;justify-content:space-between;font-size:var(--text-xs);color:var(--color-ink-faint);"><span>Slow</span><span>Fast</span></div>
                </div>
              </div>
              <button type="button" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);background:none;border:none;cursor:pointer;padding:var(--space-1) 0;" onclick="if(window.__resetReadingSettings)window.__resetReadingSettings();">Reset to defaults</button>
            </div>
          </div>
          {% endif %}

          {# 6. Download (.txt / .md / .epub) #}
          <div class="download-wrap">
            <button class="article-action-btn" id="download-btn" type="button"
              aria-label="Download article"
              aria-expanded="false"
              aria-controls="download-panel"
              data-title="{{ title | escape }}"
              data-author="{{ (authors[author].name or authorName or author) | default('') }}"
              data-date="{{ page.date | htmlDateString }}"
              data-url="{{ site.url }}{{ page.url }}"
              data-slug="{{ page.fileSlug }}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              <span class="btn-label">Download</span>
            </button>
            <div id="download-panel" class="download-panel" hidden role="menu">
              <button class="download-panel__item" id="dl-txt" type="button" role="menuitem">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>
                Plain text (.txt)
              </button>
              <button class="download-panel__item" id="dl-md" type="button" role="menuitem">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
                Markdown (.md)
              </button>
            </div>
          </div>

          {# 7. Cite #}
          <button class="article-action-btn" id="cite-btn" type="button" aria-label="Cite this article" aria-expanded="false" aria-controls="cite-modal">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.685.54-2.293.44-.6 1.05-1.05 1.83-1.343.78-.295 1.56-.43 2.34-.43v-1.52c-.976 0-1.94.16-2.886.48-.95.32-1.8.824-2.556 1.51-.755.685-1.347 1.54-1.78 2.563-.432 1.025-.65 2.218-.65 3.58 0 1.36.22 2.47.65 3.33.432.86 1.02 1.5 1.76 1.92.74.42 1.57.63 2.48.63.97 0 1.79-.22 2.46-.66.67-.44 1.17-1.03 1.5-1.77.33-.74.5-1.55.5-2.44zm9 0c0-.88-.23-1.618-.69-2.217-.326-.42-.77-.692-1.327-.817-.56-.124-1.074-.132-1.54-.022-.16-.95.1-1.685.54-2.294.44-.606 1.05-1.056 1.83-1.35.78-.294 1.56-.43 2.34-.43v-1.52c-.976 0-1.94.16-2.886.48-.95.32-1.8.825-2.556 1.51-.755.686-1.347 1.54-1.78 2.565-.432 1.022-.65 2.216-.65 3.578 0 1.36.22 2.47.65 3.33.432.86 1.02 1.5 1.76 1.92.74.42 1.57.63 2.48.63.97 0 1.79-.22 2.46-.66.67-.44 1.17-1.03 1.5-1.77.33-.74.5-1.55.5-2.44z"/>
            </svg>
            <span class="btn-label">Cite</span>
          </button>

          {# 7b. Revision history (only if repo configured) #}
          {% if site.repo and site.repo.owner %}
          <button class="article-action-btn" id="revision-history-btn" type="button"
            aria-label="View revision history"
            data-source-path="{{ page.inputPath }}">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/>
            </svg>
            <span class="btn-label">History</span>
          </button>
          {% endif %}

          {# 8. Comments #}
          {% if site.comments and site.comments.appId %}
          <button class="article-action-btn" type="button" aria-label="Comments"
            onclick="window.__tftShowComments(null, true);">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            <span class="btn-label">Comment</span>
          </button>
          {% endif %}

          {# 9. Feedback (popup form) #}
          <div class="article-feedback-wrap">
            <button class="article-action-btn" type="button" id="article-feedback-btn" aria-label="Send feedback" aria-expanded="false"
              onclick="var p=document.getElementById('article-feedback-popup');p.hidden=!p.hidden;this.setAttribute('aria-expanded',String(!p.hidden));if(!p.hidden){var self=this;setTimeout(function(){document.addEventListener('click',function cl(e){if(!p.contains(e.target)&&!self.contains(e.target)){p.hidden=true;self.setAttribute('aria-expanded','false');document.removeEventListener('click',cl);}});},10);}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>
              </svg>
              <span class="btn-label">Feedback</span>
            </button>
            <div id="article-feedback-popup" class="article-feedback-popup" hidden>
              <header class="article-feedback-popup__header">
                <div class="article-feedback-popup__head-text">
                  <p class="article-feedback-popup__kicker">{{ site.title }}</p>
                  <h2 class="article-feedback-popup__title">Send feedback</h2>
                </div>
                <button type="button" class="article-feedback-popup__close" aria-label="Close feedback"
                  onclick="var p=document.getElementById('article-feedback-popup');p.hidden=true;var b=document.getElementById('article-feedback-btn');if(b)b.setAttribute('aria-expanded','false');">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </header>
              <form class="article-feedback-form" action="https://api.web3forms.com/submit" method="POST">
                <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
                <input type="hidden" name="subject" value="Article feedback, {{ title | escape }}">
                <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
                <input type="hidden" name="from_name" value="{{ site.title }} Article Feedback">
                <input type="hidden" name="page_url" value="{{ site.url }}{{ page.url }}">
                <input type="checkbox" name="botcheck" class="article-feedback-form__botcheck" tabindex="-1" autocomplete="off">

                <label class="article-feedback-form__field">
                  <span class="article-feedback-form__label">Category</span>
                  <select name="category" class="article-feedback-form__input">
                    <option value="General feedback">General feedback</option>
                    <option value="Suggestion">Suggestion</option>
                    <option value="Question">Question</option>
                    <option value="Compliment">Compliment</option>
                  </select>
                </label>

                <label class="article-feedback-form__field">
                  <span class="article-feedback-form__label">Your feedback</span>
                  <textarea name="message" rows="4" required placeholder="Tell us what you think…" class="article-feedback-form__input article-feedback-form__textarea"></textarea>
                </label>

                <label class="article-feedback-form__field">
                  <span class="article-feedback-form__label">Email <span class="article-feedback-form__label-hint">(optional, for a response)</span></span>
                  <input type="email" name="email" autocomplete="email" class="article-feedback-form__input">
                </label>


                <div class="article-feedback-form__actions">
                  <button type="submit" class="article-feedback-form__submit w3f__submit">Send feedback</button>
                </div>

                <div class="article-feedback-form__footer">
                  <p>We read every piece of feedback.</p>
                  <p>Found an error? <a href="/corrections/report/">Report a correction</a></p>
                  <p>Want to respond to this piece? <a href="/letters/submit/">Write a letter to the editor</a></p>
                </div>
              </form>
              <footer class="article-feedback-popup__footer">
                <p class="article-feedback-popup__footer-mark">{{ site.title }}</p>
                <p class="article-feedback-popup__footer-tag">{{ site.tagline or "Independent journalism, freely shared." }}</p>
              </footer>
            </div>
          </div>

        </div>

        {# Citation data, consumed by JS to build formatted citations #}
        <div id="cite-data"
          data-title="{{ title | escape }}"
          data-author="{{ (authors[author].name or authorName or author) | default('') }}"
          data-date="{{ page.date | isoDate }}"
          data-publication="{{ site.title }}"
          data-url="{{ site.url }}{{ page.url }}"
          hidden></div>

      </header>

      {# Cite modal #}
      <div id="cite-overlay" class="cite-overlay" hidden aria-hidden="true"></div>
      <div id="cite-modal" class="cite-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cite-modal-title">
        <div class="cite-modal__inner">
          <div class="cite-modal__header">
            <p class="cite-modal__title" id="cite-modal-title">Cite This Article</p>
            <button id="cite-close" class="cite-modal__close" type="button" aria-label="Close citation panel">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
          <div class="cite-modal__tabs" role="tablist" aria-label="Citation format">
            <button class="cite-tab is-active" data-format="apa"     role="tab" aria-selected="true"  type="button">APA 7th</button>
            <button class="cite-tab"           data-format="mla"     role="tab" aria-selected="false" type="button">MLA 9th</button>
            <button class="cite-tab"           data-format="chicago" role="tab" aria-selected="false" type="button">Chicago 17th</button>
          </div>
          <div class="cite-modal__body">
            <p id="cite-text" class="cite-modal__text"></p>
          </div>
          <button id="cite-copy-btn" class="cite-modal__copy-btn" type="button">Copy citation</button>
        </div>
      </div>

      {# ── "In response to" banner ───────────────────────────────
         responseTo accepts either a string URL (internal article path
         OR external absolute URL) or an object for richer external
         metadata: { url, title, author, publisher, date }. Internal
         responses look up the target article in collections; external
         responses render the metadata directly. #}
      {% if responseTo %}
      {% set _rtUrl       = responseTo.url       if responseTo.url else responseTo %}
      {% set _rtTitle     = responseTo.title     if responseTo.title else null %}
      {% set _rtAuthor    = responseTo.author    if responseTo.author else null %}
      {% set _rtPublisher = responseTo.publisher if responseTo.publisher else null %}
      {% set _rtDate      = responseTo.date      if responseTo.date else null %}
      {% set _rtIsExternal = (_rtUrl | string).startsWith('http') %}
      {% set responseTarget = null %}
      {% if not _rtIsExternal %}
        {% for item in collections.allContent %}
          {% if item.url == _rtUrl %}{% set responseTarget = item %}{% endif %}
        {% endfor %}
      {% endif %}
      <aside class="response-banner{% if _rtIsExternal %} response-banner--external{% endif %}">
        <span class="response-banner__label">In response to{% if _rtIsExternal %} (external){% endif %}</span>
        <a class="response-banner__link" href="{{ _rtUrl }}"{% if _rtIsExternal %} target="_blank" rel="noopener"{% endif %}>
          {% if responseTarget %}{{ responseTarget.data.title }}
          {% elif _rtTitle %}{{ _rtTitle }}
          {% else %}{{ _rtUrl }}{% endif %}
        </a>
        {% if _rtIsExternal and (_rtAuthor or _rtPublisher or _rtDate) %}
        <span class="response-banner__meta">
          {% if _rtAuthor %}<span>{{ _rtAuthor }}</span>{% endif %}
          {% if _rtPublisher %}<span class="response-banner__publisher">{{ _rtPublisher }}</span>{% endif %}
          {% if _rtDate %}<time datetime="{{ _rtDate | htmlDateString }}">{{ _rtDate | readableDate }}</time>{% endif %}
        </span>
        {% endif %}
      </aside>
      {% endif %}

      {# Series navigation (shown before lead image if article belongs to a series) #}
      {% if series %}
      {% set seriesItems = collections.allContent | seriesArticles(series) %}
      {% include "partials/series-nav.njk" %}
      {% endif %}

      {# Argument map (for opinion/analysis pieces with structured arguments) #}
      {% if argument %}
      {% include "partials/argument-map.njk" %}
      {% endif %}

      {# Lead image #}
      {% if image %}
      <figure class="article-lead-image">
        <img src="{{ image }}" alt="{{ imageAlt or title }}" loading="eager" fetchpriority="high" width="1200" height="630">
        {% if imageCaption %}
        <figcaption>{{ imageCaption }}</figcaption>
        {% endif %}
      </figure>
      {% endif %}

      {# Profile-specific header: audio player for podcast, embed for data viz #}
      {% if profile == "podcast" and audioUrl %}
      <figure class="profile-audio">
        <audio controls preload="metadata" src="{{ audioUrl }}"></audio>
        <figcaption>Listen to this episode. Transcript below.</figcaption>
      </figure>
      {% endif %}
      {% if profile == "datavisualization" and embedUrl %}
      <figure class="profile-embed">
        <iframe src="{{ embedUrl }}" loading="lazy" title="{{ title | escape }}" style="width:100%;min-height:480px;border:1px solid var(--color-rule);"></iframe>
      </figure>
      {% endif %}

      {# Body copy #}
      <div class="article-body">
        {{ content | safe }}
      </div>

      {# Footnotes, visible, hideable #}
      <div id="article-footnotes" class="article-footnotes"></div>

      {# Article footer #}
      <footer class="article-footer">

        {# Corrections log #}
        {% if corrections and corrections.length %}
        <div class="corrections-log">
          <p class="corrections-log__title">Corrections</p>
          {% for correction in corrections %}
          <div class="corrections-log__entry">
            <time class="corrections-log__date" datetime="{{ correction.date }}">{{ correction.date }}</time>
            <p class="corrections-log__text">{{ correction.description }}</p>
          </div>
          {% endfor %}
        </div>
        {% endif %}

      </footer>

      {# Backlinks, other articles that reference this one #}
      {% set backlinks = collections.allContent | backlinksTo(page.url) %}
      {% if backlinks.length %}
      <aside class="backlinks-section">
        <p class="backlinks-section__title">Referenced in</p>
        <ul class="backlinks-section__list">
          {% for item in backlinks %}
          <li class="backlinks-section__item">
            {% if item.data.section %}
            <span class="backlinks-section__section">{{ item.data.section }}</span>
            {% endif %}
            <a class="backlinks-section__link" href="{{ item.url }}">{{ item.data.title }}</a>
            <time class="backlinks-section__date">{{ item.date | readableDate }}</time>
          </li>
          {% endfor %}
        </ul>
      </aside>
      {% endif %}


      {# Webmentions, replies, likes, reposts pulled from webmention.io
         at build time. Silent empty state if nothing yet. #}
      {% include "partials/article-webmentions.njk" %}

      {# Comments, always rendered, comments provider is always
         configured (cusdis app id is set in site.js with a fallback). #}
      <div class="article-comments">
        <div class="article-comments__header">
          <div class="article-comments__heading">
            <span class="article-comments__title">Comments</span>
            <a class="article-comments__guidelines" href="/community-guidelines/">Community guidelines</a>
          </div>
          <button type="button" class="article-comments__toggle" id="comments-toggle"
            onclick="window.__tftShowComments(this);">
            Show comments
          </button>
        </div>
        <div id="comments-body" hidden>
          <div class="article-comments__loading" hidden>Loading comments…</div>
          <div id="cusdis_thread"
            data-host="{{ site.comments.host }}"
            data-app-id="{{ site.comments.appId }}"
            data-page-id="{{ page.url }}"
            data-page-url="{{ site.url }}{{ page.url }}"
            data-page-title="{{ title }}">
          </div>
        </div>
      </div>

<script>
// Unified comments-toggle handler used by the inline "Show comments"
// button and by the bottom toolbar's comments icon. Handles three
// states cleanly:
//   1. Cusdis script not yet loaded → inject + initial() on load
//   2. Cusdis loaded but thread empty (e.g. SPA-nav left it stale) →
//      call CUSDIS.initial() against the current data-* attributes
//   3. Already rendered → just toggle visibility / scroll
window.__tftShowComments = window.__tftShowComments || function (btn, alwaysOpen) {
  var body = document.getElementById('comments-body');
  if (!body) return;
  var inlineBtn = document.getElementById('comments-toggle');
  var loading = body.querySelector('.article-comments__loading');
  var thread = document.getElementById('cusdis_thread');
  var willShow = alwaysOpen || body.hidden;
  body.hidden = !willShow;
  if (inlineBtn) inlineBtn.textContent = willShow ? 'Hide comments' : 'Show comments';
  if (!willShow) return;
  if (thread) {
    thread.setAttribute('data-theme', document.documentElement.getAttribute('data-theme') || 'light');
  }
  function rerender() {
    try { if (window.CUSDIS && typeof window.CUSDIS.initial === 'function') window.CUSDIS.initial(); } catch (e) {}
    if (loading) loading.hidden = true;
  }
  if (window.CUSDIS && typeof window.CUSDIS.initial === 'function') {
    rerender();
  } else {
    if (loading) loading.hidden = false;
    var existing = document.querySelector('script[data-cusdis]');
    if (!existing) {
      var s = document.createElement('script');
      s.async = true;
      s.defer = true;
      s.dataset.cusdis = 'true';
      s.src = '{{ site.comments.host }}/js/cusdis.es.js';
      s.onload = rerender;
      s.onerror = function () { if (loading) loading.textContent = 'Comments are unavailable right now.'; };
      document.body.appendChild(s);
    } else {
      // Script tag exists but window.CUSDIS isn't ready yet — poll briefly.
      var tries = 0;
      var iv = setInterval(function () {
        tries += 1;
        if (window.CUSDIS) { clearInterval(iv); rerender(); }
        else if (tries > 30) { clearInterval(iv); if (loading) loading.textContent = 'Comments are taking a while to load — refresh the page if they don’t appear.'; }
      }, 200);
    }
  }
  // Scroll into view (toolbar invocation passes alwaysOpen, so scroll there).
  // Target the .article-comments wrapper rather than #comments-body so the
  // user lands on the "Comments" heading, not deep inside the cusdis thread
  // below the header / toggle button.
  if (alwaysOpen) {
    var anchor = body.closest('.article-comments') || body;
    var top = anchor.getBoundingClientRect().top + window.scrollY - 80;
    window.scrollTo({ top: top, behavior: 'smooth' });
  }
};
</script>

    </div>{# /.article-layout__body #}

  </div>{# /.article-layout__inner #}
</div>{# /.container #}

{# Article-info toggle — read the persisted preference and apply
   data-meta-collapsed on the .article-header on every page load /
   spa-nav swap. Tapping #ann-info-btn toggles + persists. #}
<script>
(function () {
  var KEY = 'tft-article-meta-expanded';
  function apply() {
    var header = document.querySelector('.article-header[data-meta-collapsed]');
    var btn    = document.getElementById('ann-info-btn');
    if (!header) return;
    var expanded = false;
    try { expanded = localStorage.getItem(KEY) === 'true'; } catch (e) {}
    header.setAttribute('data-meta-collapsed', expanded ? 'false' : 'true');
    if (btn) {
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.setAttribute('aria-label', expanded ? 'Hide article details' : 'Show article details');
    }
  }
  function bind() {
    var btn = document.getElementById('ann-info-btn');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', function () {
      var current = false;
      try { current = localStorage.getItem(KEY) === 'true'; } catch (e) {}
      var next = !current;
      try { localStorage.setItem(KEY, next ? 'true' : 'false'); } catch (e) {}
      apply();
    });
  }
  // The toolbar (containing #ann-info-btn) renders LATER in the
  // article.njk source than this script, so on initial page load
  // the button doesn't exist yet when the script runs. Defer the
  // first apply()/bind() until after parsing finishes. SPA-nav
  // re-renders scripts after innerHTML, so spa:contentswap can
  // call directly.
  function run() { apply(); bind(); }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
  document.addEventListener('spa:contentswap', run);
})();
</script>

