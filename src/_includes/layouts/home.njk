---
layout: layouts/base.njk
---

<div class="container front-page">

  {# -- Hero / brand statement -- #}
  <section class="recipe-hero" style="border-bottom: 0; padding: var(--space-12) 0 var(--space-6);">
    <span class="recipe-hero__eyebrow">A community food publication &middot; Free and open source</span>
    <h1 class="recipe-hero__title" style="max-width: 16ch;">Cook better. Together.</h1>
    <p class="recipe-hero__dek">
      Tested recipes, technique guides, food journalism, and reviews -- written by cooks, for cooks. Every recipe is licensed Creative Commons. Every line of code is on GitHub.
    </p>
    <p style="margin-top: var(--space-5); display: flex; gap: var(--space-3); flex-wrap: wrap;">
      <a href="/recipes/" class="btn btn--primary" style="font-family:var(--font-ui);font-weight:600;background:var(--color-accent);color:var(--color-bg);padding:10px 20px;text-decoration:none;display:inline-block;">Browse Recipes</a>
      <a href="/submit/recipe/" class="btn" style="font-family:var(--font-ui);font-weight:600;background:var(--color-bg);color:var(--color-ink);border:1px solid var(--color-rule);padding:10px 20px;text-decoration:none;display:inline-block;">Submit a Recipe</a>
    </p>
  </section>

  {# -- Latest recipes -- #}
  {% set latestRecipes = collections.recipes | reverse %}
  {% if latestRecipes.length > 0 %}
  <section class="home-strip" aria-label="Latest recipes" style="margin-top: var(--space-12);">
    <header class="home-section-head" style="display:flex;justify-content:space-between;align-items:baseline;padding-bottom: var(--space-4); margin-bottom: var(--space-6); position: relative;">
      <h2 style="font-family: var(--font-headline); font-size: var(--text-xl); margin: 0;" data-rough="underline" data-rough-color="accent">Latest Recipes</h2>
      <a href="/recipes/" style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-accent); text-decoration: none;">All recipes &rarr;</a>
    </header>
    <div class="recipe-grid">
      {% for recipe in latestRecipes | limit(6) %}
        {% set recipe = recipe %}
        {% include "partials/recipe-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# -- Techniques + Reviews two-column -- #}
  <section style="margin-top: var(--space-12); display: grid; gap: var(--space-10); grid-template-columns: 1fr;">
    {% set latestTechniques = collections.techniques | reverse | limit(3) %}
    {% if latestTechniques.length > 0 %}
    <div>
      <header style="display:flex;justify-content:space-between;align-items:baseline; padding-bottom: var(--space-4); margin-bottom: var(--space-5);">
        <h2 style="font-family: var(--font-headline); font-size: var(--text-lg); margin: 0;" data-rough="underline" data-rough-color="olive">Techniques</h2>
        <a href="/techniques/" style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-techniques); text-decoration: none;">All techniques &rarr;</a>
      </header>
      <ul style="list-style:none;padding:0;margin:0;">
        {% for item in latestTechniques %}
        <li style="padding: var(--space-3) 0; border-bottom: 1px solid var(--color-rule);">
          <a href="{{ item.url }}" style="font-family: var(--font-headline); font-size: var(--text-md); font-weight: 600; color: var(--color-ink); text-decoration: none; display: block; line-height: var(--leading-snug);">{{ item.data.title }}</a>
          {% if item.data.dek %}<p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-ink-muted); margin: 4px 0 0; font-style: italic;">{{ item.data.dek }}</p>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% set latestReviews = collections.reviews | reverse | limit(3) %}
    {% if latestReviews.length > 0 %}
    <div>
      <header style="display:flex;justify-content:space-between;align-items:baseline; padding-bottom: var(--space-4); margin-bottom: var(--space-5);">
        <h2 style="font-family: var(--font-headline); font-size: var(--text-lg); margin: 0;" data-rough="underline" data-rough-color="reviews">Reviews</h2>
        <a href="/reviews/" style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-reviews); text-decoration: none;">All reviews &rarr;</a>
      </header>
      <ul style="list-style:none;padding:0;margin:0;">
        {% for item in latestReviews %}
        <li style="padding: var(--space-3) 0; border-bottom: 1px solid var(--color-rule);">
          <a href="{{ item.url }}" style="font-family: var(--font-headline); font-size: var(--text-md); font-weight: 600; color: var(--color-ink); text-decoration: none; display: block; line-height: var(--leading-snug);">{{ item.data.title }}</a>
          {% if item.data.dek %}<p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-ink-muted); margin: 4px 0 0; font-style: italic;">{{ item.data.dek }}</p>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </section>

  {# -- Community call-out -- #}
  <section data-rough="frame" data-rough-color="accent" style="margin-top: var(--space-16); padding: var(--space-10) var(--space-8); background: var(--color-bg-alt); position: relative;">
    <p style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent); margin: 0 0 var(--space-3);">Built by readers</p>
    <h2 style="font-family: var(--font-masthead); font-size: var(--text-xl); margin: 0 0 var(--space-3);">This site belongs to the people who cook from it.</h2>
    <p style="font-family: var(--font-body); font-size: var(--text-md); line-height: var(--leading-relaxed); color: var(--color-ink-muted); max-width: 60ch; margin: 0 0 var(--space-5);">
      Every recipe is tested. Every contributor is credited. The whole codebase is open source on GitHub. Submit a recipe, pitch a story, or open a pull request -- whichever feels like your speed.
    </p>
    <p style="display: flex; gap: var(--space-3); flex-wrap: wrap;">
      <a href="/submit/" style="font-family:var(--font-ui);font-weight:600;background:var(--color-accent);color:var(--color-bg);padding:10px 20px;text-decoration:none;display:inline-block;">Ways to contribute</a>
      <a href="https://github.com/jonajinga/the-umami-post" style="font-family:var(--font-ui);font-weight:600;background:var(--color-bg);color:var(--color-ink);border:1px solid var(--color-rule);padding:10px 20px;text-decoration:none;display:inline-block;">View on GitHub</a>
    </p>
  </section>

</div>{# /.container #}

<script src="/assets/js/rough-decorations.js?v={{ buildTime }}" defer></script>
