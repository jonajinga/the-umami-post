{# Star rating. Expects: rating (0-5). Renders as a rough.js sketched
   5-star row via rough-decorations.js, with the numeric value as
   accessible label + visible suffix. #}
{% set _r = rating or 0 %}
<span class="star-rating" aria-label="Rated {{ _r }} out of 5">
  <span data-rough="stars" data-rough-rating="{{ _r }}" data-rough-color="reviews"></span>
  <span class="star-rating__value">{{ _r }}/5</span>
</span>
