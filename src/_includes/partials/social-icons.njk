{#
  Social icon strip. Expects a `social` object with keys like x, bluesky,
  mastodon, linkedin, github, threads, instagram, website, email.
  Only populated keys render, everything else is silently skipped.

  Usage:
    {% set social = authorData.social %}
    {% include "partials/social-icons.njk" %}
#}
{% if social %}
{% set hasAny = social.x or social.bluesky or social.mastodon or social.linkedin or social.github or social.threads or social.instagram or social.website or social.email %}
{% if hasAny %}
<ul class="social-icons" role="list" aria-label="Social links">
