{#
  article-audio.njk — small play-button toggle, only when a pre-
  generated MP3 exists for this article. Renders as a single icon
  button (play triangle by default; switches to pause bars when the
  global audio bar is playing this article via JS state).

  Click routes through the global audio bar via the standard
  [data-tft-audio-trigger] mechanism — same as every other listen
  pill on the site.
#}
{% set _aud = audioManifest[page.url] %}
{% if _aud %}
{% set _mins = (_aud.duration / 60) | round(0, 'ceil') %}
<button type="button"
        class="listen-btn listen-btn--icon"
        data-tft-audio-trigger
        data-tft-audio-src="{{ _aud.mp3 }}"
        data-tft-audio-url="{{ page.url }}"
        data-tft-audio-title="{{ title | escape }}"
        data-tft-audio-duration="{{ _aud.duration }}"
        data-umami-event="article-listen"
        aria-label="Listen to this article, {{ _mins }} {{ "minute" if _mins == 1 else "minutes" }}"
        title="Listen, {{ _mins }} {{ "minute" if _mins == 1 else "minutes" }}">
  <svg class="listen-btn__play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4"/></svg>
  <svg class="listen-btn__pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
</button>
{% endif %}
