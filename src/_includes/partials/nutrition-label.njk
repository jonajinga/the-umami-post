{# Nutrition facts: summary strip in the recipe footer + a separate
   modal panel with the full FDA-style label. The modal trigger and
   overlay are wired purely in HTML/inline JS — no extra JS file. #}

{% if nutrition %}
{% set fat = nutrition.totalFat or nutrition.fat %}
{% set carbs = nutrition.totalCarbs or nutrition.carbs %}

<aside class="nutrition" data-rough="frame" data-rough-color="olive">
  <p class="nutrition__eyebrow">Nutrition facts <span>(per serving)</span></p>

  <ul class="nutrition__summary">
    {% if nutrition.calories %}<li><strong>{{ nutrition.calories }}</strong><span>Calories</span></li>{% endif %}
    {% if fat %}<li><strong>{{ fat }}</strong><span>Fat</span></li>{% endif %}
    {% if carbs %}<li><strong>{{ carbs }}</strong><span>Carbs</span></li>{% endif %}
    {% if nutrition.protein %}<li><strong>{{ nutrition.protein }}</strong><span>Protein</span></li>{% endif %}
  </ul>

  <button type="button" class="nutrition__toggle" aria-haspopup="dialog" aria-controls="nutrition-modal"
    onclick="var m=document.getElementById('nutrition-modal');var o=document.getElementById('nutrition-overlay');if(!m)return;m.hidden=false;o.hidden=false;document.body.style.overflow='hidden';m.focus();">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    <span>Full nutrition label</span>
  </button>
</aside>

{# Modal lives at body-end so its z-index escapes any clipping
   ancestor. Open: clear `hidden` on overlay + dialog. Close on
   overlay click, close button, or Escape. #}
<div id="nutrition-overlay" class="modal-overlay" hidden
  onclick="this.hidden=true;document.getElementById('nutrition-modal').hidden=true;document.body.style.overflow='';"></div>

<div id="nutrition-modal" class="modal nutrition-modal" hidden role="dialog" aria-modal="true" aria-labelledby="nutrition-modal-title" tabindex="-1">
  <header class="modal__header">
    <h2 id="nutrition-modal-title" class="modal__title">Nutrition Facts</h2>
    <button type="button" class="modal__close" aria-label="Close nutrition label"
      onclick="document.getElementById('nutrition-modal').hidden=true;document.getElementById('nutrition-overlay').hidden=true;document.body.style.overflow='';">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </header>

  <div class="modal__body">
    {% if nutrition.servings %}<p class="nutrition-modal__servings">Servings: {{ nutrition.servings }}</p>{% endif %}

    <p class="nutrition-modal__amount">Amount per serving</p>
    {% if nutrition.calories %}
    <p class="nutrition-modal__calories"><strong>Calories</strong> <span>{{ nutrition.calories }}</span></p>
    {% endif %}

    <p class="nutrition-modal__dv">% Daily Value*</p>

    <table class="nutrition-modal__table">
      <tbody>
        {% if fat %}<tr><th>Total Fat <span class="nutrition__value">{{ fat }}</span></th><td>{% if nutrition.totalFatDV %}{{ nutrition.totalFatDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.saturatedFat %}<tr class="nutrition__sub"><th>Saturated Fat <span class="nutrition__value">{{ nutrition.saturatedFat }}</span></th><td>{% if nutrition.saturatedFatDV %}{{ nutrition.saturatedFatDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.transFat %}<tr class="nutrition__sub"><th>Trans Fat <span class="nutrition__value">{{ nutrition.transFat }}</span></th><td></td></tr>{% endif %}
        {% if nutrition.cholesterol %}<tr><th>Cholesterol <span class="nutrition__value">{{ nutrition.cholesterol }}</span></th><td>{% if nutrition.cholesterolDV %}{{ nutrition.cholesterolDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.sodium %}<tr><th>Sodium <span class="nutrition__value">{{ nutrition.sodium }}</span></th><td>{% if nutrition.sodiumDV %}{{ nutrition.sodiumDV }}%{% endif %}</td></tr>{% endif %}
        {% if carbs %}<tr><th>Total Carbohydrate <span class="nutrition__value">{{ carbs }}</span></th><td>{% if nutrition.totalCarbsDV %}{{ nutrition.totalCarbsDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.dietaryFiber %}<tr class="nutrition__sub"><th>Dietary Fiber <span class="nutrition__value">{{ nutrition.dietaryFiber }}</span></th><td>{% if nutrition.dietaryFiberDV %}{{ nutrition.dietaryFiberDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.totalSugars %}<tr class="nutrition__sub"><th>Total Sugars <span class="nutrition__value">{{ nutrition.totalSugars }}</span></th><td></td></tr>{% endif %}
        {% if nutrition.addedSugars %}<tr class="nutrition__sub nutrition__sub--deep"><th>Includes Added Sugars <span class="nutrition__value">{{ nutrition.addedSugars }}</span></th><td>{% if nutrition.addedSugarsDV %}{{ nutrition.addedSugarsDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.protein %}<tr><th>Protein <span class="nutrition__value">{{ nutrition.protein }}</span></th><td></td></tr>{% endif %}
      </tbody>
    </table>

    {% if nutrition.vitaminD or nutrition.calcium or nutrition.iron or nutrition.potassium or nutrition.vitaminA or nutrition.vitaminC %}
    <table class="nutrition-modal__table nutrition-modal__table--micros">
      <tbody>
        {% if nutrition.vitaminD %}<tr><th>Vitamin D <span class="nutrition__value">{{ nutrition.vitaminD }}</span></th><td>{% if nutrition.vitaminDDV %}{{ nutrition.vitaminDDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.calcium %}<tr><th>Calcium <span class="nutrition__value">{{ nutrition.calcium }}</span></th><td>{% if nutrition.calciumDV %}{{ nutrition.calciumDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.iron %}<tr><th>Iron <span class="nutrition__value">{{ nutrition.iron }}</span></th><td>{% if nutrition.ironDV %}{{ nutrition.ironDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.potassium %}<tr><th>Potassium <span class="nutrition__value">{{ nutrition.potassium }}</span></th><td>{% if nutrition.potassiumDV %}{{ nutrition.potassiumDV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.vitaminA %}<tr><th>Vitamin A <span class="nutrition__value">{{ nutrition.vitaminA }}</span></th><td>{% if nutrition.vitaminADV %}{{ nutrition.vitaminADV }}%{% endif %}</td></tr>{% endif %}
        {% if nutrition.vitaminC %}<tr><th>Vitamin C <span class="nutrition__value">{{ nutrition.vitaminC }}</span></th><td>{% if nutrition.vitaminCDV %}{{ nutrition.vitaminCDV }}%{% endif %}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endif %}

    <p class="nutrition-modal__footnote">
      *The % Daily Value (DV) tells you how much a nutrient in a food serving contributes to a daily diet. 2,000 calories a day is used for general nutrition advice.
    </p>
    <p class="nutrition-modal__footnote nutrition-modal__footnote--est">
      Estimated values. Actual nutrition varies with substitutions, brands, and exact yields.
    </p>
  </div>
</div>
{% endif %}
