{#
  republish.njk — renders the open-license panel below the article
  byline. The TRIGGER is a tip-badge button injected directly into
  the article-header__support-row alongside "How We're Funded";
  this partial just emits the (initially hidden) panel that the
  trigger opens.

  Renders only when front matter `syndicate` is truthy. Default is
  `true` via src/content/content.11tydata.js; opt out per-article
  with `syndicate: false` for pieces with restricted material.
#}
{% if syndicate %}
<div id="republish-panel" class="republish republish--modal" role="dialog" aria-modal="true" data-article-disclosure hidden aria-labelledby="republish-heading">
  <header class="republish__header">
    <div class="republish__head-text">
      <p class="republish__kicker">{{ site.title }}</p>
      <h2 id="republish-heading" class="republish__heading">Republish this story</h2>
    </div>
    <button type="button" class="republish__close" aria-label="Close republication panel"
      onclick="var p=document.getElementById('republish-panel');if(p)p.setAttribute('hidden','');var t=document.getElementById('ann-republish-btn');if(t)t.setAttribute('aria-expanded','false');">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </header>
  <div class="republish__body">
    <p class="republish__lede">
      Free to republish under
      <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" rel="license" target="_blank" data-umami-event="license-learn">CC&nbsp;BY-NC-ND&nbsp;4.0</a>.
      Attribution required. No editing (minor time/place relative changes only). Not for commercial resale.
      See our <a href="/license/" data-umami-event="license-learn">full republication terms</a>.
    </p>
    <label class="republish__label" for="republish-html">Select all, copy, and paste into your CMS&rsquo; HTML view:</label>
    <textarea id="republish-html" class="republish__textarea" readonly rows="30" onclick="this.select()"><p><em>This story was originally published by <a href="{{ site.url }}{{ page.url }}">{{ site.title }}</a> under a <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/">CC BY-NC-ND 4.0</a> license.</em></p>
<h1>{{ title | escape }}</h1>
<p><strong>By {% if authors[author].name %}{{ authors[author].name }}{% elif authorName %}{{ authorName }}{% else %}{{ author }}{% endif %}</strong> &mdash; <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time></p>
{{ content | safe }}
<p><em>Originally: <a href="{{ site.url }}{{ page.url }}">{{ site.url }}{{ page.url }}</a></em></p></textarea>
    <button type="button" class="republish__copy" data-umami-event="republish-copy" onclick="var t=document.getElementById('republish-html');t.select();document.execCommand('copy');this.textContent='Copied';setTimeout(function(b){return function(){b.textContent='Copy to clipboard';};}(this),1800);">Copy to clipboard</button>
  </div>
  <footer class="republish__footer">
    <p class="republish__footer-mark">{{ site.title }}</p>
    <p class="republish__footer-tag">{{ site.tagline or "Independent journalism, freely shared." }}</p>
  </footer>
</div>
{% endif %}
