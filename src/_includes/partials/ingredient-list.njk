{# Ingredient list. Expects: ingredients (array of { amount, unit, name,
   prep, optional, group }), servings. Renders the scaler bar
   (label above, preset buttons + custom-multiplier input share a
   single wrap-friendly row; US / Metric below) plus the flat list. #}

<div class="recipe-scaler serving-scaler" data-recipe-scaler data-base-servings="{{ servings or 4 }}" data-unit-system="us" data-rough="frame" data-rough-color="ink">

  <div class="serving-scaler__multipliers">
    <span class="serving-scaler__label">Scale</span>
    <div class="serving-scaler__row">
      <button type="button" class="serving-scaler__btn" data-scale="0.5" data-rough="frame" data-rough-color="ink">&half;&times;</button>
      <button type="button" class="serving-scaler__btn serving-scaler__btn--active" data-scale="1" data-rough="frame" data-rough-color="yellow">1&times;</button>
      <button type="button" class="serving-scaler__btn" data-scale="2" data-rough="frame" data-rough-color="ink">2&times;</button>
      <button type="button" class="serving-scaler__btn" data-scale="3" data-rough="frame" data-rough-color="ink">3&times;</button>
      <span class="serving-scaler__custom-stack">
        <span class="serving-scaler__custom-label">Custom</span>
        <label class="serving-scaler__custom-wrap" data-rough="frame" data-rough-color="ink">
          <span class="visually-hidden">Custom scale</span>
          <input type="text" class="serving-scaler__custom" inputmode="decimal" placeholder="1.5&times;" aria-label="Custom scale multiplier (e.g. 1.5)" data-rough-skip-frame>
        </label>
      </span>
    </div>
  </div>

  <div class="unit-toggle">
    <span class="serving-scaler__label">Units</span>
    <div class="unit-switch" role="group" aria-label="Measurement units" data-active="us" data-rough="frame" data-rough-color="ink">
      <span class="unit-switch__thumb" aria-hidden="true"></span>
      <button type="button" class="unit-switch__btn" data-target-unit="us" style="color:#faf6ef">US</button>
      <button type="button" class="unit-switch__btn" data-target-unit="metric" style="color:#2b1f18">Metric</button>
    </div>
  </div>

</div>

<ul class="ingredient-list" data-ingredient-list data-recipe-slug="{{ page.fileSlug }}">
  {% set lastGroup = "" %}
  {% for ing in ingredients %}
    {% if ing.group and ing.group != lastGroup %}
      <li class="ingredient-list__group-name">{{ ing.group }}</li>
      {% set lastGroup = ing.group %}
    {% endif %}
    <li class="ingredient{% if ing.optional %} ingredient--optional{% endif %}">
      <input type="checkbox" class="ingredient__check" aria-label="Check off {{ ing.name }}">
      <span class="ingredient__text">
        {% if ing.amount %}<span class="ingredient__amount" data-base-amount="{{ ing.amount }}" data-base-unit="{{ ing.unit or '' }}">{{ ing.amount }}</span>{% endif %}
        {% if ing.unit %}<span class="ingredient__unit">{{ ing.unit }}</span>{% endif %}
        <span class="ingredient__name">{{ ing.name }}</span>{% if ing.prep %}<span class="ingredient__prep">, {{ ing.prep }}</span>{% endif %}
      </span>
    </li>
  {% endfor %}
</ul>
