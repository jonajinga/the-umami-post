{# Make-ahead & storage card + companion modal. The card sits in
   the recipe footer row; the trigger opens a focused modal so the
   cook can read the full plan without losing their place in the
   recipe. Renders only when `makeAhead` is set on the recipe. #}

{% if makeAhead %}
<aside class="recipe-notes recipe-notes--makeahead" data-rough="frame" data-rough-color="paprika">
  <h2>Make-ahead &amp; storage</h2>
  <div class="recipe-notes__preview">
    {{ makeAhead | safe }}
  </div>
  <button type="button" class="nutrition__toggle" aria-haspopup="dialog" aria-controls="makeahead-modal"
    onclick="var m=document.getElementById('makeahead-modal');var o=document.getElementById('makeahead-overlay');if(!m)return;m.hidden=false;o.hidden=false;document.body.style.overflow='hidden';m.focus();">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
    <span>Full make-ahead plan</span>
  </button>
</aside>

<div id="makeahead-overlay" class="modal-overlay" hidden
  onclick="this.hidden=true;document.getElementById('makeahead-modal').hidden=true;document.body.style.overflow='';"></div>

<div id="makeahead-modal" class="modal makeahead-modal" hidden role="dialog" aria-modal="true" aria-labelledby="makeahead-modal-title" tabindex="-1">
  <header class="modal__header">
    <h2 id="makeahead-modal-title" class="modal__title">Make-ahead &amp; storage</h2>
    <button type="button" class="modal__close" aria-label="Close make-ahead panel"
      onclick="document.getElementById('makeahead-modal').hidden=true;document.getElementById('makeahead-overlay').hidden=true;document.body.style.overflow='';">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </header>
  <div class="modal__body">
    {{ makeAhead | safe }}
    {% if makeAheadStorage %}
    <h3>Storage</h3>
    {{ makeAheadStorage | safe }}
    {% endif %}
    {% if makeAheadFreeze %}
    <h3>Freezing</h3>
    {{ makeAheadFreeze | safe }}
    {% endif %}
    {% if makeAheadReheat %}
    <h3>Reheating</h3>
    {{ makeAheadReheat | safe }}
    {% endif %}
  </div>
</div>
{% endif %}
