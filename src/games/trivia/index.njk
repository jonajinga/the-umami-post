---
layout: base
title: Freethinking Trivia
description: Ten questions spanning philosophy, science, and the history of ideas.
permalink: /games/trivia/
---

{% block head %}
<style>
  .trivia-progress {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
    margin-bottom: var(--space-4);
  }

  .trivia-question {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: var(--leading-snug);
    color: var(--color-ink);
    margin-bottom: var(--space-6);
  }

  .trivia-options {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .trivia-option {
    text-align: left;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-rule-heavy);
    background: var(--color-bg);
    color: var(--color-ink);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    line-height: var(--leading-normal);
    width: 100%;
  }

  .trivia-option:hover:not(:disabled) {
    border-color: var(--color-ink);
    background: var(--color-bg-alt);
  }

  .trivia-option.is-correct {
    background: #f0fdf4;
    border-color: #22c55e;
    color: #166534;
  }

  .trivia-option.is-wrong {
    background: #fef2f2;
    border-color: #ef4444;
    color: #991b1b;
  }

  [data-theme="dark"] .trivia-option.is-correct { background: #052e16; color: #86efac; border-color: #166534; }
  [data-theme="dark"] .trivia-option.is-wrong   { background: #2d0a0a; color: #fca5a5; border-color: #991b1b; }

  .trivia-note {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    min-height: 2.5em;
    margin-bottom: var(--space-5);
  }

  .trivia-nav {
    text-align: center;
  }

  .trivia-result {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    border: 1px solid var(--color-rule);
    border-top: 3px solid var(--color-ink);
  }

  .trivia-result__score {
    font-family: var(--font-masthead);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .trivia-result__label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-5);
  }

  .trivia-result__verdict {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: var(--space-6);
    font-style: italic;
  }
</style>
{% endblock %}

<div class="game-page">

  <div class="game-header">
    <a href="/games/" class="game-back">← Games</a>
    <h1 class="game-title">Freethinking Trivia</h1>
    <p class="game-description">Ten questions on philosophy, science, and the history of ideas. No guessing on faith.</p>
  </div>

  <div id="quiz-area">
    <p class="trivia-progress" id="progress"></p>
    <p class="trivia-question" id="question-text"></p>
    <div class="trivia-options" id="options"></div>
    <p class="trivia-note" id="note"></p>
    <div class="trivia-nav">
      <button class="game-btn" id="next-btn" type="button" style="display:none">Next →</button>
    </div>
  </div>

  <div id="result-area" style="display:none">
    <div class="trivia-result">
      <div class="trivia-result__score" id="result-score"></div>
      <p class="trivia-result__label">out of 10</p>
      <p class="trivia-result__verdict" id="result-verdict"></p>
      <button class="game-btn" id="restart-btn" type="button">Play Again</button>
    </div>
  </div>

</div>

{% block scripts %}
<script>
(function () {
  'use strict';

  var questions = [
    {
      q: "Which ancient Greek philosopher was sentenced to death for questioning Athenian beliefs and 'corrupting the youth'?",
      options: ["Plato", "Aristotle", "Socrates", "Epicurus"],
      answer: 2,
      note: "Socrates was condemned in 399 BCE and chose to drink hemlock rather than renounce his philosophical practice."
    },
    {
      q: "Galileo's conflict with the Inquisition centred primarily on his support for which model of the solar system?",
      options: ["Ptolemaic geocentrism", "Heliocentric Copernicanism", "The Tychonic model", "Steady-state cosmology"],
      answer: 1,
      note: "Galileo's telescopic observations confirmed that Earth orbited the Sun, a fact the Church found inconvenient."
    },
    {
      q: "Which philosopher wrote: 'Man is born free, and everywhere he is in chains'?",
      options: ["Voltaire", "John Locke", "Jean-Jacques Rousseau", "Montesquieu"],
      answer: 2,
      note: "The opening line of Rousseau's The Social Contract (1762)."
    },
    {
      q: "The term 'agnosticism' was coined in 1869 by which scientist and defender of Darwin?",
      options: ["Charles Darwin", "Thomas Henry Huxley", "Herbert Spencer", "Francis Galton"],
      answer: 1,
      note: "Huxley invented the word because he felt neither 'theist' nor 'atheist' accurately described his position."
    },
    {
      q: "What does empiricism hold as the primary source of knowledge?",
      options: ["Innate reason", "Divine revelation", "Sensory experience", "Logical deduction alone"],
      answer: 2,
      note: "Locke, Hume, and Berkeley all held that the mind begins as a blank slate populated through experience."
    },
    {
      q: "In which year did Charles Darwin publish On the Origin of Species?",
      options: ["1832", "1844", "1859", "1871"],
      answer: 2,
      note: "Darwin delayed publication for over 20 years. He finally released it in 1859 after learning Alfred Russel Wallace had reached the same conclusions independently."
    },
    {
      q: "Which philosopher formulated the categorical imperative: act only by principles you could will to be universal laws?",
      options: ["David Hume", "John Stuart Mill", "Immanuel Kant", "Jeremy Bentham"],
      answer: 2,
      note: "Kant's Groundwork of the Metaphysics of Morals (1785) remains one of the most influential works in ethical philosophy."
    },
    {
      q: "Baruch Spinoza was excommunicated from his Amsterdam synagogue in 1656 at age 23. What was the stated reason?",
      options: [
        "Publishing a heretical book",
        "Converting to Christianity",
        "Denying the immortality of the soul",
        "The writ names 'abominable heresies' but gives no specific charge"
      ],
      answer: 3,
      note: "His cherem is one of the harshest ever issued, yet its exact accusations remain historically unknown."
    },
    {
      q: "Occam's Razor is the principle that, when comparing explanations, one should prefer…",
      options: [
        "The most complex explanation",
        "The oldest explanation",
        "The explanation requiring the fewest assumptions",
        "The explanation endorsed by authority"
      ],
      answer: 2,
      note: "William of Ockham (c.1287, 1347): 'Entities should not be multiplied beyond necessity.' A cornerstone of scientific reasoning."
    },
    {
      q: "Mary Wollstonecraft's A Vindication of the Rights of Woman was published in which year?",
      options: ["1759", "1776", "1792", "1848"],
      answer: 2,
      note: "Published in 1792, it argued that women's apparent inferiority was the product of poor education, not nature, a radical claim at the time."
    }
  ];

  var current  = 0;
  var score    = 0;
  var answered = false;

  var progressEl  = document.getElementById('progress');
  var questionEl  = document.getElementById('question-text');
  var optionsEl   = document.getElementById('options');
  var noteEl      = document.getElementById('note');
  var nextBtn     = document.getElementById('next-btn');
  var quizArea    = document.getElementById('quiz-area');
  var resultArea  = document.getElementById('result-area');
  var resultScore = document.getElementById('result-score');
  var resultVerdict = document.getElementById('result-verdict');
  var restartBtn  = document.getElementById('restart-btn');

  function showQuestion() {
    var q = questions[current];
    answered = false;
    noteEl.textContent = '';
    nextBtn.style.display = 'none';
    nextBtn.textContent = current < questions.length - 1 ? 'Next \u2192' : 'See Results';
    progressEl.textContent = 'Question ' + (current + 1) + ' of ' + questions.length;
    questionEl.textContent = q.q;
    optionsEl.innerHTML = '';

    q.options.forEach(function (opt, i) {
      var btn = document.createElement('button');
      btn.className = 'trivia-option';
      btn.type = 'button';
      btn.textContent = opt;
      btn.addEventListener('click', function () { handleAnswer(i, btn); });
      optionsEl.appendChild(btn);
    });
  }

  function handleAnswer(chosen, btn) {
    if (answered) return;
    answered = true;

    var q    = questions[current];
    var all  = optionsEl.querySelectorAll('.trivia-option');
    all.forEach(function (b) { b.disabled = true; });

    if (chosen === q.answer) {
      btn.classList.add('is-correct');
      score++;
    } else {
      btn.classList.add('is-wrong');
      all[q.answer].classList.add('is-correct');
    }

    noteEl.textContent = q.note || '';
    nextBtn.style.display = 'inline-block';
  }

  nextBtn.addEventListener('click', function () {
    current++;
    if (current < questions.length) {
      showQuestion();
    } else {
      showResult();
    }
  });

  function showResult() {
    quizArea.style.display = 'none';
    resultArea.style.display = 'block';
    resultScore.textContent = score + '/10';

    var verdicts = [
      [0,  3,  'More reading is recommended.'],
      [4,  5,  'A fair showing. The examined life continues.'],
      [6,  7,  'Well reasoned. You have done the reading.'],
      [8,  9,  'Impressive. You think carefully.'],
      [10, 10, 'Perfect. Socrates would not have had you executed.']
    ];

    for (var i = 0; i < verdicts.length; i++) {
      if (score >= verdicts[i][0] && score <= verdicts[i][1]) {
        resultVerdict.textContent = verdicts[i][2];
        break;
      }
    }
  }

  restartBtn.addEventListener('click', function () {
    current = 0;
    score   = 0;
    quizArea.style.display  = 'block';
    resultArea.style.display = 'none';
    showQuestion();
  });

  showQuestion();
}());
</script>
{% endblock %}
