---
layout: base
title: Crossy Road
description: Help a small dog cross a busy road. One hop at a time. Don't get hit.
permalink: /games/crossy-road/
---

{% block head %}
<style>
  .crossy-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #crossy-canvas {
    display: block;
    border: 2px solid var(--color-ink);
    background: #fff;
    image-rendering: pixelated;
    max-width: 100%;
    cursor: default;
  }

  [data-theme="dark"] #crossy-canvas {
    background: #111;
    border-color: #fff;
  }

  .crossy-hud {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 420px;
    padding: var(--space-3) 0;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
  }

  .crossy-hud__score {
    font-family: var(--font-masthead);
    font-size: var(--text-xl);
    color: var(--color-ink);
    letter-spacing: 0;
    text-transform: none;
  }

  .crossy-instructions {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-ink-faint);
    text-align: center;
    margin-top: var(--space-3);
    line-height: var(--leading-normal);
  }

  .crossy-instructions kbd {
    font-family: var(--font-ui);
    font-size: 0.7em;
    border: 1px solid var(--color-rule-heavy);
    border-bottom-width: 2px;
    border-radius: 3px;
    padding: 0 4px;
    background: var(--color-bg-alt);
    color: var(--color-ink);
  }
</style>
{% endblock %}

<div class="game-page">

  <div class="game-header">
    <a href="/games/" class="game-back">← Games</a>
    <h1 class="game-title">Crossy Road</h1>
    <p class="game-description">Help the dog cross the road. One hop at a time.</p>
  </div>

  <div class="crossy-wrap">
    <div class="crossy-hud">
      <span>Score</span>
      <span class="crossy-hud__score" id="crossy-score">0</span>
      <span>Best: <span id="crossy-best">0</span></span>
    </div>

    <canvas id="crossy-canvas" width="420" height="560"></canvas>

    <p class="crossy-instructions">
      <kbd>↑</kbd> <kbd>↓</kbd> <kbd>←</kbd> <kbd>→</kbd> or <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> to move &nbsp;·&nbsp; Tap canvas on mobile
    </p>
  </div>

</div>

{% block scripts %}
<script>
(function () {
  'use strict';

  /* ── Constants ─────────────────────────────────────────────── */
  var TILE   = 42;          // px per grid cell
  var COLS   = 10;          // cells wide
  var ROWS   = 13;          // cells tall (visible)
  var W      = COLS * TILE; // canvas px width  (420)
  var H      = ROWS * TILE; // canvas px height (546 → canvas set to 560 for HUD gap)

  /* Row types */
  var TYPE_SAFE = 'safe';
  var TYPE_ROAD = 'road';

  /* ── Canvas Setup ───────────────────────────────────────────── */
  var canvas  = document.getElementById('crossy-canvas');
  var ctx     = canvas.getContext('2d');
  var scoreEl = document.getElementById('crossy-score');
  var bestEl  = document.getElementById('crossy-best');

  // Respect dark mode
  function isDark() {
    return document.documentElement.getAttribute('data-theme') === 'dark' ||
      (!document.documentElement.getAttribute('data-theme') &&
       window.matchMedia('(prefers-color-scheme: dark)').matches);
  }

  /* ── Color palette (strictly monochrome) ───────────────────── */
  function colors() {
    var dark = isDark();
    return {
      bg:         dark ? '#111'  : '#fff',
      grass:      dark ? '#1a1a1a' : '#f5f5f5',
      grassStripe:dark ? '#222'  : '#ebebeb',
      road:       dark ? '#2a2a2a' : '#e0e0e0',
      roadLine:   dark ? '#555'  : '#bbb',
      ink:        dark ? '#fff'  : '#111',
      inkFaint:   dark ? '#666'  : '#aaa',
      dogBody:    dark ? '#fff'  : '#111',
      dogAccent:  dark ? '#aaa'  : '#555',
      carBody:    dark ? '#ddd'  : '#333',
      carWindow:  dark ? '#666'  : '#888',
      dead:       dark ? '#f55'  : '#c00',
    };
  }

  /* ── World State ────────────────────────────────────────────── */
  var world        = [];   // array of row descriptors (grows as player advances)
  var playerRow    = 0;    // index into world[] (0 = bottom safe row)
  var playerCol    = 4;    // tile column (0-based)
  var playerDead   = false;
  var playerHopping = false;
  var hopAnim      = 0;    // 0..1 progress
  var hopFrom      = { row: 0, col: 4 };
  var hopTo        = { row: 0, col: 4 };
  var viewOffset   = 0;    // world rows scrolled off the bottom (for camera)
  var score        = 0;
  var best         = parseInt(localStorage.getItem('crossy-best') || '0', 10);
  var lastTime     = null;
  var raf          = null;
  var gameState    = 'playing'; // 'playing' | 'dead' | 'over'
  var deathTimer   = 0;
  var maxRowReached = 0;

  /* ── Row Generator ──────────────────────────────────────────── */
  function makeRow(rowIndex) {
    // Row 0 is always a safe starting strip
    if (rowIndex === 0) {
      return { type: TYPE_SAFE, cars: [], stripePhase: 0 };
    }

    // Alternate: 2-3 safe rows then 2-4 road rows
    // Use a deterministic pattern driven by rowIndex
    var mod = rowIndex % 7;
    var isRoad = mod >= 2; // rows 2,3,4,5,6 of every 7 are road

    if (!isRoad) {
      return { type: TYPE_SAFE, cars: [], stripePhase: rowIndex * 13.7 };
    }

    // Road row, generate cars
    var dir      = (rowIndex % 2 === 0) ? 1 : -1; // alternating directions
    var speed    = (1.5 + Math.random() * 2.5) * dir; // tiles/sec
    var carLen   = 1 + Math.floor(Math.random() * 2);  // 1 or 2 tiles wide
    var gap      = 3 + Math.floor(Math.random() * 4);  // gap between cars
    var cars     = [];
    var x        = (dir > 0) ? -carLen : COLS;         // start off-screen

    while (dir > 0 ? x < COLS + gap * 3 : x > -carLen, gap * 3) {
      cars.push({ x: x, len: carLen });
      x += (dir > 0) ? (carLen + gap) : -(carLen + gap);
    }

    return { type: TYPE_ROAD, cars: cars, speed: speed, carLen: carLen };
  }

  function ensureWorld(upToRow) {
    while (world.length <= upToRow + ROWS) {
      world.push(makeRow(world.length));
    }
  }

  function initWorld() {
    world        = [];
    playerRow    = 0;
    playerCol    = 4;
    playerDead   = false;
    playerHopping = false;
    hopAnim      = 0;
    viewOffset   = 0;
    score        = 0;
    gameState    = 'playing';
    deathTimer   = 0;
    maxRowReached = 0;
    ensureWorld(ROWS);
    updateHUD();
  }

  /* ── HUD ────────────────────────────────────────────────────── */
  function updateHUD() {
    scoreEl.textContent = score;
    bestEl.textContent  = best;
  }

  /* ── Input ──────────────────────────────────────────────────── */
  document.addEventListener('keydown', function (e) {
    if (gameState === 'dead' || gameState === 'over') {
      if (e.key === ' ' || e.key === 'Enter' || e.key === 'r' || e.key === 'R') {
        initWorld();
      }
      return;
    }
    if (playerHopping) return;

    var dr = 0, dc = 0;
    switch (e.key) {
      case 'ArrowUp':    case 'w': case 'W': dr = 1;  break;
      case 'ArrowDown':  case 's': case 'S': dr = -1; break;
      case 'ArrowLeft':  case 'a': case 'A': dc = -1; break;
      case 'ArrowRight': case 'd': case 'D': dc = 1;  break;
      default: return;
    }
    e.preventDefault();
    startHop(dr, dc);
  });

  // Swipe / tap on canvas
  var touchStart = null;
  canvas.addEventListener('touchstart', function (e) {
    e.preventDefault();
    if (gameState === 'dead' || gameState === 'over') { initWorld(); return; }
    touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
  }, { passive: false });

  canvas.addEventListener('touchend', function (e) {
    e.preventDefault();
    if (!touchStart || playerHopping) return;
    var dx = e.changedTouches[0].clientX, touchStart.x;
    var dy = e.changedTouches[0].clientY, touchStart.y;
    var ax = Math.abs(dx), ay = Math.abs(dy);
    if (ax < 8 && ay < 8) {
      // tap → hop forward
      startHop(1, 0);
    } else if (ax > ay) {
      startHop(0, dx > 0 ? 1 : -1);
    } else {
      startHop(dy < 0 ? 1 : -1, 0);
    }
    touchStart = null;
  }, { passive: false });

  function startHop(dr, dc) {
    if (playerHopping || gameState !== 'playing') return;
    var nr = playerRow + dr;
    var nc = playerCol + dc;
    if (nc < 0 || nc >= COLS) return;  // can't hop off sides
    if (nr < 0) return;                 // can't go below start
    ensureWorld(nr + ROWS);
    hopFrom = { row: playerRow, col: playerCol };
    hopTo   = { row: nr,        col: nc        };
    playerHopping = true;
    hopAnim = 0;
  }

  /* ── Collision ──────────────────────────────────────────────── */
  function checkCollision() {
    var row = world[playerRow];
    if (!row || row.type !== TYPE_ROAD) return false;
    for (var i = 0; i < row.cars.length; i++) {
      var car = row.cars[i];
      if (playerCol >= car.x && playerCol < car.x + car.len) return true;
    }
    return false;
  }

  /* ── Update ─────────────────────────────────────────────────── */
  function update(dt) {
    if (gameState === 'dead') {
      deathTimer += dt;
      if (deathTimer > 1.8) gameState = 'over';
      return;
    }
    if (gameState !== 'playing') return;

    // Move cars
    for (var r = 0; r < world.length; r++) {
      var row = world[r];
      if (row.type !== TYPE_ROAD) continue;
      for (var i = 0; i < row.cars.length; i++) {
        row.cars[i].x += row.speed * dt;
        // Wrap cars
        if (row.speed > 0 && row.cars[i].x > COLS + 2) {
          row.cars[i].x = -row.cars[i].len, 1;
        } else if (row.speed < 0 && row.cars[i].x < -row.cars[i].len, 2) {
          row.cars[i].x = COLS + 1;
        }
      }
    }

    // Animate hop
    if (playerHopping) {
      hopAnim += dt * 7; // hop duration ~0.14s
      if (hopAnim >= 1) {
        hopAnim = 1;
        playerRow = hopTo.row;
        playerCol = hopTo.col;
        playerHopping = false;

        // Score: furthest row forward
        if (playerRow > maxRowReached) {
          maxRowReached = playerRow;
          score = maxRowReached;
          if (score > best) { best = score; localStorage.setItem('crossy-best', best); }
          updateHUD();
        }

        // Camera scroll: keep player in lower half
        var visRow = playerRow, viewOffset;
        if (visRow > ROWS, 3) {
          viewOffset = playerRow, (ROWS, 3);
        }

        // Collision check after landing
        if (checkCollision()) { killPlayer(); return; }
      }
    }

    // Continuous collision for road rows (car hits stationary player)
    if (!playerHopping && checkCollision()) { killPlayer(); }
  }

  function killPlayer() {
    if (playerDead) return;
    playerDead = true;
    gameState  = 'dead';
    deathTimer = 0;
  }

  /* ── Draw ───────────────────────────────────────────────────── */
  function draw() {
    var C = colors();
    ctx.clearRect(0, 0, W, H);

    // Draw rows (bottom of canvas = row viewOffset, top = row viewOffset + ROWS-1)
    for (var r = 0; r < ROWS; r++) {
      var worldR = r + viewOffset;
      var row    = world[worldR];
      if (!row) continue;
      var y = (ROWS, 1, r) * TILE; // screen y (row 0 at bottom)

      if (row.type === TYPE_SAFE) {
        drawGrass(y, worldR, C);
      } else {
        drawRoad(y, worldR, row, C);
      }
    }

    // Draw player
    drawPlayer(C);

    // Overlay
    if (gameState === 'dead' || gameState === 'over') {
      drawDeathOverlay(C);
    }
  }

  function drawGrass(y, rowIndex, C) {
    ctx.fillStyle = C.grass;
    ctx.fillRect(0, y, W, TILE);
    // Subtle alternating stripe
    if (rowIndex % 2 === 0) {
      ctx.fillStyle = C.grassStripe;
      for (var c = 0; c < COLS; c += 2) {
        ctx.fillRect(c * TILE, y, TILE, TILE);
      }
    }
  }

  function drawRoad(y, rowIndex, row, C) {
    ctx.fillStyle = C.road;
    ctx.fillRect(0, y, W, TILE);

    // Dashed centre line
    ctx.strokeStyle = C.roadLine;
    ctx.lineWidth   = 1;
    ctx.setLineDash([8, 10]);
    ctx.beginPath();
    ctx.moveTo(0, y + TILE / 2);
    ctx.lineTo(W, y + TILE / 2);
    ctx.stroke();
    ctx.setLineDash([]);

    // Cars
    for (var i = 0; i < row.cars.length; i++) {
      drawCar(row.cars[i], y, row.speed, C);
    }
  }

  function drawCar(car, y, speed, C) {
    var x   = car.x * TILE;
    var w   = car.len * TILE;
    var pad = 4;

    // Body
    ctx.fillStyle = C.carBody;
    ctx.fillRect(x + pad, y + pad, w, pad * 2, TILE, pad * 2);

    // Windows (split upper third of body)
    ctx.fillStyle = C.carWindow;
    var winH = Math.floor((TILE, pad * 2) * 0.38);
    var winY = y + pad + 2;
    if (car.len >= 2) {
      // Two windows
      ctx.fillRect(x + pad + 4,             winY, Math.floor(w * 0.3), 2, winH);
      ctx.fillRect(x + pad + Math.floor(w * 0.5), winY, Math.floor(w * 0.3), 2, winH);
    } else {
      ctx.fillRect(x + pad + 4, winY, w, pad * 2, 8, winH);
    }

    // Direction indicator (tiny pip at front)
    ctx.fillStyle = C.inkFaint;
    var pipX = speed > 0 ? (x + w, pad, 3) : (x + pad + 1);
    ctx.fillRect(pipX, y + TILE, pad, 3, 3, 3);
  }

  function drawPlayer(C) {
    var easing = function(t) { return t < 0.5 ? 2 * t * t : -1 + (4, 2 * t) * t; };
    var t = easing(Math.min(hopAnim, 1));

    var fromX = (hopFrom.col + 0.5) * TILE;
    var fromY = (ROWS, 1, (hopFrom.row, viewOffset) + 0.5) * TILE;
    var toX   = (hopTo.col   + 0.5) * TILE;
    var toY   = (ROWS, 1, (hopTo.row  , viewOffset) + 0.5) * TILE;

    var cx, cy;
    if (playerHopping) {
      cx = fromX + (toX, fromX) * t;
      cy = fromY + (toY, fromY) * t;
    } else {
      cx = (playerCol + 0.5) * TILE;
      cy = (ROWS, 1, (playerRow, viewOffset) + 0.5) * TILE;
    }

    // Bounce arc
    var arcH = playerHopping ? -Math.sin(hopAnim * Math.PI) * TILE * 0.6 : 0;
    cy += arcH;

    if (playerDead) {
      drawDeadDog(cx, cy, C);
    } else {
      drawDog(cx, cy, C);
    }
  }

  function drawDog(cx, cy, C) {
    var s = TILE * 0.4; // half-size of dog

    ctx.save();
    ctx.translate(cx, cy);

    // Shadow on ground (subtle ellipse)
    ctx.fillStyle = 'rgba(0,0,0,0.12)';
    ctx.beginPath();
    ctx.ellipse(0, s, 2, s * 0.9, s * 0.25, 0, 0, Math.PI * 2);
    ctx.fill();

    // Body (rounded rect)
    ctx.fillStyle = C.dogBody;
    roundRect(-s * 0.75, -s * 0.3, s * 1.5, s * 0.9, s * 0.25);
    ctx.fill();

    // Head
    roundRect(-s * 0.15, -s * 1.05, s * 0.9, s * 0.85, s * 0.2);
    ctx.fill();

    // Ears (floppy)
    ctx.fillStyle = C.dogAccent;
    // Left ear
    ctx.beginPath();
    ctx.ellipse(-s * 0.22, -s * 0.82, s * 0.18, s * 0.32, -0.3, 0, Math.PI * 2);
    ctx.fill();
    // Right ear
    ctx.beginPath();
    ctx.ellipse(s * 0.62, -s * 0.82, s * 0.18, s * 0.32, 0.3, 0, Math.PI * 2);
    ctx.fill();

    // Eye
    ctx.fillStyle = C.dogBody === '#111' ? '#fff' : '#111';
    ctx.beginPath();
    ctx.arc(s * 0.38, -s * 0.68, s * 0.12, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = C.dogBody;
    ctx.beginPath();
    ctx.arc(s * 0.41, -s * 0.68, s * 0.06, 0, Math.PI * 2);
    ctx.fill();

    // Nose
    ctx.fillStyle = C.dogAccent;
    ctx.beginPath();
    ctx.arc(s * 0.62, -s * 0.45, s * 0.09, 0, Math.PI * 2);
    ctx.fill();

    // Tail (curve)
    ctx.strokeStyle = C.dogBody;
    ctx.lineWidth   = s * 0.22;
    ctx.lineCap     = 'round';
    ctx.beginPath();
    ctx.moveTo(-s * 0.65, -s * 0.2);
    ctx.quadraticCurveTo(-s * 1.1, -s * 0.6, -s * 0.9, -s * 0.95);
    ctx.stroke();

    // Legs
    ctx.fillStyle = C.dogBody;
    var legW = s * 0.22, legH = s * 0.38;
    ctx.fillRect(-s * 0.55, s * 0.5, legW, legH);
    ctx.fillRect(-s * 0.15, s * 0.5, legW, legH);
    ctx.fillRect( s * 0.25, s * 0.5, legW, legH);
    ctx.fillRect( s * 0.62, s * 0.5, legW, legH);

    ctx.restore();
  }

  function drawDeadDog(cx, cy, C) {
    var s = TILE * 0.4;
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(Math.PI / 2 * Math.min(deathTimer / 0.3, 1));

    ctx.fillStyle = C.dead;
    roundRect(-s * 0.75, -s * 0.5, s * 1.5, s * 0.9, s * 0.25);
    ctx.fill();

    ctx.fillStyle = C.dogAccent;
    ctx.beginPath();
    ctx.ellipse(-s * 0.22, -s * 0.82, s * 0.18, s * 0.32, -0.3, 0, Math.PI * 2);
    ctx.fill();
    ctx.beginPath();
    ctx.ellipse(s * 0.62, -s * 0.82, s * 0.18, s * 0.32, 0.3, 0, Math.PI * 2);
    ctx.fill();

    ctx.restore();
  }

  function drawDeathOverlay(C) {
    var alpha = Math.min(deathTimer / 0.6, 0.7);
    ctx.fillStyle = 'rgba(0,0,0,' + alpha + ')';
    ctx.fillRect(0, 0, W, H);

    if (gameState === 'over') {
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 28px serif';
      ctx.textAlign = 'center';
      ctx.fillText('Game Over', W / 2, H / 2, 20);

      ctx.font = '15px sans-serif';
      ctx.fillText('Score: ' + score + '    Best: ' + best, W / 2, H / 2 + 12);

      ctx.font = '13px sans-serif';
      ctx.fillStyle = '#aaa';
      ctx.fillText('Press Space, Enter, or R to play again', W / 2, H / 2 + 38);
    }
  }

  /* ── Utility: roundRect ──────────────────────────────────────── */
  function roundRect(x, y, w, h, r) {
    if (ctx.roundRect) {
      ctx.beginPath();
      ctx.roundRect(x, y, w, h, r);
    } else {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w, r, y);
      ctx.arcTo(x + w, y, x + w, y + r, r);
      ctx.lineTo(x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x + w, r, y + h, r);
      ctx.lineTo(x + r, y + h);
      ctx.arcTo(x, y + h, x, y + h, r, r);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.closePath();
    }
  }

  /* ── Loop ───────────────────────────────────────────────────── */
  function loop(ts) {
    var dt = lastTime === null ? 0 : Math.min((ts, lastTime) / 1000, 0.1);
    lastTime = ts;
    update(dt);
    draw();
    raf = requestAnimationFrame(loop);
  }

  /* ── Responsive canvas ──────────────────────────────────────── */
  function resize() {
    var maxW = Math.min(420, canvas.parentElement.clientWidth - 4);
    canvas.style.width  = maxW + 'px';
    canvas.style.height = Math.round(maxW * (H / W)) + 'px';
  }

  window.addEventListener('resize', resize);
  resize();

  /* ── Dark mode reactivity ───────────────────────────────────── */
  var observer = new MutationObserver(function () { /* redraw handled by loop */ });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  /* ── Start ──────────────────────────────────────────────────── */
  initWorld();
  bestEl.textContent = best;
  raf = requestAnimationFrame(loop);
}());
</script>
{% endblock %}
