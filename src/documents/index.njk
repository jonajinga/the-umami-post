---
layout: layouts/base.njk
title: Document Library
description: "Primary source materials: FOIA responses, court filings, government reports, spending records, and other evidentiary materials underlying our reporting."
permalink: /documents/
---

<div class="container doc-index">

  {# ── Header ── #}
  <header class="doc-index__header">
    <p class="doc-index__kicker">Primary Sources</p>
    <h1 class="doc-index__title">Document Library</h1>
    <p class="doc-index__lede">
      Original documents underlying our reporting. FOIA responses, public records, court filings, government reports, and other primary sources, reproduced in full with editor context and linked to the pieces they support.
    </p>
    <p class="doc-index__meta">
      {% set totalDocs = collections.documents | length %}
      {{ totalDocs }} document{{ "s" if totalDocs != 1 else "" }} in the library.
      Know of a document we should post? <a href="/tips/">Send a tip &rarr;</a>
    </p>

    {# Search + type filter #}
    <div class="doc-index__controls">
      <div class="doc-search" role="search">
        <svg class="doc-search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <label for="doc-search-input" class="visually-hidden">Filter documents</label>
        <input id="doc-search-input" type="search" placeholder="Filter by title, source, or subject…" autocomplete="off">
        <button type="button" id="doc-search-clear" aria-label="Clear filter" hidden>&times;</button>
      </div>

      {# Build a unique set of docTypes for the pill row #}
      {% set docTypes = [] %}
      {% for doc in collections.documents %}
        {% if doc.data.docType and doc.data.docType not in docTypes %}
          {% set docTypes = (docTypes.push(doc.data.docType), docTypes) %}
        {% endif %}
      {% endfor %}
      {% if docTypes.length %}
      <div class="doc-types" role="group" aria-label="Filter by document type">
        <button class="doc-type-pill is-active" data-type="" type="button">All</button>
        {% for type in docTypes %}
        <button class="doc-type-pill" data-type="{{ type }}" type="button">{{ type }}</button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <p class="doc-index__status" id="doc-index-status" aria-live="polite"></p>
  </header>

  {% if collections.documents and collections.documents.length %}
  <div class="doc-index__grid" id="doc-index-grid">
    {% for doc in collections.documents | reverse %}
    <article class="doc-card"
             data-type="{{ doc.data.docType or '' }}"
             data-search="{{ (doc.data.title + ' ' + (doc.data.source or '') + ' ' + (doc.data.description or '')) | lower }}">
      {% if doc.data.docType %}
      <span class="doc-card__badge">{{ doc.data.docType }}</span>
      {% endif %}
      <h2 class="doc-card__title">
        <a href="{{ doc.url }}">{{ doc.data.title }}</a>
      </h2>
      {% if doc.data.description %}
      <p class="doc-card__desc">{{ doc.data.description }}</p>
      {% endif %}
      <dl class="doc-card__meta">
        {% if doc.data.source %}
        <div><dt>Source</dt><dd>{{ doc.data.source }}</dd></div>
        {% endif %}
        {% if doc.data.dateObtained %}
        <div><dt>Obtained</dt><dd><time datetime="{{ doc.data.dateObtained }}">{{ doc.data.dateObtained | readableDate }}</time></dd></div>
        {% endif %}
        <div><dt>Published</dt><dd><time datetime="{{ doc.date | htmlDateString }}">{{ doc.date | readableDate }}</time></dd></div>
      </dl>
      {% if doc.data.relatedArticles and doc.data.relatedArticles.length %}
      <p class="doc-card__related">
        <span class="doc-card__related-label">Powers:</span>
        {% for url in doc.data.relatedArticles %}
          <a href="{{ url }}">{%- for art in collections.allContent -%}{%- if art.url == url -%}{{ art.data.title }}{%- endif -%}{%- endfor -%}</a>{% if not loop.last %}; {% endif %}
        {% endfor %}
      </p>
      {% endif %}
    </article>
    {% endfor %}
  </div>
  <p class="doc-index__empty" id="doc-index-empty" hidden>No documents match this filter.</p>
  {% else %}
  <p class="doc-index__empty-static">No documents in the library yet. Documents obtained through FOIA or public records requests will be posted here alongside the reporting they support.</p>
  {% endif %}

</div>

<style>
.doc-index { padding-top: var(--space-10); padding-bottom: var(--space-20); }

/* Header */
.doc-index__header {
  max-width: 880px;
  margin-bottom: var(--space-10);
  padding-bottom: var(--space-6);
  border-bottom: 3px solid var(--color-ink);
}
.doc-index__kicker {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-accent);
  margin-bottom: var(--space-3);
}
.doc-index__title {
  font-family: var(--font-masthead);
  font-size: clamp(1.8rem, 5vw, 3.2rem);
  line-height: var(--leading-tight);
  color: var(--color-ink);
  margin-bottom: var(--space-4);
}
.doc-index__lede {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: var(--color-ink-muted);
  line-height: var(--leading-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-3);
}
.doc-index__meta {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-ink-faint);
  margin-bottom: var(--space-5);
}
.doc-index__meta a { color: var(--color-link); }

/* Controls */
.doc-index__controls {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
  margin-top: var(--space-4);
}
.doc-search {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: var(--space-2);
  min-width: 280px;
  flex: 1 1 320px;
  max-width: 480px;
  padding: 0 var(--space-3);
  min-height: 44px;
  background: var(--color-bg-alt);
  border: 1px solid var(--color-rule);
  transition: border-color var(--transition-fast);
}
.doc-search:focus-within { border-color: var(--color-ink); background: var(--color-bg); }
.doc-search__icon { color: var(--color-ink-faint); flex-shrink: 0; }
.doc-search input {
  border: none;
  background: transparent;
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-ink);
  min-height: 44px;
  padding: 0;
  width: 100%;
}
.doc-search input:focus { outline: none; }
.doc-search input::placeholder { color: var(--color-ink-faint); font-style: italic; }
.doc-search button {
  background: none;
  border: none;
  font-size: var(--text-lg);
  color: var(--color-ink-faint);
  cursor: pointer;
  padding: var(--space-1);
}
.doc-search button:hover { color: var(--color-ink); }

.doc-types {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}
.doc-type-pill {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 0.4rem 0.85rem;
  min-height: 30px;
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink-muted);
  border-radius: 999px;
  cursor: pointer;
  transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
}
.doc-type-pill:hover { border-color: var(--color-ink); color: var(--color-ink); background: var(--color-bg-alt); }
.doc-type-pill.is-active {
  background: var(--color-accent);
  color: #fff;
  border-color: var(--color-accent);
}

.doc-index__status {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-faint);
  margin-top: var(--space-3);
  min-height: 1.2em;
}
.doc-index__status:empty { display: none; }

/* Grid */
.doc-index__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--space-6);
}

/* Card */
.doc-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-6);
  background: var(--color-bg);
  border: 1px solid var(--color-rule);
  border-top: 3px solid var(--color-ink);
  transition: border-top-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
}
.doc-card:hover {
  border-top-color: var(--color-accent);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
}
.doc-card--hidden { display: none; }

.doc-card__badge {
  align-self: flex-start;
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  padding: 3px 8px;
  background: var(--color-ink);
  color: var(--color-bg);
  border-radius: 2px;
}
.doc-card__title {
  font-family: var(--font-headline);
  font-size: var(--text-md);
  font-weight: 700;
  line-height: var(--leading-snug);
  margin: 0;
}
.doc-card__title a {
  color: var(--color-ink);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.doc-card__title a:hover { color: var(--color-accent); }
.doc-card__desc {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  line-height: var(--leading-relaxed);
  margin: 0;
}

.doc-card__meta {
  display: grid;
  gap: var(--space-1);
  margin: 0;
  padding-top: var(--space-3);
  border-top: 1px solid var(--color-rule);
}
.doc-card__meta > div {
  display: grid;
  grid-template-columns: 6rem 1fr;
  gap: var(--space-2);
  font-family: var(--font-ui);
  font-size: var(--text-xs);
}
.doc-card__meta dt {
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-ink-faint);
}
.doc-card__meta dd {
  color: var(--color-ink-muted);
  margin: 0;
}

.doc-card__related {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-muted);
  line-height: var(--leading-relaxed);
  margin: 0;
  padding-top: var(--space-3);
  border-top: 1px solid var(--color-rule);
}
.doc-card__related-label {
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-ink-faint);
  display: block;
  margin-bottom: 2px;
}
.doc-card__related a { color: var(--color-link); }

.doc-index__empty,
.doc-index__empty-static {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  font-style: italic;
  color: var(--color-ink-muted);
  padding: var(--space-10) 0;
}
</style>

<script>
(function () {
  var input  = document.getElementById('doc-search-input');
  var clear  = document.getElementById('doc-search-clear');
  var status = document.getElementById('doc-index-status');
  var empty  = document.getElementById('doc-index-empty');
  var pills  = document.querySelectorAll('.doc-type-pill');
  var cards  = document.querySelectorAll('.doc-card');
  if (!cards.length) return;

  var state = { q: '', type: '' };

  function apply() {
    var visible = 0;
    cards.forEach(function (c) {
      var hay  = c.getAttribute('data-search') || '';
      var type = c.getAttribute('data-type') || '';
      var okQ    = !state.q || hay.indexOf(state.q) !== -1;
      var okType = !state.type || type === state.type;
      var show = okQ && okType;
      c.classList.toggle('doc-card--hidden', !show);
      if (show) visible++;
    });
    if (empty) empty.hidden = visible > 0;
    if (status) {
      var n = cards.length;
      if (!state.q && !state.type) status.textContent = '';
      else status.textContent = visible + ' of ' + n + ' document' + (n === 1 ? '' : 's') + ' match.';
    }
  }

  if (input) {
    input.addEventListener('input', function () {
      state.q = input.value.trim().toLowerCase();
      if (clear) clear.hidden = !state.q;
      apply();
    });
  }
  if (clear) {
    clear.addEventListener('click', function () {
      if (input) { input.value = ''; input.focus(); }
      state.q = '';
      clear.hidden = true;
      apply();
    });
  }
  pills.forEach(function (p) {
    p.addEventListener('click', function () {
      state.type = p.getAttribute('data-type') || '';
      pills.forEach(function (x) { x.classList.toggle('is-active', x === p); });
      apply();
    });
  });
}());
</script>
