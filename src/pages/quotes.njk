---
layout: base
title: Quotes
description: A curated collection of freethought quotes, save, share, and print your favourites.
permalink: /quotes/
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Freethought Quotes",
  "numberOfItems": {{ quotes | length }},
  "itemListElement": [
    {% for q in quotes | limit(10) %}
    {% if not loop.first %},{% endif %}
    {
      "@type": "Quotation",
      "text": {{ q.quote | dump | safe }},
      "spokenByCharacter": { "@type": "Person", "name": "{{ q.author }}" }
      {% if q.source %},"isPartOf": { "@type": "CreativeWork", "name": "{{ q.source }}" }{% endif %}
    }
    {% endfor %}
  ]
}
</script>

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/projects/">Projects</a></li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Quotes</li>
    </ol>
  </nav>

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-10);">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Quotes</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic;">
      A curated collection of freethought quotes.
    </p>
    <p style="font-family: var(--font-ui); font-size: var(--text-sm); margin-top: var(--space-4);">
      Know a great quote? <a href="/quotes/submit/" style="color: var(--color-link); font-weight: 600;">Submit it</a>
    </p>
    <div style="display:flex;gap:var(--space-3);margin-top:var(--space-4);flex-wrap:wrap;justify-content:center;">
      <a href="/quotes/timeline/" class="btn">View Timeline</a>
      <a href="/quotes/showcase/" class="btn">Showcase</a>
    </div>
  </header>

  <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);flex-wrap:wrap;">
    <select id="quotes-author-filter" aria-label="Filter by author" style="padding:var(--space-2) var(--space-3);font-family:var(--font-ui);font-size:var(--text-sm);border:1px solid var(--color-rule);border-radius:var(--radius-sm);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All authors</option>
      {% set authorSet = [] %}
      {% for q in quotes %}
        {% if q.author not in authorSet %}{% set authorSet = authorSet.concat([q.author]) %}{% endif %}
      {% endfor %}
      {% for a in authorSet | sort %}
        <option value="{{ a }}">{{ a }}</option>
      {% endfor %}
    </select>
    <select id="quotes-tag-filter" aria-label="Filter by topic" style="padding:var(--space-2) var(--space-3);font-family:var(--font-ui);font-size:var(--text-sm);border:1px solid var(--color-rule);border-radius:var(--radius-sm);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All topics</option>
      {% set tagSet = [] %}
      {% for q in quotes %}
        {% for t in q.tags %}
          {% if t not in tagSet %}{% set tagSet = tagSet.concat([t]) %}{% endif %}
        {% endfor %}
      {% endfor %}
      {% for t in tagSet | sort %}
        <option value="{{ t }}">{{ t }}</option>
      {% endfor %}
    </select>
    <select id="quotes-era-filter" aria-label="Filter by era" style="padding:var(--space-2) var(--space-3);font-family:var(--font-ui);font-size:var(--text-sm);border:1px solid var(--color-rule);border-radius:var(--radius-sm);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All eras</option>
      {% set eraSet = [] %}
      {% for q in quotes %}
        {% if q.era and q.era not in eraSet %}{% set eraSet = eraSet.concat([q.era]) %}{% endif %}
      {% endfor %}
      {% for e in eraSet | sort %}
        <option value="{{ e }}">{{ e }}</option>
      {% endfor %}
    </select>
  </div>

  <style>.quote-card { scroll-margin-top: 8rem; }</style>
  <div id="quotes-list" data-pagefind-ignore style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-4);">
    {% for q in quotes %}
    <blockquote class="quote-card" data-author="{{ q.author }}" data-tags="{{ q.tags | join(',') }}" data-era="{{ q.era }}" data-url="/quotes/{{ q | quoteSlug }}/" id="q{{ loop.index }}" style="margin:0;padding:var(--space-6);border:1px solid var(--color-rule);border-top:3px solid var(--color-accent);display:flex;flex-direction:column;justify-content:space-between;font-style:normal;color:var(--color-ink);gap:var(--space-3);">
      <a href="/quotes/{{ q | quoteSlug }}/" style="font-family:var(--font-body);font-size:var(--text-sm);line-height:var(--leading-loose);color:var(--color-ink);margin:0;text-decoration:none;">
        &ldquo;{{ q.quote }}&rdquo;
      </a>
      <div>
        <p style="font-family:var(--font-headline);font-size:var(--text-sm);font-weight:700;color:var(--color-ink);margin:0;">{{ q.author }}</p>
        {% if q.source %}<p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin:0;">{{ q.source }}</p>{% endif %}
        <div class="quote-actions" style="display:flex;gap:var(--space-1);">
          <button class="article-action-btn quote-save-btn" type="button" aria-label="Save to reading list" title="Save" data-index="{{ loop.index }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          </button>
          <button class="article-action-btn quote-share-btn" type="button" aria-label="Share quote" title="Share" data-author="{{ q.author }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
          <button class="article-action-btn quote-copy-btn" type="button" aria-label="Copy quote" title="Copy" data-author="{{ q.author }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
        </div>
      </div>
    </blockquote>
    {% endfor %}
  </div>
</div>

<script>
(function () {
  var _p = window.__PREFIX || 'tft';

  // Scroll to hash on load (for reading list links)
  if (window.location.hash) {
    var target = document.querySelector(window.location.hash);
    if (target) {
      setTimeout(function () {
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        target.style.outline = '2px solid var(--color-accent)';
        setTimeout(function () { target.style.outline = ''; }, 2000);
      }, 300);
    }
  }

  // Filters
  var authorFilter = document.getElementById('quotes-author-filter');
  var tagFilter = document.getElementById('quotes-tag-filter');
  var eraFilter = document.getElementById('quotes-era-filter');

  function filterQuotes() {
    var author = authorFilter ? authorFilter.value : '';
    var tag = tagFilter ? tagFilter.value : '';
    var era = eraFilter ? eraFilter.value : '';
    document.querySelectorAll('.quote-card').forEach(function (card) {
      var matchAuthor = !author || card.dataset.author === author;
      var matchTag = !tag || (card.dataset.tags || '').indexOf(tag) !== -1;
      var matchEra = !era || card.dataset.era === era;
      card.style.display = (matchAuthor && matchTag && matchEra) ? '' : 'none';
    });
  }

  if (authorFilter) authorFilter.addEventListener('change', filterQuotes);
  if (tagFilter) tagFilter.addEventListener('change', filterQuotes);
  if (eraFilter) eraFilter.addEventListener('change', filterQuotes);

  function getQuoteText(btn) {
    var card = btn.closest('.quote-card');
    var text = card.querySelector('p').textContent;
    var author = btn.dataset.author || '';
    return text + (author ? ' \u2014 ' + author : '');
  }

  var checkSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

  function flashCheck(btn) {
    var orig = btn.innerHTML;
    btn.innerHTML = checkSvg;
    setTimeout(function () { btn.innerHTML = orig; }, 1200);
  }

  // Save to reading list (toggle like article bookmark)
  document.querySelectorAll('.quote-save-btn').forEach(function (btn) {
    var card = btn.closest('.quote-card');
    var url = '/quotes/#' + card.id;
    var k = _p + '-reading-list';

    // Check if already saved on load
    var list = JSON.parse(localStorage.getItem(k) || '[]');
    if (list.some(function (i) { return i.url === url; })) {
      btn.querySelector('svg').style.fill = 'currentColor';
    }

    btn.addEventListener('click', function () {
      var list = JSON.parse(localStorage.getItem(k) || '[]');
      var saved = list.some(function (i) { return i.url === url; });
      if (saved) {
        list = list.filter(function (i) { return i.url !== url; });
        localStorage.setItem(k, JSON.stringify(list));
        btn.querySelector('svg').style.fill = 'none';
      } else {
        var quoteText = card.querySelector('p').textContent;
        var citeEl = card.querySelector('cite');
        var citeText = citeEl ? citeEl.textContent.trim() : '';
        list.unshift({
          url: url,
          title: quoteText + ', ' + citeText,
          section: 'Quotes',
          date: '',
          mins: ''
        });
        localStorage.setItem(k, JSON.stringify(list));
        btn.querySelector('svg').style.fill = 'currentColor';
      }
    });
  });

  // Copy, show checkmark briefly
  document.querySelectorAll('.quote-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var text = getQuoteText(btn);
      navigator.clipboard.writeText(text).then(function () {
        flashCheck(btn);
      });
    });
  });

  // Share, social share panel
  document.querySelectorAll('.quote-share-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var text = getQuoteText(btn);
      var enc = encodeURIComponent;
      var url = window.location.href;

      // Remove existing panel
      var old = document.getElementById('quote-share-panel');
      if (old) old.remove();

      var panel = document.createElement('div');
      panel.id = 'quote-share-panel';
      panel.style.cssText = 'position:fixed;bottom:3.5rem;left:50%;transform:translateX(-50%);z-index:300;min-width:220px;background:var(--color-bg-alt);border:1px solid var(--color-rule-heavy);border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,.15);padding:8px 0;';

      var IC = {
        twitter: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
        facebook: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
        linkedin: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
        reddit: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249z"/></svg>',
        email: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
        copy: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>'
      };

      var shareItems = [
        { label: 'X / Twitter', icon: IC.twitter, href: 'https://twitter.com/intent/tweet?text=' + enc(text.slice(0, 240)) },
        { label: 'Facebook', icon: IC.facebook, href: 'https://www.facebook.com/sharer/sharer.php?u=' + enc(url) + '&quote=' + enc(text.slice(0, 200)) },
        { label: 'LinkedIn', icon: IC.linkedin, href: 'https://www.linkedin.com/sharing/share-offsite/?url=' + enc(url) },
        { label: 'Reddit', icon: IC.reddit, href: 'https://www.reddit.com/submit?url=' + enc(url) + '&title=' + enc(text.slice(0, 100)) },
        { label: 'Email', icon: IC.email, href: 'mailto:?subject=' + enc('A quote worth sharing') + '&body=' + enc(text + '\n\n' + url) },
        { label: 'Copy text', icon: IC.copy, action: 'copy' }
      ];

      shareItems.forEach(function (item) {
        if (item.action === 'copy') {
          var b = document.createElement('button');
          b.style.cssText = 'display:flex;align-items:center;gap:8px;width:100%;padding:6px 16px;font-family:var(--font-ui);font-size:14px;color:var(--color-ink);background:none;border:none;text-align:left;cursor:pointer;';
          b.innerHTML = item.icon + ' ' + item.label;
          b.onmouseover = function () { b.style.background = 'var(--color-bg-inset)'; };
          b.onmouseout = function () { b.style.background = 'none'; };
          b.addEventListener('click', function () {
            navigator.clipboard.writeText(text).then(function () {
              b.textContent = 'Copied!';
              setTimeout(function () { panel.remove(); }, 800);
            });
          });
          panel.appendChild(b);
        } else {
          var a = document.createElement('a');
          a.href = item.href;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.innerHTML = item.icon + ' ' + item.label;
          a.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 16px;font-family:var(--font-ui);font-size:14px;color:var(--color-ink);text-decoration:none;cursor:pointer;';
          a.onmouseover = function () { a.style.background = 'var(--color-bg-inset)'; };
          a.onmouseout = function () { a.style.background = 'none'; };
          a.addEventListener('click', function () { setTimeout(function () { panel.remove(); }, 100); });
          panel.appendChild(a);
        }
      });

      document.body.appendChild(panel);
      setTimeout(function () {
        document.addEventListener('mousedown', function closer(e) {
          if (!panel.contains(e.target)) { panel.remove(); document.removeEventListener('mousedown', closer); }
        });
      }, 100);
    });
  });
})();
</script>
