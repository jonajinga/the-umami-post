---
layout: base
title: Quotes Through the Ages
description: Freethought quotes arranged chronologically, from Epicurus to Carl Sagan.
permalink: /quotes/timeline/
eleventyExcludeFromCollections: true
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-10); text-align: center;">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Quotes Through the Ages</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 40ch; margin-inline: auto;">
      The words that challenged orthodoxy, century by century.
    </p>
    <div style="margin-top:var(--space-6);display:flex;justify-content:center;gap:var(--space-3);">
      <a href="/quotes/" class="btn">&larr; All Quotes</a>
      <a href="/quotes/showcase/" class="btn">Showcase</a>
    </div>
  </header>

  <div style="text-align: center; margin-bottom: var(--space-10);">
    <select id="timeline-era-filter" aria-label="Filter by era" class="rs-select" style="display:inline-block;width:auto;min-width:200px;font-size:var(--text-md);padding:var(--space-3) var(--space-4);">
      <option value="">All eras</option>
      {% set eraSet = [] %}
      {% for q in quotes %}
        {% if q.era not in eraSet %}{% set eraSet = eraSet.concat([q.era]) %}{% endif %}
      {% endfor %}
      {% for era in eraSet %}
        <option value="{{ era }}">{{ era }}</option>
      {% endfor %}
    </select>
    <span id="timeline-count" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin-left:var(--space-2);">{{ quotes | length }} quotes</span>
  </div>

  {# Build sorted array with extracted years #}
  {% set sortedQuotes = [] %}
  {% for q in quotes %}
    {% set yr = q.source | extractYear(q.era) %}
    {% set sortedQuotes = sortedQuotes.concat([{ year: yr, quote: q.quote, author: q.author, source: q.source, era: q.era, tags: q.tags, obj: q }]) %}
  {% endfor %}

  <div class="tl" id="timeline-list" data-pagefind-ignore>
    <div class="tl__line" aria-hidden="true"></div>

    {% set currentEra = '' %}
    {% for item in sortedQuotes | sort(false, false, 'year') %}

      {% if item.era != currentEra %}
        {% set currentEra = item.era %}
        <div class="tl__era" data-era="{{ item.era }}">
          <span class="tl__era-label">{{ item.era }}</span>
        </div>
      {% endif %}

      <div class="tl__event {% if loop.index0 % 2 == 0 %}tl__event--left{% else %}tl__event--right{% endif %}" data-era="{{ item.era }}">
        <div class="tl__connector" aria-hidden="true"></div>
        <div class="tl__dot" aria-hidden="true"></div>
        <div class="tl__card">
          <div class="tl__year">
            {% if item.year < 0 %}{{ item.year * -1 }} BCE{% elif item.year > 0 %}{{ item.year }}{% endif %}
          </div>
          <blockquote class="tl__quote">&ldquo;{{ item.quote }}&rdquo;</blockquote>
          <p class="tl__author">,  {{ item.author }}</p>
          <p class="tl__source">{{ item.source }}</p>
        </div>
      </div>

    {% endfor %}
  </div>
</div>

{% include "partials/timeline-styles.njk" %}

<style>
.tl__quote {
  font-family: var(--font-body);
  font-size: var(--text-md);
  font-style: italic;
  line-height: 1.65;
  color: var(--color-ink);
  margin: var(--space-2) 0 var(--space-3);
  padding: 0;
  border: none;
}

.tl__author {
  font-family: var(--font-headline);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 var(--space-1);
}

.tl__source {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-faint);
  margin: 0;
}
</style>

<script>
(function () {
  var filter = document.getElementById('timeline-era-filter');
  var countEl = document.getElementById('timeline-count');
  if (filter) {
    filter.addEventListener('change', function () {
      var era = this.value;
      var visible = 0;
      document.querySelectorAll('.tl__event, .tl__era').forEach(function (el) {
        var show = !era || el.dataset.era === era;
        el.style.display = show ? '' : 'none';
        if (show && el.classList.contains('tl__event')) visible++;
      });
      if (countEl) countEl.textContent = visible + ' quote' + (visible !== 1 ? 's' : '');
    });
  }
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.tl__event').forEach(function (el) { observer.observe(el); });
  } else {
    document.querySelectorAll('.tl__event').forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>
