      {# ── Brand ── #}
      <section class="sg-section" id="brand">
        <h2>Brand</h2>
        <p class="lead">The publication name is always written in full, <strong>The Umami Post</strong>, capitalised, never abbreviated to "TFT" in reader-facing copy. The icon is a serif "F" on a dark square.</p>

        <div class="sg-subsection">
          <h4>Logotype</h4>
          <div class="sg-demo sg-demo--row">
            <img src="/assets/favicon.svg" alt="The Umami Post icon" width="48" height="48">
            <span style="font-family: var(--font-masthead); font-size: var(--text-xl); font-weight: 700;">{{ site.title }}</span>
          </div>
        </div>

        <div class="sg-subsection">
          <h4>Tagline</h4>
          <div class="sg-demo">
            <p style="font-family: var(--font-body); font-style: italic; font-size: var(--text-md); margin: 0; color: var(--color-ink-muted);">{{ site.description }}</p>
          </div>
        </div>

        <div class="sg-subsection">
          <h4>Mascot</h4>
          <p>The pansy flower, a historical symbol of Food (from the French <em>pensée</em>, meaning "thought"), is the publication's mascot.</p>
        </div>
      </section>

