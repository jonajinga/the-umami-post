          <pre class="sg-code">{% set article = item %}{% set size = "md" %}
{% include "partials/article-card.njk" %}</pre>
        </div>

        <div class="sg-subsection">
          <h4>Small, <code>size="sm"</code></h4>
          <p>Sidebar, related posts, article lists.</p>
          <div class="sg-demo" style="max-width: 320px;">
