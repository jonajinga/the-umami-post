---
layout: layouts/base.njk
title: Bookshelf Showcase
description: The freethought bookshelf, one book at a time.
permalink: /bookshelf/showcase/
eleventyExcludeFromCollections: true
---

{% block head %}
<style>
.bs-showcase { position:fixed;inset:0;background:var(--color-bg);color:var(--color-ink);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:var(--space-8) var(--gutter);z-index:9999;overflow:hidden; }
.bs-showcase__title { font-family:var(--font-headline);font-size:clamp(1.6rem,4vw,2.8rem);font-weight:700;text-align:center;max-width:20em;font-style:italic;opacity:0;transform:translateY(16px);transition:opacity 0.6s ease,transform 0.6s ease; }
.bs-showcase__title.is-visible { opacity:1;transform:translateY(0); }
.bs-showcase__author { font-family:var(--font-ui);font-size:clamp(0.9rem,1.5vw,1.1rem);font-weight:600;margin-top:var(--space-4);opacity:0;transition:opacity 0.6s ease 0.3s; }
.bs-showcase__author.is-visible { opacity:0.7; }
.bs-showcase__year { font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-accent);margin-top:var(--space-2);opacity:0;transition:opacity 0.5s ease 0.4s; }
.bs-showcase__year.is-visible { opacity:0.5; }
.bs-showcase__desc { font-family:var(--font-body);font-size:clamp(1rem,2vw,1.15rem);text-align:center;max-width:36em;line-height:1.65;color:var(--color-ink-muted);margin-top:var(--space-5);opacity:0;transition:opacity 0.6s ease 0.5s; }
.bs-showcase__desc.is-visible { opacity:1; }
.bs-showcase__nav { position:fixed;bottom:var(--space-6);left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:var(--space-4);font-family:var(--font-ui);font-size:var(--text-sm);opacity:0.3;transition:opacity 0.3s; }
.bs-showcase__nav:hover { opacity:0.7; }
.bs-showcase__nav button { background:none;border:1px solid currentColor;color:inherit;border-radius:50%;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s; }
.bs-showcase__nav button:hover { background:rgba(128,128,128,0.1); }
.bs-showcase__counter { font-variant-numeric:tabular-nums;white-space:nowrap; }
.bs-showcase__home { position:fixed;top:var(--space-6);left:50%;transform:translateX(-50%);text-decoration:none;color:inherit;opacity:0.25;transition:opacity 0.3s; }
.bs-showcase__home:hover { opacity:0.6; }
.bs-showcase__home-name { font-family:var(--font-headline);font-size:clamp(0.75rem,1.2vw,1rem);letter-spacing:0.12em;text-transform:uppercase; }
.bs-showcase__progress { position:fixed;bottom:0;left:0;height:2px;background:var(--color-accent);opacity:0.3;transition:width linear; }
</style>
{% endblock %}

<div class="bs-showcase" id="bs-showcase">
  <div class="bs-showcase__title" id="bs-title"></div>
  <div class="bs-showcase__author" id="bs-author"></div>
  <div class="bs-showcase__year" id="bs-year"></div>
  <div class="bs-showcase__desc" id="bs-desc"></div>
  <a class="bs-showcase__home" href="/bookshelf/" data-no-spa aria-label="Exit showcase"><span class="bs-showcase__home-name">&larr; Exit showcase</span></a>
  <div class="bs-showcase__nav">
    <button id="bs-prev" type="button" aria-label="Previous"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
    <span class="bs-showcase__counter" id="bs-counter"></span>
    <button id="bs-next" type="button" aria-label="Next"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    <button id="bs-pause" type="button" aria-label="Pause">
      <svg id="bs-pause-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg id="bs-play-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    </button>
  </div>
  <div class="bs-showcase__progress" id="bs-progress"></div>
</div>

{% block scripts %}
<script>
(function () {
  var books = [
    {% for book in collections.bookshelf | sort(false, false, 'data.year') %}
    { title: "{{ book.data.title | escape }}", author: "{{ book.data.bookAuthor | escape }}", year: {{ book.data.year }}, desc: "{{ book.data.description | escape }}" }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
  if (!books.length) return;
  var idx=0,paused=false,INTERVAL=12000,timer=null;
  var elTitle=document.getElementById('bs-title'),elAuthor=document.getElementById('bs-author'),elYear=document.getElementById('bs-year'),elDesc=document.getElementById('bs-desc'),elCounter=document.getElementById('bs-counter'),elProgress=document.getElementById('bs-progress'),pauseIcon=document.getElementById('bs-pause-icon'),playIcon=document.getElementById('bs-play-icon');
  function show(i){idx=((i%books.length)+books.length)%books.length;var b=books[idx];elTitle.classList.remove('is-visible');elAuthor.classList.remove('is-visible');elYear.classList.remove('is-visible');elDesc.classList.remove('is-visible');setTimeout(function(){elTitle.textContent=b.title;elAuthor.textContent=b.author;elYear.textContent=b.year;elDesc.textContent=b.desc;elCounter.textContent=(idx+1)+' / '+books.length;elTitle.classList.add('is-visible');elAuthor.classList.add('is-visible');elYear.classList.add('is-visible');elDesc.classList.add('is-visible');},400);resetProgress();}
  function resetProgress(){elProgress.style.transition='none';elProgress.style.width='0';if(!paused){clearTimeout(timer);requestAnimationFrame(function(){elProgress.style.transition='width '+(INTERVAL/1000)+'s linear';elProgress.style.width='100%';});timer=setTimeout(function(){show(idx+1);},INTERVAL);}}
  function togglePause(){paused=!paused;pauseIcon.style.display=paused?'none':'';playIcon.style.display=paused?'':'none';if(paused){clearTimeout(timer);elProgress.style.transition='none';elProgress.style.width='0';}else{resetProgress();}}
  document.getElementById('bs-prev').addEventListener('click',function(e){e.stopPropagation();show(idx-1);});
  document.getElementById('bs-next').addEventListener('click',function(e){e.stopPropagation();show(idx+1);});
  document.getElementById('bs-pause').addEventListener('click',function(e){e.stopPropagation();togglePause();});
  document.addEventListener('keydown',function(e){if(e.key==='ArrowLeft')show(idx-1);else if(e.key==='ArrowRight'||e.key===' '){e.preventDefault();show(idx+1);}else if(e.key==='p')togglePause();else if(e.key==='Escape')window.location.href='/bookshelf/';});
  var w=document.querySelector('.site-wrapper');if(w){document.body.appendChild(document.getElementById('bs-showcase'));w.style.display='none';}document.body.style.overflow='hidden';
  show(0);
})();
</script>
{% endblock %}
