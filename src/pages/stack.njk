<script>
(function () {
  var links = document.querySelectorAll('.sg-nav a');
  var sections = Array.from(links).map(function (a) { return document.querySelector(a.getAttribute('href')); }).filter(Boolean);
  function onScroll() {
    var scrollY = window.scrollY + 100;
    var current = sections[0];
    sections.forEach(function (s) { if (s && s.offsetTop <= scrollY) current = s; });
    links.forEach(function (a) {
      a.classList.toggle('sg-active', current && a.getAttribute('href') === '#' + current.id);
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
