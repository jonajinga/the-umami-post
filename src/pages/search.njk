---
layout: base
title: Search
description: Search all articles, quotes, library texts, glossary terms, videos, timeline, and more.
permalink: /search/
---

<div class="container" style="padding-top: 0; padding-bottom: var(--space-20);">

  {# ── Sticky search bar (input + section filters), sits flush below masthead ─── #}
  <div class="sp-sticky">

    <div class="sp-input-wrap">
      <svg class="sp-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="sp-input" placeholder="Search articles, quotes, library, glossary…" autocomplete="off" autofocus aria-keyshortcuts="/">
      <button type="button" id="sp-clear" class="sp-clear" hidden aria-label="Clear search">&#10005;</button>
      <div id="sp-autocomplete" class="sp-autocomplete" hidden></div>
    </div>

    <div id="sp-filters" class="sp-filters">
      <button class="sp-filter is-active" data-section="" type="button">All</button>
      <button class="sp-filter" data-section="News" type="button">News</button>
      <button class="sp-filter" data-section="Opinion" type="button">Opinion</button>
      <button class="sp-filter" data-section="Analysis" type="button">Analysis</button>
      <button class="sp-filter" data-section="Arts & Culture" type="button">Arts &amp; Culture</button>
      <button class="sp-filter" data-section="Science & Technology" type="button">Science &amp; Tech</button>
      <button class="sp-filter" data-section="History" type="button">History</button>
      <button class="sp-filter" data-section="Letters" type="button">Letters</button>
      <button class="sp-filter" data-section="Reviews" type="button">Reviews</button>
      <button class="sp-filter" data-section="Quotes" type="button">Quotes</button>
      <button class="sp-filter" data-section="Videos" type="button">Videos</button>
      <button class="sp-filter" data-section="Timeline" type="button">Timeline</button>
      <button class="sp-filter" data-section="Glossary" type="button">Glossary</button>
      <button class="sp-filter" data-section="Bookshelf" type="button">Bookshelf</button>
      <button class="sp-filter" data-section="Library" type="button">Library</button>
      <button class="sp-filter" data-section="Authors" type="button">Authors</button>
      <button class="sp-filter" data-section="Thought Experiments" type="button">Thought Experiments</button>
      <button class="sp-filter" data-section="Trials of Thought" type="button">Trials</button>
    </div>

  </div>

  {# ── Page title (sits below the sticky bar) ─────────────────── #}
  <header class="sp-header">
    <p class="sp-header__kicker">Search</p>
    <h1 class="sp-header__title">Find anything we&rsquo;ve published</h1>
    <p class="sp-header__lede">
      Articles, quotes, library texts, glossary terms, timeline, and more &mdash; across every section.
    </p>
    <p class="sp-header__hint">
      <kbd>/</kbd> focuses search from anywhere. Use <kbd>&darr;</kbd>&thinsp;<kbd>&uarr;</kbd> to navigate results. Press <kbd>Enter</kbd> to open the focused result.
    </p>
  </header>

  {# ── States, only one visible at a time ─────────────────────── #}
  <div id="sp">

    <div id="sp-default" class="sp-state">
      <div id="sp-saved"></div>
      <div id="sp-history"></div>
      <div class="sp-try">
        <p class="sp-try__label">Try searching for</p>
        <div class="sp-try__list">
          <button class="sp-try__btn" type="button">Ingersoll</button>
          <button class="sp-try__btn" type="button">separation of church and state</button>
          <button class="sp-try__btn" type="button">epistemology</button>
          <button class="sp-try__btn" type="button">Thomas Paine</button>
          <button class="sp-try__btn" type="button">Darwin</button>
          <button class="sp-try__btn" type="button">free speech</button>
          <button class="sp-try__btn" type="button">Carl Sagan</button>
        </div>
      </div>
    </div>

    <div id="sp-loading" class="sp-state sp-loading" hidden>
      <p class="sp-loading__label">Searching&hellip;</p>
    </div>

    <div id="sp-active" class="sp-state" hidden>
      <div class="sp-results-header">
        <span id="sp-count" aria-live="polite" aria-atomic="true"></span>
        <div id="sp-section-counts" class="sp-section-counts"></div>
        <div class="sp-sort">
          <button type="button" id="sp-save" class="sp-save-btn" title="Save this search">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-1px"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            Save
          </button>
          <select id="sp-sort" class="sp-sort-select" aria-label="Sort results">
            <option value="relevance">Relevance</option>
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
          </select>
        </div>
      </div>
      <div id="sp-results"></div>
      <div id="sp-more" class="sp-more" hidden>
        <button type="button" id="sp-more-btn" class="sp-more-btn">Load more results</button>
      </div>
    </div>

    <div id="sp-empty" class="sp-state sp-empty" hidden>
      <p class="sp-empty__title">No results found</p>
      <p class="sp-empty__lede">Try a different spelling, fewer words, or broaden the section filter. Or browse by project:</p>
      <div class="sp-empty__browse">
        <a href="/archives/" class="sp-browse">Archives</a>
        <a href="/topics/" class="sp-browse">Topics</a>
        <a href="/quotes/" class="sp-browse">Quotes</a>
        <a href="/library/" class="sp-browse">Library</a>
        <a href="/glossary/" class="sp-browse">Glossary</a>
        <a href="/timeline/" class="sp-browse">Timeline</a>
        <a href="/videos/" class="sp-browse">Videos</a>
        <a href="/bookshelf/" class="sp-browse">Bookshelf</a>
      </div>
    </div>

  </div>
</div>

<style>
/* ── Search page ─────────────────────────────────────────────── */

/* Header card */
.sp-header {
  margin-top: var(--space-8);
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-6);
  border-bottom: 3px solid var(--color-ink);
}
.sp-header__kicker {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-accent);
  margin: 0 0 var(--space-2);
}
.sp-header__title {
  font-family: var(--font-masthead, var(--font-headline));
  font-size: clamp(1.8rem, 5vw, 3.2rem);
  line-height: var(--leading-tight);
  color: var(--color-ink);
  margin: 0 0 var(--space-3);
}
.sp-header__lede {
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-ink-muted);
  font-style: italic;
  margin: 0 0 var(--space-3);
  max-width: 62ch;
}
.sp-header__hint {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--color-ink-faint);
  margin: 0;
}
.sp-header__hint kbd {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 1px 6px;
  border: 1px solid var(--color-rule);
  background: var(--color-bg-alt);
  color: var(--color-ink);
  border-radius: 3px;
}

/* Empty + loading polish */
.sp-loading__label {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-ink-faint);
  margin: 0;
}
.sp-empty {
  text-align: center;
  padding: var(--space-10) 0;
}
.sp-empty__title {
  font-family: var(--font-headline);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 var(--space-2);
}
.sp-empty__lede {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  margin: 0 0 var(--space-6);
  max-width: 52ch;
  margin-inline: auto;
}
.sp-empty__browse {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  justify-content: center;
}

/* Sticky bar: input + filter pills. Same behavior as .archive-toolbar,
   sits flush below the sticky masthead (7rem full / 4.5rem below 1180px). */
.sp-sticky {
  position: sticky;
  top: 7rem;
  z-index: 99;
  background: var(--color-bg);
  padding: var(--space-4) 0;
  margin-bottom: 0;
  border-bottom: 1px solid var(--color-rule-heavy);
}
@media (max-width: 1180px) {
  .sp-sticky { top: 4.5rem; }
}

.sp-input-wrap { position: relative; margin-bottom: var(--space-4); }
.sp-input-icon { position: absolute; left: var(--space-4); top: 50%; transform: translateY(-50%); color: var(--color-ink-faint); pointer-events: none; }
#sp-input {
  width: 100%;
  font-family: var(--font-body);
  font-size: var(--text-lg);
  padding: var(--space-4) var(--space-10) var(--space-4) var(--space-12);
  border: 2px solid var(--color-rule-heavy);
  background: var(--color-bg-alt);
  color: var(--color-ink);
}
#sp-input:focus { outline: none; border-color: var(--color-ink); }
#sp-input::placeholder { color: var(--color-ink-faint); }
#sp-input::-webkit-search-cancel-button { display: none; -webkit-appearance: none; }
.sp-clear { position: absolute; right: var(--space-4); top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--color-ink-faint); cursor: pointer; font-size: var(--text-md); padding: var(--space-2); }
.sp-clear:hover { color: var(--color-ink); }

/* Section filter pills */
.sp-filters { display: flex; flex-wrap: wrap; gap: var(--space-1); margin-bottom: 0; }
.sp-filter {
  font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 600;
  color: var(--color-ink-muted); background: none; border: 1px solid var(--color-rule);
  padding: var(--space-1) var(--space-3); cursor: pointer; white-space: nowrap;
  transition: all var(--transition-fast);
}
.sp-filter:hover { border-color: var(--color-ink); color: var(--color-ink); }
.sp-filter.is-active { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }

/* States */
.sp-state { padding-top: var(--space-2); }

/* Try suggestions */
.sp-try__label { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); margin: 0 0 var(--space-3); text-transform: uppercase; letter-spacing: 0.08em; }
.sp-try__list { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.sp-try__btn { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-link); background: none; border: 1px solid var(--color-rule); padding: var(--space-2) var(--space-3); cursor: pointer; transition: all var(--transition-fast); }
.sp-try__btn:hover { border-color: var(--color-link); background: var(--color-bg-alt); }

/* History */
.sp-history__label { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); margin: 0 0 var(--space-2); text-transform: uppercase; letter-spacing: 0.08em; }
.sp-history__item { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-link); background: none; border: none; cursor: pointer; padding: var(--space-1) 0; display: block; text-align: left; }
.sp-history__item:hover { text-decoration: underline; }
.sp-history__clear { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); background: none; border: none; cursor: pointer; margin-top: var(--space-2); padding: 0; }
.sp-history__clear:hover { color: var(--color-ink); }
#sp-history:not(:empty) { margin-bottom: var(--space-8); padding-bottom: var(--space-6); border-bottom: 1px solid var(--color-rule); }

/* Saved searches */
.sp-saved__label { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); margin: 0 0 var(--space-2); text-transform: uppercase; letter-spacing: 0.08em; }
.sp-saved__item { display: flex; justify-content: space-between; align-items: center; padding: var(--space-1) 0; }
.sp-saved__link { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-link); background: none; border: none; cursor: pointer; padding: 0; text-align: left; flex: 1; }
.sp-saved__link:hover { text-decoration: underline; }
.sp-saved__meta { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); margin-left: var(--space-3); }
.sp-saved__del { background: none; border: none; color: var(--color-ink-faint); cursor: pointer; font-size: var(--text-md); padding: 0 var(--space-2); line-height: 1; }
.sp-saved__del:hover { color: var(--color-accent); }
#sp-saved:not(:empty) { margin-bottom: var(--space-8); padding-bottom: var(--space-6); border-bottom: 1px solid var(--color-rule); }

.sp-save-btn { font-family: var(--font-ui); font-size: var(--text-xs); background: var(--color-bg); border: 1px solid var(--color-rule); color: var(--color-ink); padding: var(--space-1) var(--space-2); cursor: pointer; transition: all var(--transition-fast); display: inline-flex; align-items: center; gap: 4px; }
.sp-save-btn:hover { border-color: var(--color-ink); color: var(--color-ink); }
.sp-save-btn.is-saved { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }

/* Results header */
.sp-results-header { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-3); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-rule); margin-bottom: var(--space-4); font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); }
.sp-section-counts { display: flex; flex-wrap: wrap; gap: var(--space-2); flex: 1; }
.sp-section-count { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-muted); background: none; border: 1px solid var(--color-rule); padding: 1px var(--space-2); cursor: pointer; transition: all var(--transition-fast); }
.sp-section-count:hover { border-color: var(--color-ink); color: var(--color-ink); }
.sp-sort { flex-shrink: 0; display: flex; align-items: center; gap: var(--space-2); }
.sp-sort-select { font-family: var(--font-ui); font-size: var(--text-xs); background: var(--color-bg); border: 1px solid var(--color-rule); color: var(--color-ink); padding: var(--space-1) var(--space-2); cursor: pointer; }

/* Results */
.sp-result {
  display: block;
  padding: var(--space-4) var(--space-6) var(--space-6) var(--space-8);
  border-left: 3px solid var(--color-rule);
  border-bottom: 1px solid var(--color-rule);
  text-decoration: none;
  transition: background var(--transition-fast);
}
.sp-result:hover { background: var(--color-bg-alt); }
.sp-result.is-focused { background: var(--color-bg-alt); outline: 2px solid var(--color-link); outline-offset: -2px; }
.sp-result[data-section="News"]                { border-left-color: var(--color-news); }
.sp-result[data-section="Opinion"]             { border-left-color: var(--color-opinion); }
.sp-result[data-section="Analysis"]            { border-left-color: var(--color-analysis); }
.sp-result[data-section="Arts & Culture"]      { border-left-color: var(--color-arts-culture); }
.sp-result[data-section="Science & Technology"] { border-left-color: var(--color-science); }
.sp-result[data-section="History"]             { border-left-color: var(--color-history); }
.sp-result[data-section="Letters"]             { border-left-color: var(--color-letters); }
.sp-result[data-section="Reviews"]             { border-left-color: var(--color-reviews); }
.sp-result[data-section="Quotes"]              { border-left-color: var(--color-history); }
.sp-result[data-section="Videos"]              { border-left-color: var(--color-arts-culture); }
.sp-result[data-section="Timeline"]            { border-left-color: var(--color-science); }
.sp-result[data-section="Glossary"]            { border-left-color: var(--color-glossary); }
.sp-result[data-section="Bookshelf"]           { border-left-color: var(--color-bookshelf); }
.sp-result[data-section="Library"]             { border-left-color: var(--color-opinion); }
.sp-result[data-section="Thought Experiments"] { border-left-color: var(--color-thought-experiments); }
.sp-result[data-section="Trials of Thought"]   { border-left-color: var(--color-trials); }
/* Section badge inside result, override display for inline flow */
.sp-result .section-badge { display: inline-block; margin-bottom: var(--space-3); }
.sp-result__title { font-family: var(--font-headline); font-size: var(--text-md); font-weight: 700; color: var(--color-ink); line-height: var(--leading-snug); display: block; margin-bottom: var(--space-3); }
.sp-result__excerpt { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-ink-muted); line-height: var(--leading-relaxed); display: block; }
.sp-result__excerpt mark { background: transparent; color: var(--color-accent); font-weight: 600; }
.sp-result__url { font-family: var(--font-ui); font-size: 11px; color: var(--color-ink-faint); display: block; margin-top: var(--space-3); padding-top: var(--space-2); border-top: 1px solid var(--color-rule); }

/* Load more */
.sp-more { text-align: center; margin-top: var(--space-8); }
.sp-more-btn { font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 700; color: var(--color-bg); background: var(--color-ink); border: none; padding: var(--space-3) var(--space-8); cursor: pointer; min-height: 44px; transition: background var(--transition-fast); }
.sp-more-btn:hover { background: var(--color-accent); }

/* Browse links (empty state) */
.sp-browse { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-link); text-decoration: none; font-weight: 600; padding: var(--space-2) var(--space-3); border: 1px solid var(--color-rule); transition: all var(--transition-fast); }
.sp-browse:hover { border-color: var(--color-link); background: var(--color-bg-alt); }

/* Autocomplete, z-index must clear the sticky bar */
.sp-autocomplete {
  position: absolute; left: 0; right: 0; top: 100%; z-index: 200;
  background: var(--color-bg); border: 1px solid var(--color-rule-heavy); border-top: none;
  max-height: 320px; overflow-y: auto;
}
.sp-ac-item {
  display: flex; flex-direction: column; gap: 2px;
  padding: var(--space-3) var(--space-4); cursor: pointer;
  border-bottom: 1px solid var(--color-rule);
  text-decoration: none; color: var(--color-ink);
  transition: background var(--transition-fast);
}
.sp-ac-item:last-child { border-bottom: none; }
.sp-ac-item:hover, .sp-ac-item.is-focused { background: var(--color-bg-alt); }
.sp-ac-item__title { font-family: var(--font-headline); font-size: var(--text-sm); font-weight: 600; }
.sp-ac-item__section { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); text-transform: uppercase; letter-spacing: 0.06em; }

@media (max-width: 640px) {
  #sp-input { font-size: var(--text-md); padding: var(--space-3) var(--space-8) var(--space-3) var(--space-10); }
}
</style>

<script type="module">
(async function () {
  var $ = function (id) { return document.getElementById(id); };
  var input = $('sp-input'), clearBtn = $('sp-clear');
  var stDefault = $('sp-default'), stLoading = $('sp-loading'), stActive = $('sp-active'), stEmpty = $('sp-empty');
  var resultsEl = $('sp-results'), countEl = $('sp-count'), moreWrap = $('sp-more'), moreBtn = $('sp-more-btn');
  var sectionCountsEl = $('sp-section-counts'), sortSelect = $('sp-sort'), historyEl = $('sp-history');
  var savedEl = $('sp-saved'), saveBtn = $('sp-save');
  var filterBtns = document.querySelectorAll('.sp-filter');

  var pagefind, activeSection = '', allResults = [], shown = 0, PAGE = 15, HKEY = 'tft-search-history', SKEY = 'tft-saved-searches', focusIdx = -1;
  var acEl = $('sp-autocomplete'), acIdx = -1, acDb;

  // URL params
  var p = new URLSearchParams(location.search);
  if (p.get('q')) input.value = p.get('q');
  if (p.get('section')) {
    activeSection = p.get('section');
    filterBtns.forEach(function (b) { b.classList.toggle('is-active', (b.dataset.section || '') === activeSection); });
  }

  try {
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.options({ excerptLength: 30 });
  } catch (e) {
    resultsEl.innerHTML = '<p style="color:var(--color-ink-faint)">Search unavailable.</p>';
    return;
  }

  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
  function showState(el) {
    [stDefault, stLoading, stActive, stEmpty].forEach(function (s) { s.hidden = s !== el; });
    if (el === stActive || el === stEmpty) hideAc();
  }

  // History
  function getH() { try { return JSON.parse(localStorage.getItem(HKEY)) || []; } catch (e) { return []; } }
  function saveH(q) { if (!q) return; var h = getH().filter(function (x) { return x !== q; }); h.unshift(q); try { localStorage.setItem(HKEY, JSON.stringify(h.slice(0, 5))); } catch (e) {} }
  function showHistory() {
    var h = getH();
    if (!h.length) { historyEl.innerHTML = ''; return; }
    historyEl.innerHTML = '<p class="sp-history__label">Recent searches</p>' +
      h.map(function (q) { return '<button class="sp-history__item" type="button">' + esc(q) + '</button>'; }).join('') +
      '<button class="sp-history__clear" type="button">Clear history</button>';
    historyEl.querySelectorAll('.sp-history__item').forEach(function (b) { b.onclick = function () { input.value = b.textContent; search(); }; });
    historyEl.querySelector('.sp-history__clear').onclick = function () { localStorage.removeItem(HKEY); historyEl.innerHTML = ''; };
  }

  // Saved searches
  function getS() { try { return JSON.parse(localStorage.getItem(SKEY)) || []; } catch (e) { return []; } }
  function setS(arr) { try { localStorage.setItem(SKEY, JSON.stringify(arr)); } catch (e) {} }
  function isCurrentSaved() {
    var q = input.value.trim();
    if (!q) return false;
    return getS().some(function (s) { return s.q === q && s.section === activeSection; });
  }
  function updateSaveBtn() {
    if (!saveBtn) return;
    saveBtn.classList.toggle('is-saved', isCurrentSaved());
    saveBtn.title = isCurrentSaved() ? 'Remove from saved searches' : 'Save this search';
  }
  function showSaved() {
    if (!savedEl) return;
    var list = getS();
    if (!list.length) { savedEl.innerHTML = ''; return; }
    savedEl.innerHTML = '<p class="sp-saved__label">Saved searches</p>' +
      list.map(function (s, i) {
        var label = esc(s.q) + (s.section ? ' <span class="sp-saved__meta">in ' + esc(s.section) + '</span>' : '');
        return '<div class="sp-saved__item"><button class="sp-saved__link" type="button" data-idx="' + i + '">' + label + '</button><button class="sp-saved__del" type="button" data-idx="' + i + '" aria-label="Remove">&times;</button></div>';
      }).join('');
    savedEl.querySelectorAll('.sp-saved__link').forEach(function (b) {
      b.onclick = function () {
        var item = getS()[b.dataset.idx];
        if (!item) return;
        input.value = item.q;
        activeSection = item.section || '';
        filterBtns.forEach(function (f) { f.classList.toggle('is-active', (f.dataset.section || '') === activeSection); });
        search();
      };
    });
    savedEl.querySelectorAll('.sp-saved__del').forEach(function (b) {
      b.onclick = function () { var list = getS(); list.splice(b.dataset.idx, 1); setS(list); showSaved(); updateSaveBtn(); };
    });
  }

  function renderResult(item) {
    var s = item.meta && item.meta.section ? item.meta.section : '';
    var slug = s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    var badge = s ? '<span class="section-badge section-badge--' + slug + '">' + esc(s) + '</span>' : '';
    return '<a class="sp-result" href="' + item.url + '" data-section="' + esc(s) + '" tabindex="0">' +
      badge +
      '<span class="sp-result__title">' + esc(item.meta && item.meta.title ? item.meta.title : 'Untitled') + '</span>' +
      '<span class="sp-result__excerpt">' + (item.excerpt || '') + '</span>' +
      '<span class="sp-result__url">' + item.url + '</span></a>';
  }

  async function search() {
    var q = input.value.trim();
    clearBtn.hidden = !q;

    if (!q && !activeSection) { showState(stDefault); showSaved(); showHistory(); updateURL(q); return; }

    showState(stLoading);
    updateURL(q);
    if (q) saveH(q);

    var opts = {};
    if (activeSection) opts.filters = { section: activeSection };
    var s = await pagefind.search(q || null, opts);

    // Section counts (only for unfiltered searches)
    if (q && !activeSection) {
      var secs = ['News','Opinion','Analysis','Arts & Culture','Science & Technology','History','Letters','Reviews','Quotes','Videos','Timeline','Glossary','Bookshelf','Library','Authors','Thought Experiments','Trials of Thought'];
      var counts = await Promise.all(secs.map(async function (sec) {
        var r = await pagefind.search(q, { filters: { section: sec } });
        return { s: sec, c: r.results.length };
      }));
      var hits = counts.filter(function (x) { return x.c > 0; });
      sectionCountsEl.innerHTML = hits.length > 1 ? hits.map(function (x) {
        return '<button class="sp-section-count" type="button" data-section="' + esc(x.s) + '">' + esc(x.s) + ' (' + x.c + ')</button>';
      }).join('') : '';
      sectionCountsEl.querySelectorAll('.sp-section-count').forEach(function (btn) {
        btn.onclick = function () {
          filterBtns.forEach(function (f) { f.classList.toggle('is-active', (f.dataset.section || '') === btn.dataset.section); });
          activeSection = btn.dataset.section;
          search();
        };
      });
    } else { sectionCountsEl.innerHTML = ''; }

    allResults = await Promise.all(s.results.map(function (r) { return r.data(); }));
    if (!allResults.length) { showState(stEmpty); return; }

    showState(stActive);
    shown = 0;
    applySort();
    render(true);
    updateSaveBtn();
  }

  function applySort() {
    var v = sortSelect.value;
    if (v === 'newest') allResults.sort(function (a, b) { return ((b.meta && b.meta.date) || '').localeCompare((a.meta && a.meta.date) || ''); });
    else if (v === 'oldest') allResults.sort(function (a, b) { return ((a.meta && a.meta.date) || '').localeCompare((b.meta && b.meta.date) || ''); });
  }

  function render(initial) {
    var batch = allResults.slice(shown, shown + PAGE);
    shown += batch.length;
    var html = batch.map(renderResult).join('');
    if (initial) resultsEl.innerHTML = html; else resultsEl.insertAdjacentHTML('beforeend', html);
    countEl.textContent = allResults.length + ' result' + (allResults.length !== 1 ? 's' : '');
    moreWrap.hidden = shown >= allResults.length;
    moreBtn.textContent = 'Load more (' + (allResults.length - shown) + ' remaining)';
    focusIdx = -1;
  }

  function updateURL(q) {
    var u = new URL(location);
    if (q) u.searchParams.set('q', q); else u.searchParams.delete('q');
    if (activeSection) u.searchParams.set('section', activeSection); else u.searchParams.delete('section');
    history.replaceState(null, '', u);
  }

  // Autocomplete
  function hideAc() { acEl.hidden = true; acEl.innerHTML = ''; acIdx = -1; }
  async function showAc(q) {
    if (!q || q.length < 2 || !pagefind) { hideAc(); return; }
    var s = await pagefind.search(q);
    var top = s.results.slice(0, 5);
    if (!top.length) { hideAc(); return; }
    var items = await Promise.all(top.map(function (r) { return r.data(); }));
    acEl.innerHTML = items.map(function (item) {
      var sec = item.meta && item.meta.section ? item.meta.section : '';
      return '<a class="sp-ac-item" href="' + item.url + '"><span class="sp-ac-item__section">' + esc(sec) + '</span><span class="sp-ac-item__title">' + esc(item.meta && item.meta.title ? item.meta.title : 'Untitled') + '</span></a>';
    }).join('');
    acEl.hidden = false;
    acIdx = -1;
  }
  function acNav(dir) {
    var items = acEl.querySelectorAll('.sp-ac-item');
    if (!items.length) return false;
    items.forEach(function (i) { i.classList.remove('is-focused'); });
    acIdx += dir;
    if (acIdx < 0) acIdx = -1;
    if (acIdx >= items.length) acIdx = items.length - 1;
    if (acIdx >= 0) { items[acIdx].classList.add('is-focused'); items[acIdx].scrollIntoView({ block: 'nearest' }); }
    return acIdx >= 0;
  }

  // Events
  var db;
  input.addEventListener('input', function () {
    clearTimeout(db); clearTimeout(acDb);
    clearBtn.hidden = !input.value;
    acDb = setTimeout(function () { showAc(input.value.trim()); }, 150);
    db = setTimeout(search, 400);
  });
  input.addEventListener('keydown', function (e) {
    if (!acEl.hidden) {
      if (e.key === 'ArrowDown') { e.preventDefault(); acNav(1); return; }
      if (e.key === 'ArrowUp')   { e.preventDefault(); acNav(-1); return; }
      if (e.key === 'Enter' && acIdx >= 0) { e.preventDefault(); acEl.querySelectorAll('.sp-ac-item')[acIdx].click(); return; }
      if (e.key === 'Escape') { hideAc(); return; }
    }
    if (e.key === 'Enter') { clearTimeout(db); clearTimeout(acDb); hideAc(); search(); }
  });
  input.addEventListener('focus', function () {
    if (input.value.trim().length >= 2) { clearTimeout(acDb); acDb = setTimeout(function () { showAc(input.value.trim()); }, 150); }
  });
  document.addEventListener('click', function (e) { if (!acEl.contains(e.target) && e.target !== input) hideAc(); });
  clearBtn.onclick = function () { input.value = ''; clearBtn.hidden = true; hideAc(); search(); input.focus(); };
  moreBtn.onclick = function () { render(false); };
  sortSelect.onchange = function () { applySort(); shown = 0; render(true); };
  filterBtns.forEach(function (b) {
    b.onclick = function () {
      filterBtns.forEach(function (x) { x.classList.remove('is-active'); });
      b.classList.add('is-active');
      activeSection = b.dataset.section || '';
      search();
    };
  });

  if (saveBtn) saveBtn.onclick = function () {
    var q = input.value.trim();
    if (!q) return;
    var list = getS();
    var idx = list.findIndex(function (s) { return s.q === q && s.section === activeSection; });
    if (idx >= 0) list.splice(idx, 1);
    else list.unshift({ q: q, section: activeSection, ts: Date.now() });
    setS(list);
    updateSaveBtn();
    showSaved();
  };

  document.querySelectorAll('.sp-try__btn').forEach(function (b) {
    b.onclick = function () { input.value = b.textContent; search(); };
  });

  // Arrow-key navigation through results
  document.addEventListener('keydown', function (e) {
    var rs = resultsEl.querySelectorAll('.sp-result');
    if (!rs.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      focusIdx = Math.min(focusIdx + 1, rs.length - 1);
      rs.forEach(function (r, i) { r.classList.toggle('is-focused', i === focusIdx); });
      rs[focusIdx].scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      focusIdx = Math.max(focusIdx - 1, -1);
      rs.forEach(function (r, i) { r.classList.toggle('is-focused', i === focusIdx); });
      if (focusIdx === -1) input.focus(); else rs[focusIdx].scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && focusIdx >= 0) {
      e.preventDefault();
      rs[focusIdx].click();
    }
  });

  // Init
  if (input.value || activeSection) search(); else { showState(stDefault); showSaved(); showHistory(); }
})();
</script>
