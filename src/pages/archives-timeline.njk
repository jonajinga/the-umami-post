---
layout: base
title: Archive Timeline
description: Every article published in The Freethinking Times, in chronological order. Narrow by author, section, subsection, or topic.
permalink: /archives/timeline/
eleventyExcludeFromCollections: true
---

<div class="container at-layout">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/archives/">Archives</a></li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Timeline</li>
    </ol>
  </nav>

  <header class="at-header">
    <p class="at-kicker">Chronological view</p>
    <h1 class="at-title" id="at-title">Archive Timeline</h1>
    <p class="at-lede" id="at-lede"></p>
    <div class="at-header__actions">
      <a id="at-view-showcase" href="/archives/showcase/" class="btn btn--accent">View as showcase</a>
      <a href="/archives/" class="btn">Back to archives</a>
    </div>
  </header>

  <div class="at-controls">
    <label class="at-filter">
      <span class="at-filter__label">Author</span>
      <select id="at-author" class="at-filter__select">
        <option value="">All authors</option>
      </select>
    </label>
    <label class="at-filter">
      <span class="at-filter__label">Section</span>
      <select id="at-section" class="at-filter__select">
        <option value="">All sections</option>
      </select>
    </label>
    <label class="at-filter" id="at-subsection-wrap" hidden>
      <span class="at-filter__label">Subsection</span>
      <select id="at-subsection" class="at-filter__select">
        <option value="">All subsections</option>
      </select>
    </label>
    <label class="at-filter">
      <span class="at-filter__label">Topic</span>
      <select id="at-topic" class="at-filter__select">
        <option value="">All topics</option>
      </select>
    </label>
    <label class="at-filter">
      <span class="at-filter__label">Year</span>
      <select id="at-year" class="at-filter__select">
        <option value="">All years</option>
      </select>
    </label>
    <button id="at-clear" type="button" class="at-clear" hidden>Clear filters</button>
    <span id="at-count" class="at-count" aria-live="polite"></span>
  </div>

  <div id="at-list" class="at-list" data-pagefind-ignore></div>

  <p id="at-empty" class="at-empty" hidden>No articles match these filters.</p>

</div>

<style>
.at-layout {
  padding-top: var(--space-10);
  padding-bottom: var(--space-20);
  max-width: var(--max-width-prose-wide, 900px);
}

/* Header */
.at-header {
  padding-bottom: var(--space-6);
  margin-bottom: var(--space-8);
  border-bottom: 3px solid var(--color-ink);
}
.at-kicker {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-accent);
  margin: 0 0 var(--space-3);
}
.at-title {
  font-family: var(--font-masthead, var(--font-headline));
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: var(--leading-tight);
  color: var(--color-ink);
  margin: 0 0 var(--space-3);
}
.at-lede {
  font-family: var(--font-body);
  font-size: var(--text-md);
  font-style: italic;
  color: var(--color-ink-muted);
  margin: 0 0 var(--space-5);
  max-width: 56ch;
}
.at-header__actions {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

/* Controls row */
.at-controls {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: var(--space-3);
  padding: var(--space-4);
  background: var(--color-bg-alt);
  border: 1px solid var(--color-rule);
  margin-bottom: var(--space-8);
}
.at-filter {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 140px;
  flex: 1 1 160px;
}
.at-filter__label {
  font-family: var(--font-ui);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-ink-faint);
}
.at-filter__select {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-3);
  min-height: 40px;
  background: var(--color-bg);
  color: var(--color-ink);
  border: 1px solid var(--color-rule);
  cursor: pointer;
}
.at-filter__select:focus {
  outline: none;
  border-color: var(--color-ink);
}
.at-clear {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0 var(--space-4);
  min-height: 40px;
  background: transparent;
  color: var(--color-ink-muted);
  border: 1px solid var(--color-rule);
  cursor: pointer;
  transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
}
.at-clear:hover {
  background: var(--color-ink);
  color: var(--color-bg);
  border-color: var(--color-ink);
}
.at-count {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--color-ink-faint);
  margin-left: auto;
  font-variant-numeric: tabular-nums;
}

/* Timeline body */
.at-list {
  display: block;
}
.at-year {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  padding-bottom: var(--space-2);
  margin: var(--space-10) 0 var(--space-4);
  border-bottom: 2px solid var(--color-ink);
}
.at-year:first-of-type { margin-top: 0; }
.at-year__n {
  font-family: var(--font-masthead, var(--font-headline));
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  font-weight: 700;
  line-height: 1;
  color: var(--color-ink);
}
.at-year__count {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-ink-faint);
  margin-left: auto;
}
.at-month {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent);
  margin: var(--space-6) 0 var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1px solid var(--color-rule);
}
.at-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  column-gap: var(--space-5);
  row-gap: 2px;
  padding: var(--space-4) 0;
  border-bottom: 1px solid var(--color-rule);
  text-decoration: none;
  color: var(--color-ink);
  transition: background var(--transition-fast);
}
.at-item:hover { background: var(--color-bg-alt); }
.at-item__date {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  font-variant-numeric: tabular-nums;
  color: var(--color-ink-faint);
  padding-top: 2px;
}
.at-item__body { min-width: 0; grid-column: 2; }
.at-item__listen { margin-top: var(--space-2); }
.at-item__section {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent);
  display: block;
  margin-bottom: 4px;
}
.at-item__title {
  font-family: var(--font-headline);
  font-weight: 700;
  font-size: var(--text-md);
  line-height: var(--leading-snug);
  color: var(--color-ink);
  margin: 0 0 4px;
}
.at-item:hover .at-item__title { color: var(--color-accent); }
.at-item__meta {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--color-ink-muted);
  margin: 0;
}
@media (max-width: 640px) {
  .at-item { grid-template-columns: 1fr; row-gap: 4px; }
  .at-item__body { grid-column: 1; }
  .at-item__date { padding-top: 0; }
}

.at-empty {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  font-style: italic;
  color: var(--color-ink-muted);
  text-align: center;
  padding: var(--space-12) 0;
}
</style>

<script id="at-data" type="application/json">
{%- set _articles = [] -%}
{%- for a in collections.allContent -%}
  {%- set entry = {
    url: a.url,
    title: a.data.title,
    date: a.data.date | isoDate,
    section: a.data.section,
    sectionSlug: a.data.section | slugify,
    subsection: a.data.subsection,
    author: a.data.author,
    authorName: (authors[a.data.author].name if a.data.author and authors[a.data.author] else (a.data.authorName or '')),
    tags: a.data.tags | rejectattr('post')
  } -%}
  {%- set _articles = _articles.concat([entry]) -%}
{%- endfor -%}
{{ _articles | dump | safe }}
</script>

<script>
(function () {
  var data = [];
  try { data = JSON.parse(document.getElementById('at-data').textContent); } catch (e) {}

  function normSlug(s) { return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }

  var titleEl = document.getElementById('at-title');
  var ledeEl = document.getElementById('at-lede');
  var listEl = document.getElementById('at-list');
  var countEl = document.getElementById('at-count');
  var emptyEl = document.getElementById('at-empty');
  var showcaseLink = document.getElementById('at-view-showcase');
  var clearBtn = document.getElementById('at-clear');
  var authorSel = document.getElementById('at-author');
  var sectionSel = document.getElementById('at-section');
  var subsectionSel = document.getElementById('at-subsection');
  var subsectionWrap = document.getElementById('at-subsection-wrap');
  var topicSel = document.getElementById('at-topic');
  var yearSel = document.getElementById('at-year');

  // Build { sectionSlug: { subsectionSlug: displayName } } for the
  // dependent subsection dropdown below.
  var subsByBySection = {};
  data.forEach(function (a) {
    if (!a.section || !a.subsection) return;
    var sec = normSlug(a.sectionSlug || a.section);
    var sub = normSlug(a.subsection);
    if (!subsByBySection[sec]) subsByBySection[sec] = {};
    subsByBySection[sec][sub] = a.subsection;
  });
  function populateSubsections(sectionSlugNorm) {
    // Clear existing (keep the first "All" option)
    while (subsectionSel.options.length > 1) subsectionSel.remove(1);
    var subs = subsByBySection[sectionSlugNorm] || {};
    var keys = Object.keys(subs).sort(function (a, b) { return subs[a].localeCompare(subs[b]); });
    if (!keys.length) { subsectionWrap.hidden = true; return; }
    keys.forEach(function (k) {
      var opt = document.createElement('option');
      opt.value = k;
      opt.textContent = subs[k];
      subsectionSel.appendChild(opt);
    });
    subsectionWrap.hidden = false;
  }

  // ── Build filter option lists from the data set ──
  (function buildOptions() {
    var authors = {}, sections = {}, topics = {}, years = {};
    data.forEach(function (a) {
      if (a.author && a.authorName) authors[a.author] = a.authorName;
      if (a.sectionSlug) sections[a.sectionSlug] = a.section;
      (a.tags || []).forEach(function (t) {
        var slug = normSlug(t);
        if (slug) topics[slug] = t;
      });
      var y = new Date(a.date).getUTCFullYear();
      if (!isNaN(y)) years[y] = true;
    });
    function addOptions(sel, map, sortByKey) {
      var entries = Object.keys(map).map(function (k) { return [k, map[k]]; });
      entries.sort(function (a, b) {
        return sortByKey ? (b[0] - a[0]) : a[1].localeCompare(b[1]);
      });
      entries.forEach(function (e) {
        var opt = document.createElement('option');
        opt.value = e[0];
        opt.textContent = e[1] === true ? e[0] : e[1];
        sel.appendChild(opt);
      });
    }
    addOptions(authorSel, authors, false);
    addOptions(sectionSel, sections, false);
    addOptions(topicSel, topics, false);
    addOptions(yearSel, years, true);
  })();

  // ── Read state from URL ──
  function readParams() {
    var p = new URLSearchParams(location.search);
    return {
      author:     p.get('author')     || '',
      section:    (p.get('section')    || '').toLowerCase(),
      subsection: (p.get('subsection') || '').toLowerCase(),
      topic:      (p.get('topic')      || '').toLowerCase(),
      year:       p.get('year')       || '',
      month:      p.get('month')      || ''
    };
  }
  function writeParams(state) {
    var p = new URLSearchParams();
    if (state.author)     p.set('author', state.author);
    if (state.section)    p.set('section', state.section);
    if (state.subsection) p.set('subsection', state.subsection);
    if (state.topic)      p.set('topic', state.topic);
    if (state.year)       p.set('year', state.year);
    if (state.month)      p.set('month', state.month);
    var qs = p.toString();
    history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
  }

  function syncSelects(state) {
    authorSel.value = state.author || '';
    sectionSel.value = state.section || '';
    // Populate subsection dropdown based on current section before we
    // try to set its value so the option actually exists.
    if (state.section) {
      populateSubsections(state.section);
      subsectionSel.value = state.subsection || '';
    } else {
      subsectionWrap.hidden = true;
      subsectionSel.value = '';
    }
    topicSel.value = state.topic || '';
    yearSel.value = state.year || '';
  }

  function activeCount(state) {
    return (state.author ? 1 : 0) + (state.section ? 1 : 0) + (state.subsection ? 1 : 0) + (state.topic ? 1 : 0) + (state.year ? 1 : 0);
  }

  function filterData(state) {
    return data.filter(function (a) {
      if (state.author && a.author !== state.author) return false;
      if (state.section && normSlug(a.section) !== state.section && normSlug(a.sectionSlug) !== state.section) return false;
      if (state.subsection && normSlug(a.subsection) !== state.subsection) return false;
      if (state.topic) {
        var tags = (a.tags || []).map(function (t) { return normSlug(t); });
        if (tags.indexOf(state.topic) === -1) return false;
      }
      if (state.year || state.month) {
        var d2 = new Date(a.date);
        if (state.year  && String(d2.getUTCFullYear()) !== String(state.year))  return false;
        if (state.month && String(d2.getUTCMonth() + 1) !== String(parseInt(state.month, 10))) return false;
      }
      return true;
    }).sort(function (a, b) { return new Date(b.date) - new Date(a.date); });
  }

  function labelForState(state) {
    var label = '';
    if (state.author) {
      var name = (data.find(function (x) { return x.author === state.author; }) || {}).authorName || state.author;
      label = 'Articles by ' + name;
    } else if (state.topic) {
      var t = null;
      data.some(function (a) {
        return (a.tags || []).some(function (tag) {
          if (normSlug(tag) === state.topic) { t = tag; return true; }
        });
      });
      label = 'Topic \u2014 ' + (t || state.topic);
    } else if (state.section) {
      var s = (data.find(function (x) { return normSlug(x.sectionSlug) === state.section; }) || {}).section || state.section;
      label = s + (state.subsection ? ' \u203a ' + state.subsection : '') + ' Timeline';
    }
    return label;
  }

  function render() {
    var state = readParams();
    syncSelects(state);
    var hasAny = activeCount(state) > 0;
    clearBtn.hidden = !hasAny;

    var label = labelForState(state);
    titleEl.textContent = label || 'Archive Timeline';

    // Preserve filters on the showcase button
    var qs = new URLSearchParams(location.search).toString();
    showcaseLink.href = '/archives/showcase/' + (qs ? '?' + qs : '');

    var filtered = filterData(state);
    var n = filtered.length;
    ledeEl.textContent = n + ' ' + (n === 1 ? 'article' : 'articles') + ', most recent first.';
    countEl.textContent = n + ' ' + (n === 1 ? 'article' : 'articles');

    listEl.innerHTML = '';
    if (!n) { emptyEl.hidden = false; return; }
    emptyEl.hidden = true;

    var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var yearCounts = {};
    filtered.forEach(function (a) {
      var y = new Date(a.date).getUTCFullYear();
      yearCounts[y] = (yearCounts[y] || 0) + 1;
    });

    var currentYear = null, currentMonth = null;
    filtered.forEach(function (a) {
      var d = new Date(a.date);
      var y = d.getUTCFullYear();
      var m = d.getUTCMonth();
      if (y !== currentYear) {
        currentYear = y; currentMonth = null;
        var yEl = document.createElement('div');
        yEl.className = 'at-year';
        yEl.innerHTML =
          '<span class="at-year__n">' + y + '</span>' +
          '<span class="at-year__count">' + yearCounts[y] + ' ' + (yearCounts[y] === 1 ? 'article' : 'articles') + '</span>';
        listEl.appendChild(yEl);
      }
      if (m !== currentMonth) {
        currentMonth = m;
        var mEl = document.createElement('p');
        mEl.className = 'at-month';
        mEl.textContent = MONTHS[m];
        listEl.appendChild(mEl);
      }
      var item = document.createElement('a');
      item.className = 'at-item';
      item.href = a.url;
      var dateStr = d.toLocaleDateString(undefined, { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
      var lbtn = (window.__tftAudioBar && window.__tftAudioBar.renderListenButton) ? window.__tftAudioBar.renderListenButton(a.url, a.title) : '';
      item.innerHTML =
        '<span class="at-item__date">' + dateStr + '</span>' +
        '<div class="at-item__body">' +
          (a.section ? '<span class="at-item__section">' + a.section + (a.subsection ? ' \u203a ' + a.subsection : '') + '</span>' : '') +
          '<h2 class="at-item__title">' + a.title + '</h2>' +
          (a.authorName ? '<p class="at-item__meta">' + a.authorName + '</p>' : '') +
          (lbtn ? '<div class="at-item__listen">' + lbtn + '</div>' : '') +
        '</div>';
      // audio-bar.js's delegated click listener calls preventDefault
      // on [data-tft-audio-trigger] clicks, so the wrapping <a>'s
      // default navigation is cancelled when a reader actually
      // clicks the listen pill \u2014 no extra wiring needed here.
      listEl.appendChild(item);
    });
  }

  // ── Wire up filter changes ──
  // Section change resets subsection (dropdown options depend on it).
  function onSectionChange() {
    var state = {
      author: authorSel.value,
      section: sectionSel.value,
      subsection: '',
      topic: topicSel.value,
      year: yearSel.value
    };
    writeParams(state);
    render();
  }
  function onOtherChange() {
    var state = {
      author: authorSel.value,
      section: sectionSel.value,
      subsection: subsectionSel.value,
      topic: topicSel.value,
      year: yearSel.value
    };
    writeParams(state);
    render();
  }
  authorSel.addEventListener('change', onOtherChange);
  sectionSel.addEventListener('change', onSectionChange);
  subsectionSel.addEventListener('change', onOtherChange);
  topicSel.addEventListener('change', onOtherChange);
  yearSel.addEventListener('change', onOtherChange);

  clearBtn.addEventListener('click', function () {
    history.replaceState(null, '', location.pathname);
    render();
  });

  // Initial render reads URL, then responds to further changes.
  render();
})();
</script>
