---
layout: base
title: Ingredients
description: Browse every ingredient that has appeared in a recipe on The Umami Post.
permalink: /ingredients/
eleventyExcludeFromCollections: true
---

<div class="container ingredients-index" style="padding-top: var(--space-10); padding-bottom: var(--space-20); word-spacing: normal;">

  <header class="recipe-hero">
    <span class="recipe-hero__eyebrow">Index</span>
    <h1 class="recipe-hero__title">Ingredients</h1>
    <p class="recipe-hero__dek">Pick an ingredient. See every recipe that uses it.</p>
  </header>

  {% if ingredientIndex.length > 0 %}
  <section style="margin-top: var(--space-8); word-spacing: normal;">
    <p style="font-family: var(--font-body); font-size: var(--text-md); color: var(--color-ink-muted); margin: 0 0 var(--space-6);">{{ ingredientIndex.length }} unique ingredients across {{ collections.recipes.length }} recipes.</p>
    <ul style="list-style:none;padding:0;margin:0;display:grid;gap:var(--space-3);grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));word-spacing:normal;">
      {% for ing in ingredientIndex %}
      <li>
        <a href="/ingredients/{{ ing.slug }}/" style="padding: var(--space-3); font-family: var(--font-ui); font-size: var(--text-sm); display:flex; justify-content:space-between; align-items:baseline; text-decoration:none; color:var(--color-ink); position:relative; word-spacing:normal;" data-rough="frame" data-rough-color="ink">
          <span style="font-weight:600;">{{ ing.name }}</span>
          <span style="color:var(--color-ink-faint);">{{ ing.recipes.length }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% else %}
  <p style="font-family: var(--font-body); font-size: var(--text-md); color: var(--color-ink-faint); margin-top: var(--space-8);">No ingredients indexed yet. <a href="/submit/recipe/" style="color: var(--color-accent);">Submit a recipe</a> to get us started.</p>
  {% endif %}

</div>

<script src="/assets/js/rough-decorations.js?v={{ buildTime }}" defer></script>
