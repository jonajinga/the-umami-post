---
layout: base
title: Ingredients
description: Browse every ingredient that has appeared in a recipe on The Umami Post.
permalink: /ingredients/
eleventyExcludeFromCollections: true
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header class="recipe-hero">
    <span class="recipe-hero__eyebrow">Index</span>
    <h1 class="recipe-hero__title">Ingredients</h1>
    <p class="recipe-hero__dek">Pick an ingredient. See every recipe that uses it.</p>
  </header>

  {% if ingredients.length > 0 %}
  <section style="margin-top: var(--space-8);">
    <p style="font-family: var(--font-body); font-size: var(--text-md); color: var(--color-ink-muted); margin: 0 0 var(--space-6);">{{ ingredients.length }} unique ingredients across {{ collections.recipes.length }} recipes.</p>
    <ul style="list-style:none;padding:0;margin:0;display:grid;gap:var(--space-3);grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
      {% for ing in ingredients %}
      <li style="padding: var(--space-3); border: 1px solid var(--color-rule); font-family: var(--font-ui); font-size: var(--text-sm); display:flex; justify-content:space-between; align-items:baseline;">
        <span style="font-weight:600;">{{ ing.name }}</span>
        <span style="color:var(--color-ink-faint);">{{ ing.recipes.length }}</span>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% else %}
  <p style="font-family: var(--font-body); font-size: var(--text-md); color: var(--color-ink-faint); margin-top: var(--space-8);">No ingredients indexed yet. <a href="/submit/recipe/" style="color: var(--color-accent);">Submit a recipe</a> to get us started.</p>
  {% endif %}

</div>
