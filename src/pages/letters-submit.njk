---
layout: base
title: "Write a Cook's Letter"
description: Respond to something we published -- a recipe, a review, a story. Cook's Letters are selected, edited for clarity, and published in our Cook's Letters section.
permalink: /letters/submit/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header class="page-header">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/cooks-letters/">Cook's Letters</a></li>
          <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Write a Letter</li>
        </ol>
      </nav>
      <h1 class="page-header__title">Write a Cook's Letter</h1>
      <p class="page-header__lede">
        Respond to a recipe, a review, a story -- anything we published. We read every letter and publish a selection.
      </p>
    </header>

    <div class="article-body">

      <p>Letters should respond to a specific recipe, technique, review, or article. Include your name, city, and a brief note on your relevant background -- "home cook", "pastry chef", "restaurant line cook", whatever applies. Letters may be edited for length and clarity. You can also send letters via <a href="/contact/">our contact form</a>.</p>

      <form action="https://api.web3forms.com/submit" method="POST" class="w3f" style="margin-top: var(--space-6);">
        <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
        <input type="hidden" name="subject" value="Letter to the editor, {{ site.title }}">
        <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
        <input type="hidden" name="from_name" value="{{ site.title }} Letters Form">
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="letter-name">Your name <span class="w3f__required">*</span></label>
            <input class="w3f__input" type="text" name="name" id="letter-name" required aria-required="true" autocomplete="name">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="letter-email">Email <span class="w3f__required">*</span></label>
            <input class="w3f__input" type="email" name="email" id="letter-email" required aria-required="true" autocomplete="email">
          </div>
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="letter-city">City</label>
            <input class="w3f__input" type="text" name="city" id="letter-city" placeholder="e.g. Denver, CO">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="letter-background">Background <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="background" id="letter-background" placeholder="e.g. Home cook, line cook, butcher, farmer">
          </div>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="letter-responding">Responding to <span class="w3f__required">*</span></label>
          <span class="w3f__hint" id="letter-responding-hint">Paste the URL or title of the article you are responding to</span>
          <input class="w3f__input" type="text" name="responding_to" id="letter-responding" required aria-required="true" aria-describedby="letter-responding-hint" placeholder="https://theumamipost.com/...">
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="letter-body">Your letter <span class="w3f__required">*</span></label>
          <textarea class="w3f__textarea" name="letter" id="letter-body" rows="10" required aria-required="true" maxlength="5000" data-dictation></textarea>
        </div>

        <button type="submit" class="w3f__submit">Submit Letter</button>
        <p class="w3f__privacy">By submitting, you grant us permission to publish your letter (edited for length and clarity) with your name and city. We will not publish your email address.</p>
      </form>

    </div>
  </div>
</div>
