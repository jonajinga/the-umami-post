---
layout: layouts/base.njk
title: Glossary Showcase
description: Freethought terms, one at a time.
permalink: /glossary/showcase/
eleventyExcludeFromCollections: true
---

{% block head %}
<style>
.gs-showcase { position:fixed;inset:0;background:var(--color-bg);color:var(--color-ink);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:var(--space-8) var(--gutter);z-index:9999;overflow:hidden; }
.gs-showcase__term { font-family:var(--font-headline);font-size:clamp(2rem,5vw,3.5rem);font-weight:700;text-align:center;opacity:0;transform:translateY(16px);transition:opacity 0.6s ease,transform 0.6s ease; }
.gs-showcase__term.is-visible { opacity:1;transform:translateY(0); }
.gs-showcase__def { font-family:var(--font-body);font-size:clamp(1rem,2vw,1.2rem);text-align:center;max-width:36em;line-height:1.65;color:var(--color-ink-muted);margin-top:var(--space-6);opacity:0;transition:opacity 0.6s ease 0.3s; }
.gs-showcase__def.is-visible { opacity:1; }
.gs-showcase__nav { position:fixed;bottom:var(--space-6);left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:var(--space-4);font-family:var(--font-ui);font-size:var(--text-sm);opacity:0.3;transition:opacity 0.3s; }
.gs-showcase__nav:hover { opacity:0.7; }
.gs-showcase__nav button { background:none;border:1px solid currentColor;color:inherit;border-radius:50%;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s; }
.gs-showcase__nav button:hover { background:rgba(128,128,128,0.1); }
.gs-showcase__counter { font-variant-numeric:tabular-nums;white-space:nowrap; }
.gs-showcase__home { position:fixed;top:var(--space-6);left:50%;transform:translateX(-50%);text-decoration:none;color:inherit;opacity:0.25;transition:opacity 0.3s; }
.gs-showcase__home:hover { opacity:0.6; }
.gs-showcase__home-name { font-family:var(--font-headline);font-size:clamp(0.75rem,1.2vw,1rem);letter-spacing:0.12em;text-transform:uppercase; }
.gs-showcase__progress { position:fixed;bottom:0;left:0;height:2px;background:var(--color-accent);opacity:0.3;transition:width linear; }
</style>
{% endblock %}

<div class="gs-showcase" id="gs-showcase">
  <div class="gs-showcase__term" id="gs-term"></div>
  <div class="gs-showcase__def" id="gs-def"></div>
  <a class="gs-showcase__home" href="/glossary/" data-no-spa aria-label="Exit showcase"><span class="gs-showcase__home-name">&larr; Exit showcase</span></a>
  <div class="gs-showcase__nav">
    <button id="gs-prev" type="button" aria-label="Previous"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
    <span class="gs-showcase__counter" id="gs-counter"></span>
    <button id="gs-next" type="button" aria-label="Next"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    <button id="gs-pause" type="button" aria-label="Pause">
      <svg id="gs-pause-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg id="gs-play-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    </button>
  </div>
  <div class="gs-showcase__progress" id="gs-progress"></div>
</div>

{% block scripts %}
<script>
(function () {
  var terms = [
    {% for entry in collections.glossary | sort(false, false, 'data.title') %}
    { term: "{{ entry.data.title | escape }}", def: "{{ entry.data.description | escape }}" }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
  if (!terms.length) return;
  var idx=0,paused=false,INTERVAL=10000,timer=null;
  var elTerm=document.getElementById('gs-term'),elDef=document.getElementById('gs-def'),elCounter=document.getElementById('gs-counter'),elProgress=document.getElementById('gs-progress'),pauseIcon=document.getElementById('gs-pause-icon'),playIcon=document.getElementById('gs-play-icon');
  function show(i){idx=((i%terms.length)+terms.length)%terms.length;var t=terms[idx];elTerm.classList.remove('is-visible');elDef.classList.remove('is-visible');setTimeout(function(){elTerm.textContent=t.term;elDef.textContent=t.def;elCounter.textContent=(idx+1)+' / '+terms.length;elTerm.classList.add('is-visible');elDef.classList.add('is-visible');},400);resetProgress();}
  function resetProgress(){elProgress.style.transition='none';elProgress.style.width='0';if(!paused){clearTimeout(timer);requestAnimationFrame(function(){elProgress.style.transition='width '+(INTERVAL/1000)+'s linear';elProgress.style.width='100%';});timer=setTimeout(function(){show(idx+1);},INTERVAL);}}
  function togglePause(){paused=!paused;pauseIcon.style.display=paused?'none':'';playIcon.style.display=paused?'':'none';if(paused){clearTimeout(timer);elProgress.style.transition='none';elProgress.style.width='0';}else{resetProgress();}}
  document.getElementById('gs-prev').addEventListener('click',function(e){e.stopPropagation();show(idx-1);});
  document.getElementById('gs-next').addEventListener('click',function(e){e.stopPropagation();show(idx+1);});
  document.getElementById('gs-pause').addEventListener('click',function(e){e.stopPropagation();togglePause();});
  document.addEventListener('keydown',function(e){if(e.key==='ArrowLeft')show(idx-1);else if(e.key==='ArrowRight'||e.key===' '){e.preventDefault();show(idx+1);}else if(e.key==='p')togglePause();else if(e.key==='Escape')window.location.href='/glossary/';});
  var w=document.querySelector('.site-wrapper');if(w){document.body.appendChild(document.getElementById('gs-showcase'));w.style.display='none';}document.body.style.overflow='hidden';
  show(0);
})();
</script>
{% endblock %}
