<style>
  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
    font-family: var(--font-ui);
  }
  .sitemap-section {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    align-self: start;
  }
  .sitemap-section summary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-headline);
    font-size: var(--text-md);
    font-weight: 700;
    cursor: pointer;
    user-select: none;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition-fast);
  }
  .sitemap-section summary > .sitemap-title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sitemap-section summary:hover {
    color: var(--color-link);
  }
  .sitemap-section[open] > summary {
    border-bottom-color: var(--color-ink);
  }
  .sitemap-section summary::after {
    content: '+';
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-ink-faint);
    transition: transform var(--transition-fast);
    line-height: 1;
  }
  .sitemap-section[open] > summary::after {
    content: '\2212';
  }
  .sitemap-section summary::-webkit-details-marker,
  .sitemap-section summary::marker {
    display: none;
    content: '';
  }
  .sitemap-section ul {
    list-style: none;
    padding: var(--space-2) var(--space-4) var(--space-4);
    margin: 0;
  }
  .sitemap-section li {
    padding: var(--space-1) 0;
  }
  .sitemap-section a {
    color: var(--color-ink);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }
  .sitemap-section a:hover {
    color: var(--color-link);
    text-decoration: underline;
  }
  .sitemap-section .sub {
    color: var(--color-ink-muted);
    font-size: var(--text-xs);
    padding-left: var(--space-4);
  }
  .sitemap-section .sub:hover {
    color: var(--color-link);
  }
  .sitemap-count {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-ink-faint);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
    text-align: right;
    flex-shrink: 0;
  }
</style>

