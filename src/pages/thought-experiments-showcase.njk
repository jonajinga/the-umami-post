---
layout: layouts/base.njk
title: Thought Experiments Showcase
description: Philosophical thought experiments, one at a time.
permalink: /thought-experiments/showcase/
eleventyExcludeFromCollections: true
---

{% block head %}
<style>
.te-showcase { position:fixed;inset:0;background:var(--color-bg);color:var(--color-ink);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:var(--space-8) var(--gutter);z-index:9999;overflow:hidden; }
.te-showcase__name { font-family:var(--font-headline);font-size:clamp(1.6rem,4vw,2.8rem);font-weight:700;text-align:center;max-width:20em;opacity:0;transform:translateY(16px);transition:opacity 0.6s ease,transform 0.6s ease; }
.te-showcase__name.is-visible { opacity:1;transform:translateY(0); }
.te-showcase__meta { font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-muted);margin-top:var(--space-3);text-align:center;opacity:0;transition:opacity 0.5s ease 0.2s; }
.te-showcase__meta.is-visible { opacity:0.7; }
.te-showcase__desc { font-family:var(--font-body);font-size:clamp(1rem,2vw,1.2rem);text-align:center;max-width:36em;line-height:1.65;color:var(--color-ink-muted);margin-top:var(--space-5);opacity:0;transition:opacity 0.6s ease 0.4s; }
.te-showcase__desc.is-visible { opacity:1; }
.te-showcase__nav { position:fixed;bottom:var(--space-6);left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:var(--space-4);font-family:var(--font-ui);font-size:var(--text-sm);opacity:0.3;transition:opacity 0.3s; }
.te-showcase__nav:hover { opacity:0.7; }
.te-showcase__nav button { background:none;border:1px solid currentColor;color:inherit;border-radius:50%;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s; }
.te-showcase__nav button:hover { background:rgba(128,128,128,0.1); }
.te-showcase__counter { font-variant-numeric:tabular-nums;white-space:nowrap; }
.te-showcase__home { position:fixed;top:var(--space-6);left:50%;transform:translateX(-50%);text-decoration:none;color:inherit;opacity:0.25;transition:opacity 0.3s; }
.te-showcase__home:hover { opacity:0.6; }
.te-showcase__home-name { font-family:var(--font-headline);font-size:clamp(0.75rem,1.2vw,1rem);letter-spacing:0.12em;text-transform:uppercase; }
.te-showcase__progress { position:fixed;bottom:0;left:0;height:2px;background:var(--color-accent);opacity:0.3;transition:width linear; }
</style>
{% endblock %}

<div class="te-showcase" id="te-showcase">
  <div class="te-showcase__name" id="te-name"></div>
  <div class="te-showcase__meta" id="te-meta"></div>
  <div class="te-showcase__desc" id="te-desc"></div>
  <a class="te-showcase__home" href="/thought-experiments/" data-no-spa aria-label="Exit showcase"><span class="te-showcase__home-name">&larr; Exit showcase</span></a>
  <div class="te-showcase__nav">
    <button id="te-prev" type="button" aria-label="Previous"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
    <span class="te-showcase__counter" id="te-counter"></span>
    <button id="te-next" type="button" aria-label="Next"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    <button id="te-pause" type="button" aria-label="Pause">
      <svg id="te-pause-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg id="te-play-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    </button>
  </div>
  <div class="te-showcase__progress" id="te-progress"></div>
</div>

{% block scripts %}
<script>
(function () {
  var experiments = [
    {% for te in collections["thought-experiments"] %}
    { name: "{{ te.data.title | escape }}", philosopher: "{{ te.data.philosopher | escape }}", year: "{{ te.data.yearProposed }}", desc: "{{ te.data.description | escape }}" }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
  if (!experiments.length) return;
  var idx=0,paused=false,INTERVAL=12000,timer=null;
  var elName=document.getElementById('te-name'),elMeta=document.getElementById('te-meta'),elDesc=document.getElementById('te-desc'),elCounter=document.getElementById('te-counter'),elProgress=document.getElementById('te-progress'),pauseIcon=document.getElementById('te-pause-icon'),playIcon=document.getElementById('te-play-icon');
  function show(i){idx=((i%experiments.length)+experiments.length)%experiments.length;var t=experiments[idx];elName.classList.remove('is-visible');elMeta.classList.remove('is-visible');elDesc.classList.remove('is-visible');setTimeout(function(){elName.textContent=t.name;elMeta.textContent=(t.philosopher||'')+(t.year?' \u2014 '+t.year:'');elDesc.textContent=t.desc;elCounter.textContent=(idx+1)+' / '+experiments.length;elName.classList.add('is-visible');elMeta.classList.add('is-visible');elDesc.classList.add('is-visible');},400);resetProgress();}
  function resetProgress(){elProgress.style.transition='none';elProgress.style.width='0';if(!paused){clearTimeout(timer);requestAnimationFrame(function(){elProgress.style.transition='width '+(INTERVAL/1000)+'s linear';elProgress.style.width='100%';});timer=setTimeout(function(){show(idx+1);},INTERVAL);}}
  function togglePause(){paused=!paused;pauseIcon.style.display=paused?'none':'';playIcon.style.display=paused?'':'none';if(paused){clearTimeout(timer);elProgress.style.transition='none';elProgress.style.width='0';}else{resetProgress();}}
  document.getElementById('te-prev').addEventListener('click',function(e){e.stopPropagation();show(idx-1);});
  document.getElementById('te-next').addEventListener('click',function(e){e.stopPropagation();show(idx+1);});
  document.getElementById('te-pause').addEventListener('click',function(e){e.stopPropagation();togglePause();});
  document.addEventListener('keydown',function(e){if(e.key==='ArrowLeft')show(idx-1);else if(e.key==='ArrowRight'||e.key===' '){e.preventDefault();show(idx+1);}else if(e.key==='p')togglePause();else if(e.key==='Escape')window.location.href='/thought-experiments/';});
  var w=document.querySelector('.site-wrapper');if(w){document.body.appendChild(document.getElementById('te-showcase'));w.style.display='none';}document.body.style.overflow='hidden';
  show(0);
})();
</script>
{% endblock %}
