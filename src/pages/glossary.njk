---
layout: base
title: Cooking Glossary
description: The vocabulary of the kitchen -- techniques, ingredients, and the words cooks use to describe both. Searchable, alphabetised, linked from every recipe.
permalink: /glossary/
eleventyExcludeFromCollections: true
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header class="recipe-hero" style="margin-bottom: var(--space-6);">
    <span class="recipe-hero__eyebrow">Reference</span>
    <h1 class="recipe-hero__title">Cooking Glossary</h1>
    <p class="recipe-hero__dek">The vocabulary of the kitchen. Click any term for its full definition.</p>
  </header>

  {% set terms = collections.glossary | sort(false, false, "data.title") %}
  {% if terms.length > 0 %}

  <div style="display:flex;align-items:center;gap:var(--space-3);margin:0 0 var(--space-6);">
    <input type="search" id="glossary-search" placeholder="Search the glossary" aria-label="Search glossary" style="flex:1;max-width:24rem;font-family:var(--font-ui);font-size:var(--text-base);padding:10px 14px;border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
    <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">{{ terms.length }} terms</span>
  </div>

  {# A-Z rail #}
  <nav aria-label="Jump to letter" style="display:flex;flex-wrap:wrap;gap:4px;margin:0 0 var(--space-8);padding:var(--space-3) 0;border-top:1px solid var(--color-rule);border-bottom:1px solid var(--color-rule);">
    {% set letters = [] %}
    {% for t in terms %}
      {% set first = (t.data.title | first) | upper %}
      {% if first not in letters %}{% set letters = letters.concat([first]) %}{% endif %}
    {% endfor %}
    {% for L in letters | sort %}
    <a href="#letter-{{ L }}" style="display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 6px;font-family:var(--font-ui);font-size:var(--text-sm);font-weight:600;color:var(--color-ink);text-decoration:none;border:1px solid var(--color-rule);">{{ L }}</a>
    {% endfor %}
  </nav>

  {# Term list grouped by letter #}
  <div id="glossary-list">
    {% set lastLetter = "" %}
    {% for t in terms %}
      {% set first = (t.data.title | first) | upper %}
      {% if first != lastLetter %}
        {% if not loop.first %}</section>{% endif %}
        <section id="letter-{{ first }}" style="margin-top:var(--space-8);scroll-margin-top:6rem;">
        <h2 style="font-family:var(--font-masthead);font-size:var(--text-2xl);margin:0 0 var(--space-4);padding-bottom:var(--space-2);border-bottom:2px solid var(--color-accent);">{{ first }}</h2>
        {% set lastLetter = first %}
      {% endif %}
      <article class="glossary-term-row" data-term="{{ t.data.title | lower }}" data-desc="{{ t.data.description | lower }}" style="padding:var(--space-4) 0;border-bottom:1px solid var(--color-rule);">
        <a href="{{ t.url }}" style="font-family:var(--font-headline);font-size:var(--text-md);font-weight:700;color:var(--color-ink);text-decoration:none;">{{ t.data.title }}</a>
        <p style="font-family:var(--font-body);font-size:var(--text-base);line-height:var(--leading-relaxed);color:var(--color-ink-muted);margin:6px 0 0;">{{ t.data.description }}</p>
      </article>
      {% if loop.last %}</section>{% endif %}
    {% endfor %}
  </div>

  <p id="glossary-empty" style="display:none;font-family:var(--font-body);font-style:italic;color:var(--color-ink-faint);text-align:center;padding:var(--space-8);">No terms match your search.</p>

  {% else %}
  <p style="font-family: var(--font-body); font-size: var(--text-md); color: var(--color-ink-faint);">No glossary terms yet.</p>
  {% endif %}

</div>

<script>
(function () {
  var input = document.getElementById('glossary-search');
  var rows = Array.prototype.slice.call(document.querySelectorAll('.glossary-term-row'));
  var sections = Array.prototype.slice.call(document.querySelectorAll('#glossary-list section'));
  var empty = document.getElementById('glossary-empty');
  if (!input) return;
  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var visible = 0;
    rows.forEach(function (r) {
      var match = !q || (r.dataset.term || '').indexOf(q) !== -1 || (r.dataset.desc || '').indexOf(q) !== -1;
      r.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    sections.forEach(function (s) {
      var anyVisible = Array.prototype.some.call(s.querySelectorAll('.glossary-term-row'), function (r) { return r.style.display !== 'none'; });
      s.style.display = anyVisible ? '' : 'none';
    });
    empty.style.display = visible === 0 ? 'block' : 'none';
  });
})();
</script>
