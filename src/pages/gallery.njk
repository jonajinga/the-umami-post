---
layout: base
title: Gallery
description: A collection of natural world photography, celebrating the beauty that exists without design.
permalink: /gallery/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/projects/">Projects</a></li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Gallery</li>
    </ol>
  </nav>

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8); text-align: center;">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Gallery</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 40ch; margin-inline: auto;">
      The natural world needs no designer to be beautiful.
    </p>
    <div style="display:flex;justify-content:center;margin-top:var(--space-4);">
      <p style="font-family: var(--font-ui); font-size: var(--text-sm); margin: 0;">
        Have a photo to share? <a href="/gallery/submit/" style="color: var(--color-link); font-weight: 600;">Submit it</a>
      </p>
    </div>
  </header>

  {% if gallery.length == 0 %}
  <div style="text-align:center;padding:var(--space-10) 0;">
    <p style="font-family:var(--font-ui);font-size:var(--text-md);color:var(--color-ink-faint);font-style:italic;">The gallery is being curated. Check back soon, or <a href="/gallery/submit/" style="color:var(--color-link);">submit a photo</a> to help us get started.</p>
  </div>
  {% else %}

  {# Filters #}
  <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);flex-wrap:wrap;align-items:center;">
    <input type="search" id="gallery-search" placeholder="Search images..." aria-label="Search gallery" style="flex:1;min-width:200px;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);border-radius:var(--radius-sm);">
    <select id="gallery-category" aria-label="Filter by category" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All categories</option>
      {% set cats = [] %}
      {% for img in gallery %}{% if img.category and img.category not in cats %}{% set cats = cats.concat([img.category]) %}{% endif %}{% endfor %}
      {% for cat in cats %}<option value="{{ cat }}">{{ cat }}</option>{% endfor %}
    </select>
    <select id="gallery-license" aria-label="Filter by license" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All licenses</option>
      {% set lics = [] %}
      {% for img in gallery %}{% if img.license and img.license not in lics %}{% set lics = lics.concat([img.license]) %}{% endif %}{% endfor %}
      {% for lic in lics %}<option value="{{ lic }}">{{ lic }}</option>{% endfor %}
    </select>
    <select id="gallery-source" aria-label="Filter by source" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
      <option value="">All sources</option>
      {% set srcs = [] %}
      {% for img in gallery %}{% if img.credit and img.credit not in srcs %}{% set srcs = srcs.concat([img.credit]) %}{% endif %}{% endfor %}
      {% for src in srcs %}<option value="{{ src }}">{{ src }}</option>{% endfor %}
    </select>
    <span id="gallery-count" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">{{ gallery.length }} image{{ "s" if gallery.length != 1 }}</span>
  </div>

  <div class="gallery-grid">
    {% for img in gallery %}
    <figure class="gallery-card" data-idx="{{ loop.index0 }}" data-alt="{{ img.alt | lower }}" data-category="{{ img.category or '' }}" data-license="{{ img.license or '' }}" data-credit="{{ img.credit or '' }}" onclick="openLightbox({{ loop.index0 }})">
      <div class="gallery-card__img-wrap">
        <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy" class="gallery-card__img" width="800" height="260">
        <div class="gallery-card__overlay">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </div>
      </div>
      <figcaption class="gallery-card__caption">
        {% if img.category %}<span class="gallery-card__tag">{{ img.category }}</span>{% endif %}
        <p class="gallery-card__title">{{ img.alt }}</p>
        <div class="gallery-card__meta">
          {% if img.credit %}<span>{{ img.credit }}</span>{% endif %}
          {% if img.license %}<span class="gallery-card__license">{{ img.license }}</span>{% endif %}
        </div>
      </figcaption>
    </figure>
    {% endfor %}
  </div>

  {# Lightbox #}
  <div id="gallery-lightbox" class="gallery-lightbox" hidden>
    <div class="gallery-lightbox__backdrop" onclick="closeLightbox()"></div>
    <div class="gallery-lightbox__content">
      <button class="gallery-lightbox__close" onclick="closeLightbox()" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="gallery-lightbox__img-wrap">
        <img id="lb-img" src="" alt="" class="gallery-lightbox__img">
      </div>
      <div class="gallery-lightbox__info">
        <p id="lb-alt" class="gallery-lightbox__title"></p>
        <p id="lb-credit" class="gallery-lightbox__credit"></p>
        <div class="gallery-lightbox__actions">
          <button class="btn" onclick="zoomIn()" type="button">Zoom in</button>
          <button class="btn" onclick="zoomOut()" type="button">Zoom out</button>
          <button class="btn" onclick="resetZoom()" type="button">Reset</button>
          <a id="lb-download" href="" download class="btn">Download</a>
        </div>
      </div>
      <div class="gallery-lightbox__nav">
        <button onclick="navLightbox(-1)" type="button" aria-label="Previous">&larr;</button>
        <span id="lb-counter"></span>
        <button onclick="navLightbox(1)" type="button" aria-label="Next">&rarr;</button>
      </div>
    </div>
  </div>
  {% endif %}

</div>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: var(--space-6);
}
@media (max-width: 480px) {
  /* Phones: drop the 300 px floor so the grid collapses cleanly to a
   * single full-width column at 360 viewport. */
  .gallery-grid { grid-template-columns: 1fr; gap: var(--space-4); }
}

/* Phone-friendly filter row: at <=640 the search input takes a full
 * row of its own and the three selects + count flow on a second row.
 * Without this the search's inline min-width: 200 forced an overflow
 * with the three selects beside it on a 360 viewport. */
@media (max-width: 640px) {
  #gallery-search {
    min-width: 0 !important;
    flex: 1 1 100% !important;
  }
  #gallery-category,
  #gallery-license,
  #gallery-source {
    flex: 1 1 calc(50% - var(--space-3)) !important;
    min-width: 0 !important;
  }
}

.gallery-card {
  margin: 0;
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  cursor: pointer;
  transition: box-shadow 0.25s, transform 0.25s;
  overflow: hidden;
}

.gallery-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,0.1);
  transform: translateY(-3px);
}

.gallery-card__img-wrap {
  position: relative;
  overflow: hidden;
}

.gallery-card__img {
  width: 100%;
  height: 260px;
  object-fit: contain;
  display: block;
  background: #111;
  transition: transform 0.3s ease;
}

.gallery-card:hover .gallery-card__img {
  transform: scale(1.03);
}

.gallery-card__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  opacity: 0;
  transition: opacity 0.25s;
}

.gallery-card:hover .gallery-card__overlay { opacity: 1; }

.gallery-card__caption {
  padding: var(--space-6) var(--space-8);
}

.gallery-card__tag {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-accent);
  margin-bottom: var(--space-3);
}

.gallery-card__title {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  line-height: 1.6;
  margin: 0 0 var(--space-4);
}

.gallery-card__meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-faint);
  padding-top: var(--space-3);
  border-top: 1px solid var(--color-rule);
}

.gallery-card__license {
  padding: 1px 6px;
  border: 1px solid var(--color-rule);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Lightbox */
.gallery-lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-lightbox[hidden] {
  display: none !important;
}

.gallery-lightbox__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.85);
}

.gallery-lightbox__content {
  position: relative;
  max-width: 90vw;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.gallery-lightbox__close {
  position: fixed;
  top: var(--space-4);
  right: var(--space-4);
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  opacity: 0.7;
  transition: opacity 0.15s;
  z-index: 10;
  padding: var(--space-2);
}

.gallery-lightbox__close:hover { opacity: 1; }

.gallery-lightbox__img-wrap {
  overflow: auto;
  max-width: 85vw;
  max-height: 65vh;
  cursor: grab;
}

.gallery-lightbox__img {
  display: block;
  max-width: 100%;
  max-height: 65vh;
  transition: transform 0.2s ease;
  transform-origin: center center;
}

.gallery-lightbox__info {
  padding: var(--space-4) 0;
  text-align: center;
  max-width: 600px;
}

.gallery-lightbox__title {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: #e0e0e0;
  line-height: 1.5;
  margin: 0 0 var(--space-2);
}

.gallery-lightbox__credit {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: #888;
  margin: 0 0 var(--space-3);
}

.gallery-lightbox__actions {
  display: flex;
  gap: var(--space-2);
  justify-content: center;
  flex-wrap: wrap;
}

.gallery-lightbox__actions .btn {
  font-size: var(--text-xs);
  padding: var(--space-1) var(--space-3);
  color: #fff;
  border-color: #555;
}

.gallery-lightbox__actions .btn:hover {
  background: #fff;
  color: #111;
}

.gallery-lightbox__nav {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-3);
}

.gallery-lightbox__nav button {
  background: none;
  border: 1px solid #555;
  color: #fff;
  width: 36px;
  height: 36px;
  cursor: pointer;
  font-size: var(--text-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-lightbox__nav button:hover { border-color: #fff; }

.gallery-lightbox__nav span {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: #888;
}
</style>

<script>
(function () {
  var images = {{ gallery | dump | safe }};
  var currentIdx = 0;
  var zoomLevel = 1;

  var lb = document.getElementById('gallery-lightbox');
  var lbImg = document.getElementById('lb-img');
  var lbAlt = document.getElementById('lb-alt');
  var lbCredit = document.getElementById('lb-credit');
  var lbDownload = document.getElementById('lb-download');
  var lbCounter = document.getElementById('lb-counter');

  window.openLightbox = function (idx) {
    currentIdx = idx;
    zoomLevel = 1;
    showImage();
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  };

  window.closeLightbox = function () {
    lb.hidden = true;
    document.body.style.overflow = '';
  };

  window.navLightbox = function (dir) {
    currentIdx = ((currentIdx + dir) % images.length + images.length) % images.length;
    zoomLevel = 1;
    showImage();
  };

  window.zoomIn = function () {
    zoomLevel = Math.min(zoomLevel + 0.5, 5);
    lbImg.style.transform = 'scale(' + zoomLevel + ')';
    lbImg.style.maxWidth = 'none';
    lbImg.style.maxHeight = 'none';
  };

  window.zoomOut = function () {
    zoomLevel = Math.max(zoomLevel - 0.5, 0.5);
    lbImg.style.transform = 'scale(' + zoomLevel + ')';
  };

  window.resetZoom = function () {
    zoomLevel = 1;
    lbImg.style.transform = 'scale(1)';
    lbImg.style.maxWidth = '100%';
    lbImg.style.maxHeight = '65vh';
  };

  function showImage() {
    var img = images[currentIdx];
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbImg.style.transform = 'scale(1)';
    lbImg.style.maxWidth = '100%';
    lbImg.style.maxHeight = '65vh';
    lbAlt.textContent = img.alt;
    lbCredit.textContent = (img.credit || '') + (img.license ? ' · ' + img.license : '');
    lbDownload.href = img.src;
    lbCounter.textContent = (currentIdx + 1) + ' / ' + images.length;
  }

  document.addEventListener('keydown', function (e) {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowLeft') navLightbox(-1);
    else if (e.key === 'ArrowRight') navLightbox(1);
    else if (e.key === '+' || e.key === '=') zoomIn();
    else if (e.key === '-') zoomOut();
  });

  // Filters
  var searchInput = document.getElementById('gallery-search');
  var catFilter = document.getElementById('gallery-category');
  var licFilter = document.getElementById('gallery-license');
  var srcFilter = document.getElementById('gallery-source');
  var countEl = document.getElementById('gallery-count');
  var cards = document.querySelectorAll('.gallery-card');

  function filterGallery() {
    var q = (searchInput.value || '').toLowerCase().trim();
    var cat = catFilter.value;
    var lic = licFilter.value;
    var src = srcFilter.value;
    var visible = 0;
    cards.forEach(function (card) {
      var show = true;
      if (q && card.dataset.alt.indexOf(q) === -1) show = false;
      if (cat && card.dataset.category !== cat) show = false;
      if (lic && card.dataset.license !== lic) show = false;
      if (src && card.dataset.credit !== src) show = false;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = visible + ' image' + (visible !== 1 ? 's' : '');
  }

  if (searchInput) searchInput.addEventListener('input', filterGallery);
  if (catFilter) catFilter.addEventListener('change', filterGallery);
  if (licFilter) licFilter.addEventListener('change', filterGallery);
  if (srcFilter) srcFilter.addEventListener('change', filterGallery);
})();
</script>
