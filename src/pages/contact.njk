---
layout: base
title: Contact Us
description: How to reach The Freethinking Times, general inquiries, corrections, submissions, and tips.
permalink: /contact/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header class="page-header">
      <h1 class="page-header__title">Contact Us</h1>
      <p class="page-header__lede">
        We read every message. Expect a response within a few business days if one is needed.
      </p>
    </header>

    <div class="article-body">

      {# ── Contact Form ── #}
      <form action="https://api.web3forms.com/submit" method="POST" class="w3f">
        <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
        <input type="hidden" name="subject" value="Contact form, {{ site.title }}">
        <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
        <input type="hidden" name="from_name" value="{{ site.title }} Contact Form">
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="contact-name">Name <span class="w3f__required">*</span></label>
            <input class="w3f__input" type="text" name="name" id="contact-name" required aria-required="true" autocomplete="name">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="contact-email">Email <span class="w3f__required">*</span></label>
            <input class="w3f__input" type="email" name="email" id="contact-email" required aria-required="true" autocomplete="email">
          </div>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="contact-subject">Subject</label>
          <select class="w3f__select" name="subject_line" id="contact-subject">
            {% for subject in site.contactSubjects %}
            <option value="{{ subject }}">{{ subject }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="contact-message">Message <span class="w3f__required">*</span></label>
          <textarea class="w3f__textarea" name="message" id="contact-message" rows="6" required aria-required="true" maxlength="5000"></textarea>
        </div>

        <div class="w3f__status" role="status" aria-live="polite" aria-atomic="true"></div>
        <button type="submit" class="w3f__submit">Send Message</button>
        <p class="w3f__privacy">Delivered to our editorial inbox via Web3Forms. We never sell or share submissions. See our <a href="/privacy/#contact-forms">privacy policy</a> for what Web3Forms does with form data and how long we retain messages.</p>
      </form>

      {# ── Other Ways to Reach Us ── #}
      <div style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid var(--color-rule);">
        <h2>Have something specific?</h2>
        <p>We have dedicated forms for common requests:</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-4);margin-top:var(--space-4);">

        <a href="/submit/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-opinion);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Submit a Piece</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Pitch an article, essay, or letter to the editor.</span>
        </a>

        <a href="/corrections/report/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-accent);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Report a Correction</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Found an error? Help us get it right.</span>
        </a>

        <a href="/tips/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-history);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Tip Line</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Share a news tip. Anonymous submissions welcome.</span>
        </a>

        <a href="/feedback/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-science);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Feedback</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Report a bug, suggest a feature, or say something kind.</span>
        </a>

        <a href="/events/submit/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-arts-culture);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Submit an Event</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Add a conference, meetup, or observance to our calendar.</span>
        </a>

        <a href="/letters/submit/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-letters);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Write a Letter</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Respond to an article. Published letters include name and city.</span>
        </a>

        <a href="/quotes/submit/" style="border:1px solid var(--color-rule);border-top:3px solid var(--color-bookshelf);padding:var(--space-6);text-decoration:none;display:flex;flex-direction:column;gap:var(--space-2);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Submit a Quote</strong>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);">Suggest a freethought quote for our curated collection.</span>
        </a>

      </div>

      {# ── Follow ── #}
      <div style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid var(--color-rule);">
        <h2>Follow</h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-4);margin-top:var(--space-4);">

        <div style="border:1px solid var(--color-rule);padding:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">Newsletter</strong>
          <p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);margin:0;">New articles delivered to your inbox. Free, no tracking, unsubscribe anytime.</p>
          <a href="/newsletter/" style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:600;color:var(--color-link);text-decoration:none;">Subscribe &rarr;</a>
        </div>

        <div style="border:1px solid var(--color-rule);padding:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);">
          <strong style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink);">RSS Feed</strong>
          <p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);margin:0;">Follow in your preferred feed reader. All sections, full content.</p>
          <a href="/feed.xml" style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:600;color:var(--color-link);text-decoration:none;">{{ site.url }}/feed.xml &rarr;</a>
        </div>

      </div>

      {# ── Direct Email ── #}
      <div style="margin-top: var(--space-10); font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-ink-faint);">
        Use the form above, it goes straight to our editorial inbox
      </div>

    </div>
  </div>
</div>
