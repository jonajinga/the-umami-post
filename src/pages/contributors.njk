---
layout: layouts/base.njk
title: Contributors
description: The writers, editors, and reporters of The Freethinking Times. Filter by role, beat, or activity; sort by output, words, or recency.
permalink: /contributors/
---

{% set roster = authors | contributorsRoster(collections.allContent) %}
{% set totalContributors = roster | length %}
{% set totalArticles = 0 %}
{% set totalWords = 0 %}
{% set activeCount = 0 %}
{% for r in roster %}
  {% set totalArticles = totalArticles + r.articles %}
  {% set totalWords    = totalWords + r.words %}
  {% if r.isActive %}{% set activeCount = activeCount + 1 %}{% endif %}
{% endfor %}

<div class="container contributors-page">

  <header class="contributors-page__header">
    <p class="contributors-page__kicker">Masthead</p>
    <h1 class="contributors-page__title">Contributors</h1>
    <p class="contributors-page__lede">
      The writers, editors, and reporters of {{ site.title }}. Filter by role, beat, or activity. Click any name for the full archive.
    </p>
  </header>

  {# ── Stats overview strip ── #}
  <ul class="contributors-stats" role="list">
    <li class="contributors-stat">
      <p class="contributors-stat__label">Contributors</p>
      <p class="contributors-stat__value">{{ totalContributors }}</p>
    </li>
    <li class="contributors-stat">
      <p class="contributors-stat__label">Active in 90d</p>
      <p class="contributors-stat__value">{{ activeCount }}</p>
    </li>
    <li class="contributors-stat">
      <p class="contributors-stat__label">Total articles</p>
      <p class="contributors-stat__value">{{ totalArticles }}</p>
    </li>
    <li class="contributors-stat">
      <p class="contributors-stat__label">Words published</p>
      <p class="contributors-stat__value">{{ (totalWords / 1000) | round(0) }}k</p>
    </li>
  </ul>

  {# ── Toolbar: search + sort + filter chips ── #}
  <div class="contributors-toolbar" role="toolbar" aria-label="Contributor filters">
    <input type="search" id="contrib-search" class="contributors-toolbar__input" placeholder="Search by name, role, location, or beat…" aria-label="Search contributors">
    <select id="contrib-sort" class="contributors-toolbar__select" aria-label="Sort contributors">
      <option value="recent">Sort: Most recent</option>
      <option value="articles">Sort: Most articles</option>
      <option value="words">Sort: Most words</option>
      <option value="alpha">Sort: A &rarr; Z</option>
    </select>
    <div class="contributors-chips" role="tablist" aria-label="Activity filter">
      <button type="button" class="contributors-chip is-on"      data-filter="all"     aria-pressed="true" role="tab">All</button>
      <button type="button" class="contributors-chip"            data-filter="active"  aria-pressed="false" role="tab">Active (90d)</button>
      <button type="button" class="contributors-chip"            data-filter="dormant" aria-pressed="false" role="tab">Dormant</button>
      <button type="button" class="contributors-chip"            data-filter="editors" aria-pressed="false" role="tab">Editors</button>
    </div>
  </div>

  <div class="contributors-grid" id="contrib-grid">
    {% for r in roster %}
    {% set isEditor = (r.role | lower).indexOf("editor") != -1 %}
    <article class="author-card{% if r.isActive %} author-card--active{% else %} author-card--dormant{% endif %}{% if isEditor %} author-card--editor{% endif %}"
             data-search="{{ ((r.name or '') + ' ' + (r.role or '') + ' ' + (r.location or '') + ' ' + (r.beat | join(' '))) | lower }}"
             data-articles="{{ r.articles or 0 }}"
             data-words="{{ r.words or 0 }}"
             data-last="{{ r.lastDate or 0 }}"
             data-name="{{ (r.name or '') | lower }}"
             data-active="{{ 'true' if r.isActive else 'false' }}"
             data-editor="{{ 'true' if isEditor else 'false' }}">
      <header class="author-card__head">
        <div class="author-card__avatar">
          <div class="author-card__initials" aria-hidden="true">{{ r.name | initials }}</div>
          {% if r.photo %}
            {% set photoSrc = r.photo | replace("src", "") %}
            <img src="{{ photoSrc }}" alt="{{ r.name }}"
                 class="author-card__photo" width="101" height="101" loading="lazy" decoding="async"
                 onerror="this.style.opacity=0">
          {% endif %}
        </div>
        <div class="author-card__head-meta">
          {% if r.isActive %}
          <span class="author-card__badge author-card__badge--active" title="Published in the last 90 days">Active</span>
          {% else %}
          <span class="author-card__badge author-card__badge--dormant" title="No publication in the last 90 days">Dormant</span>
          {% endif %}
          {% if r.role %}<p class="author-card__role">{{ r.role }}</p>{% endif %}
          {% if r.location %}<p class="author-card__loc">{{ r.location }}</p>{% endif %}
        </div>
      </header>

      <h2 class="author-card__name"><a href="/author/{{ r.slug }}/"
        {% if r.bio %}data-tippy-content="{{ r.bio }}" data-tippy-theme="author-bio"{% endif %}>{{ r.name }}</a></h2>

      {% if r.bio %}
      <p class="author-card__bio">{{ r.bio }}</p>
      {% endif %}

      {% if r.beat.length %}
      <ul class="author-card__beat" aria-label="Recurring topics covered">
        {% for tag in r.beat %}
        <li><a href="/topics/{{ tag | slugify }}/" class="author-card__beat-tag">{{ tag }}</a></li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if r.recentArticle %}
      <div class="author-card__latest">
        <p class="author-card__latest-label">Most recent</p>
        <a class="author-card__latest-link" href="{{ r.recentArticle.url }}">
          {% if r.recentArticle.section %}<span class="author-card__latest-section">{{ r.recentArticle.section }}</span>{% endif %}
          <span class="author-card__latest-title">{{ r.recentArticle.title }}</span>
        </a>
      </div>
      {% endif %}

      <div class="author-card__socials-row">
        {% set social = r.social %}
        {% include "partials/social-icons.njk" %}
        {% if r.articles %}
        <span class="author-card__socials-divider" aria-hidden="true"></span>
        {% set viewFilter = "author=" + r.slug %}
        {% set viewsSize = "sm" %}
        {% set rssHref = "/feeds/" + r.slug + ".xml" %}
        {% set rssFeed = "author-" + r.slug %}
        {% set rssLabel = r.name %}
        {% include "partials/archive-views-buttons.njk" %}
        {% endif %}
      </div>

      {% if r.articles or r.drafts %}
      <div class="author-card__stats">
        <span class="author-card__stat"><strong>{{ r.articles }}</strong> {{ "article" if r.articles == 1 else "articles" }}</span>
        {% if r.drafts %}<span class="author-card__stat author-card__stat--soft"><strong>{{ r.drafts }}</strong> in flight</span>{% endif %}
        {% if r.words %}<span class="author-card__stat"><strong>{{ (r.words / 1000) | round(1) }}k</strong> words</span>{% endif %}
        {% if r.avgWords %}<span class="author-card__stat">~{{ r.avgWords }} avg</span>{% endif %}
        {% if r.lastDateIso %}<span class="author-card__stat">last <strong>{{ r.lastDateIso | readableDate }}</strong></span>{% endif %}
      </div>
      {% endif %}

      <div class="author-card__footer">
        {% set tipAuthor = r %}
        {% set tipHidePublication = true %}
        {% include "partials/tip-buttons.njk" %}
        <a class="author-card__link" href="/author/{{ r.slug }}/">View archive &rarr;</a>
      </div>
    </article>
    {% endfor %}
  </div>

  <p id="contrib-empty" class="contributors-empty" hidden>No contributors match the current filter.</p>

</div>

<style>
.contributors-page { padding-top: var(--space-10); padding-bottom: var(--space-20); }
.contributors-page__header {
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-6);
  border-bottom: 3px solid var(--color-ink);
}
.contributors-page__kicker {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin: 0 0 var(--space-2);
}
.contributors-page__title {
  font-family: var(--font-masthead);
  font-size: var(--text-3xl);
  margin: 0 0 var(--space-3);
}
.contributors-page__lede {
  font-family: var(--font-body);
  font-size: var(--text-md);
  color: var(--color-ink-muted);
  font-style: italic;
  margin: 0;
  max-width: 60ch;
}

.contributors-stats {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: var(--space-3);
  padding: 0;
  margin: 0 0 var(--space-6);
}
.contributors-stat {
  background: var(--color-bg-alt);
  border: 1px solid var(--color-rule);
  border-left: 3px solid var(--color-ink);
  padding: var(--space-3) var(--space-4);
}
.contributors-stat__label {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-ink-faint);
  margin: 0 0 var(--space-1);
}
.contributors-stat__value {
  font-family: var(--font-masthead);
  font-size: clamp(1.4rem, 3vw, 2rem);
  line-height: 1;
  margin: 0;
  font-variant-numeric: tabular-nums;
}

.contributors-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  align-items: center;
  margin-bottom: var(--space-6);
}
.contributors-toolbar__input,
.contributors-toolbar__select {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink);
}
.contributors-toolbar__input { flex: 1 1 240px; min-width: 200px; }
@media (max-width: 640px) {
  /* Phones: drop the 200 px floor so the search input shrinks with
   * the toolbar instead of forcing horizontal overflow. */
  .contributors-toolbar__input { min-width: 0; flex: 1 1 100%; }
}
.contributors-chips {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}
.contributors-chip {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink-muted);
  cursor: pointer;
  transition: background-color 120ms, color 120ms, border-color 120ms;
}
.contributors-chip:hover { color: var(--color-ink); border-color: var(--color-ink); }
.contributors-chip.is-on {
  background: var(--color-ink);
  color: var(--color-bg);
  border-color: var(--color-ink);
}

/* Card additions on top of existing .author-card styles */
.author-card__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  width: 100%;
}
.author-card__head-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  width: 100%;
}
.author-card__badge {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 2px;
}
.author-card__badge--active {
  background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
}
.author-card__badge--dormant {
  background: var(--color-bg);
  color: var(--color-ink-faint);
  border: 1px solid var(--color-rule);
}
.author-card__loc {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  color: var(--color-ink-faint);
  margin: 0;
}

.author-card__beat {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: 0;
  margin: 0 0 var(--space-3);
  justify-content: center;
}
.author-card__beat-tag {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.04em;
  color: var(--color-ink-muted);
  text-decoration: none;
  padding: 2px 8px;
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  transition: background-color 120ms, color 120ms;
}
.author-card__beat-tag:hover {
  background: var(--color-accent);
  color: #fff;
  border-color: var(--color-accent);
}

.author-card__latest {
  width: 100%;
  padding: var(--space-3);
  background: var(--color-bg);
  border: 1px solid var(--color-rule);
  margin-bottom: var(--space-3);
  text-align: left;
}
.author-card__latest-label {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-ink-faint);
  margin: 0 0 4px;
}
.author-card__latest-link {
  display: block;
  text-decoration: none;
  color: var(--color-ink);
}
.author-card__latest-link:hover .author-card__latest-title { color: var(--color-accent); }
.author-card__latest-section {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-accent);
  margin-bottom: 2px;
}
.author-card__latest-title {
  font-family: var(--font-headline);
  font-size: var(--text-sm);
  font-weight: 600;
  line-height: 1.3;
  display: block;
}
.author-card__stat--soft strong { color: var(--color-accent); }

.contributors-empty {
  text-align: center;
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-ink-faint);
  font-style: italic;
  padding: var(--space-10);
}

/* Mobile collapse — already covered by existing .author-card mobile
   media queries; just shrink the new bits. Snapped 700 → 768 to
   match the canonical 7-band breakpoint scale. */
@media (max-width: 768px) {
  .author-card__beat { gap: 3px; }
  .author-card__beat-tag { font-size: 0.6rem; padding: 1px 6px; }
  .author-card__latest { padding: var(--space-2) var(--space-3); margin-bottom: var(--space-2); }
}
</style>

<script>
(function () {
  var grid    = document.getElementById('contrib-grid');
  var search  = document.getElementById('contrib-search');
  var sortSel = document.getElementById('contrib-sort');
  var empty   = document.getElementById('contrib-empty');
  var chips   = document.querySelectorAll('.contributors-chip');
  if (!grid) return;
  var cards = Array.prototype.slice.call(grid.querySelectorAll('.author-card'));
  var filter = 'all';

  function applyFilter() {
    var q = (search.value || '').toLowerCase().trim();
    var visible = 0;
    cards.forEach(function (c) {
      var matchQ = !q || (c.dataset.search || '').indexOf(q) !== -1;
      var matchF = (
        filter === 'all'    ||
        (filter === 'active'  && c.dataset.active === 'true') ||
        (filter === 'dormant' && c.dataset.active === 'false') ||
        (filter === 'editors' && c.dataset.editor === 'true')
      );
      var ok = matchQ && matchF;
      c.style.display = ok ? '' : 'none';
      if (ok) visible++;
    });
    if (empty) empty.hidden = visible !== 0;
  }

  function applySort() {
    var by = sortSel.value;
    var sorted = cards.slice().sort(function (a, b) {
      if (by === 'articles') return Number(b.dataset.articles) - Number(a.dataset.articles);
      if (by === 'words')    return Number(b.dataset.words)    - Number(a.dataset.words);
      if (by === 'recent')   return Number(b.dataset.last)     - Number(a.dataset.last);
      if (by === 'alpha')    return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      return 0;
    });
    sorted.forEach(function (c) { grid.appendChild(c); });
  }

  search.addEventListener('input', applyFilter);
  sortSel.addEventListener('change', applySort);
  chips.forEach(function (chip) {
    chip.addEventListener('click', function () {
      chips.forEach(function (c) { c.classList.remove('is-on'); c.setAttribute('aria-pressed', 'false'); });
      chip.classList.add('is-on');
      chip.setAttribute('aria-pressed', 'true');
      filter = chip.dataset.filter;
      applyFilter();
    });
  });

  // Initial sort: most-recent first.
  applySort();
})();
</script>
