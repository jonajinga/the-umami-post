---
layout: layouts/base.njk
title: Quotes Showcase
description: A curated collection of freethought quotes, displayed one at a time.
permalink: /quotes/showcase/
eleventyExcludeFromCollections: true
---

{% block head %}
<style>
.showcase {
  position: fixed;
  inset: 0;
  background: var(--color-bg, #f5f3ed);
  color: var(--color-ink, #111);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-8) var(--gutter);
  z-index: 9999;
  cursor: pointer;
  user-select: none;
  overflow: hidden;
}

.showcase__quote {
  font-family: var(--font-body);
  font-size: clamp(1.4rem, 3vw, 2.4rem);
  font-style: italic;
  line-height: 1.6;
  max-width: 42em;
  text-align: center;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.showcase__quote.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.showcase__author {
  font-family: var(--font-ui);
  font-size: clamp(0.9rem, 1.5vw, 1.1rem);
  font-style: normal;
  font-weight: 600;
  margin-top: var(--space-6);
  letter-spacing: 0.04em;
  opacity: 0;
  transition: opacity 0.6s ease 0.4s;
}

.showcase__author.is-visible {
  opacity: 0.7;
}

.showcase__source {
  font-family: var(--font-ui);
  font-size: clamp(0.75rem, 1.2vw, 0.9rem);
  font-style: normal;
  margin-top: var(--space-2);
  opacity: 0;
  transition: opacity 0.6s ease 0.6s;
}

.showcase__source.is-visible {
  opacity: 0.4;
}

.showcase__nav {
  position: fixed;
  bottom: var(--space-6);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  opacity: 0.3;
  transition: opacity 0.3s;
}

.showcase__nav:hover {
  opacity: 0.7;
}

.showcase__nav button {
  background: none;
  border: 1px solid currentColor;
  color: inherit;
  border-radius: 50%;
  width: 44px;
  height: 44px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.showcase__nav button:hover {
  background: rgba(255,255,255,0.1);
}

.showcase__counter {
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.showcase__home {
  position: fixed;
  top: var(--space-6);
  left: 50%;
  transform: translateX(-50%);
  text-decoration: none;
  color: inherit;
  opacity: 0.25;
  transition: opacity 0.3s;
}

.showcase__home:hover {
  opacity: 0.6;
}

.showcase__home-name {
  font-family: var(--font-headline, Georgia, serif);
  font-size: clamp(0.75rem, 1.2vw, 1rem);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.showcase__pause {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* Progress bar */
.showcase__progress {
  position: fixed;
  bottom: 0;
  left: 0;
  height: 2px;
  background: currentColor;
  opacity: 0.2;
  transition: width linear;
}
</style>
{% endblock %}

<div class="showcase" id="showcase">
  <blockquote class="showcase__quote" id="showcase-quote"></blockquote>
  <p class="showcase__author" id="showcase-author"></p>
  <p class="showcase__source" id="showcase-source"></p>

  <a class="showcase__home" href="/quotes/" data-no-spa aria-label="Exit showcase">
    <span class="showcase__home-name">&larr; Exit showcase</span>
  </a>

  <div class="showcase__nav">
    <button id="showcase-prev" type="button" aria-label="Previous quote">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <span class="showcase__counter" id="showcase-counter"></span>
    <button id="showcase-next" type="button" aria-label="Next quote">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <button id="showcase-pause" type="button" aria-label="Pause auto-advance" class="showcase__pause">
      <svg id="pause-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg id="play-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    </button>
  </div>

  <div class="showcase__progress" id="showcase-progress"></div>
</div>

{% block scripts %}
<script>
(function () {
  var quotes = {{ quotes | dump | safe }};
  if (!quotes || !quotes.length) return;

  // Shuffle using Fisher-Yates
  for (var i = quotes.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var t = quotes[i]; quotes[i] = quotes[j]; quotes[j] = t;
  }

  var idx = 0;
  var paused = false;
  var INTERVAL = 10000;
  var timer = null;
  var progressTimer = null;

  var elQuote = document.getElementById('showcase-quote');
  var elAuthor = document.getElementById('showcase-author');
  var elSource = document.getElementById('showcase-source');
  var elCounter = document.getElementById('showcase-counter');
  var elProgress = document.getElementById('showcase-progress');
  var elPause = document.getElementById('showcase-pause');
  var pauseIcon = document.getElementById('pause-icon');
  var playIcon = document.getElementById('play-icon');

  function show(index) {
    idx = ((index % quotes.length) + quotes.length) % quotes.length;
    var q = quotes[idx];

    // Fade out
    elQuote.classList.remove('is-visible');
    elAuthor.classList.remove('is-visible');
    elSource.classList.remove('is-visible');

    setTimeout(function () {
      elQuote.textContent = '\u201c' + q.quote + '\u201d';
      elAuthor.textContent = '\u2014 ' + q.author;
      elSource.textContent = q.source || '';
      elCounter.textContent = (idx + 1) + ' / ' + quotes.length;

      // Fade in
      elQuote.classList.add('is-visible');
      elAuthor.classList.add('is-visible');
      elSource.classList.add('is-visible');
    }, 400);

    resetProgress();
  }

  function resetProgress() {
    if (progressTimer) cancelAnimationFrame(progressTimer);
    elProgress.style.transition = 'none';
    elProgress.style.width = '0';

    if (!paused) {
      clearTimeout(timer);
      // Start progress animation
      requestAnimationFrame(function () {
        elProgress.style.transition = 'width ' + (INTERVAL / 1000) + 's linear';
        elProgress.style.width = '100%';
      });
      timer = setTimeout(function () { show(idx + 1); }, INTERVAL);
    }
  }

  function togglePause() {
    paused = !paused;
    pauseIcon.style.display = paused ? 'none' : '';
    playIcon.style.display = paused ? '' : 'none';
    elPause.setAttribute('aria-label', paused ? 'Resume auto-advance' : 'Pause auto-advance');
    if (paused) {
      clearTimeout(timer);
      elProgress.style.transition = 'none';
      elProgress.style.width = '0';
    } else {
      resetProgress();
    }
  }

  // Controls
  document.getElementById('showcase-prev').addEventListener('click', function (e) {
    e.stopPropagation(); show(idx - 1);
  });
  document.getElementById('showcase-next').addEventListener('click', function (e) {
    e.stopPropagation(); show(idx + 1);
  });
  elPause.addEventListener('click', function (e) {
    e.stopPropagation(); togglePause();
  });

  // Keyboard
  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft') show(idx - 1);
    else if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); show(idx + 1); }
    else if (e.key === 'p') togglePause();
    else if (e.key === 'Escape') window.location.href = '/quotes/';
  });

  // Click anywhere advances — except on interactive controls, so the
  // prev/next/pause buttons and the Exit link keep their own behavior.
  document.getElementById('showcase').addEventListener('click', function (e) {
    if (e.target.closest('a, button, input, select')) return;
    show(idx + 1);
  });

  // Move showcase out of site-wrapper and hide everything else
  var showcase = document.getElementById('showcase');
  var wrapper = document.querySelector('.site-wrapper');
  if (showcase && wrapper) {
    document.body.appendChild(showcase);
    wrapper.style.display = 'none';
  }
  document.body.style.overflow = 'hidden';
  document.body.style.margin = '0';

  show(0);
})();
</script>
{% endblock %}
