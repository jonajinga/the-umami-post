---
layout: base
title: "Recommend a Book"
description: Have a book that belongs on the freethought bookshelf? Tell us about it.
permalink: /bookshelf/submit/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header class="page-header">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/bookshelf/">Bookshelf</a></li>
          <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Recommend a Book</li>
        </ol>
      </nav>
      <h1 class="page-header__title">Recommend a Book</h1>
      <p class="page-header__lede">
        Think a book belongs on the freethought bookshelf? We review every recommendation.
      </p>
    </header>

    <div class="article-body">
      <form action="https://api.web3forms.com/submit" method="POST" class="w3f" style="margin: var(--space-6) 0;">
        <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
        <input type="hidden" name="subject" value="Bookshelf recommendation, {{ site.title }}">
        <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
        <input type="hidden" name="from_name" value="{{ site.title }} Bookshelf Form">
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="w3f__group">
          <label class="w3f__label" for="bk-title">Book title <span class="w3f__required">*</span></label>
          <input class="w3f__input" type="text" name="title" id="bk-title" required aria-required="true" placeholder="e.g. The Varieties of Scientific Experience">
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="bk-author">Author <span class="w3f__required">*</span></label>
            <input class="w3f__input" type="text" name="author" id="bk-author" required aria-required="true" placeholder="e.g. Carl Sagan">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="bk-year">Year published <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="year" id="bk-year" placeholder="e.g. 2006">
          </div>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="bk-category">Category <span class="w3f__optional">(optional)</span></label>
          <select class="w3f__input" name="category" id="bk-category">
            <option value="">Select...</option>
            <option>Philosophy</option>
            <option>Science & Critical Thinking</option>
            <option>History</option>
            <option>Ethics & Humanism</option>
            <option>Political Philosophy</option>
            <option>Literature & Fiction</option>
            <option>Other</option>
          </select>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="bk-why">Why does this book belong? <span class="w3f__required">*</span></label>
          <span class="w3f__hint" id="bk-why-hint">What does it contribute to the freethought tradition? What does it do well?</span>
          <textarea class="w3f__textarea" name="reason" id="bk-why" rows="4" required aria-required="true" aria-describedby="bk-why-hint" maxlength="2000"></textarea>
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="bk-name">Your name <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="name" id="bk-name" autocomplete="name">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="bk-email">Email <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="email" name="email" id="bk-email" autocomplete="email">
          </div>
        </div>

        <button type="submit" class="w3f__submit">Submit Recommendation</button>
      </form>
    </div>
  </div>
</div>
