---
layout: base
title: "Suggest a Thought Experiment"
description: Know a thought experiment relevant to freethought or philosophy of mind? Suggest it.
permalink: /thought-experiments/submit/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header class="page-header">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/thought-experiments/">Thought Experiments</a></li>
          <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Suggest One</li>
        </ol>
      </nav>
      <h1 class="page-header__title">Suggest a Thought Experiment</h1>
      <p class="page-header__lede">
        The best thought experiments force you to confront what you actually believe. Know one we should cover?
      </p>
    </header>

    <div class="article-body">
      <form action="https://api.web3forms.com/submit" method="POST" class="w3f" style="margin: var(--space-6) 0;">
        <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
        <input type="hidden" name="subject" value="Thought experiment suggestion, {{ site.title }}">
        <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
        <input type="hidden" name="from_name" value="{{ site.title }} Thought Experiments Form">
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="w3f__group">
          <label class="w3f__label" for="te-name">Thought experiment name <span class="w3f__required">*</span></label>
          <input class="w3f__input" type="text" name="title" id="te-name" required aria-required="true" placeholder="e.g. The Ship of Theseus">
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="te-author">Philosopher / originator <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="philosopher" id="te-author" placeholder="e.g. Plutarch">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="te-year">Year proposed <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="year" id="te-year" placeholder="e.g. 1st century CE">
          </div>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="te-desc">Describe the thought experiment <span class="w3f__required">*</span></label>
          <span class="w3f__hint" id="te-desc-hint">What is the scenario? What question does it force you to answer?</span>
          <textarea class="w3f__textarea" name="description" id="te-desc" rows="5" required aria-required="true" aria-describedby="te-desc-hint" maxlength="2000"></textarea>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="te-relevance">Relevance to freethought <span class="w3f__optional">(optional)</span></label>
          <textarea class="w3f__textarea" name="relevance" id="te-relevance" rows="3" maxlength="1000" placeholder="Why does this matter for reason, skepticism, or philosophy of mind?"></textarea>
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="te-sname">Your name <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="name" id="te-sname" autocomplete="name">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="te-email">Email <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="email" name="email" id="te-email" autocomplete="email">
          </div>
        </div>

        <button type="submit" class="w3f__submit">Submit Suggestion</button>
      </form>
    </div>
  </div>
</div>
