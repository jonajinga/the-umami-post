---
layout: base
title: "Abbreviation Dictionary"
description: "Personal abbreviation dictionary, type a short code and it expands to the full phrase."
permalink: /abbreviations/
eleventyExcludeFromCollections: true
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header class="page-header">
      <h1 class="page-header__title">Abbreviation Dictionary</h1>
      <p class="page-header__lede">
        Build your personal dictionary of abbreviations. Type the short form and it expands to the full phrase.
      </p>
    </header>

    <div class="article-body">

      <h2>Add abbreviation</h2>
      <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);flex-wrap:wrap;">
        <input type="text" id="abbr-short" placeholder="Short form (e.g. GSK)" style="flex:1;min-width:120px;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <input type="text" id="abbr-full" placeholder="Expands to (e.g. GlaxoSmithKline)" style="flex:2;min-width:200px;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <button type="button" id="abbr-add" class="btn btn--accent" style="font-size:var(--text-sm);">Add</button>
      </div>

      <h2>Your abbreviations</h2>
      <table style="width:100%;font-size:var(--text-sm);border-collapse:collapse;margin:var(--space-6) 0;" id="abbr-table">
        <thead>
          <tr style="border-bottom:2px solid var(--color-ink);text-align:left;">
            <th style="padding:var(--space-2);">Abbreviation</th>
            <th style="padding:var(--space-2);">Expands to</th>
            <th style="padding:var(--space-2);width:60px;"></th>
          </tr>
        </thead>
        <tbody id="abbr-body"></tbody>
      </table>
      <p id="abbr-empty" style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;">No abbreviations saved yet. Add one above.</p>

      <div style="margin-top:var(--space-6);display:flex;gap:var(--space-3);">
        <button type="button" id="abbr-export" class="btn" style="font-size:var(--text-xs);">Export</button>
        <button type="button" id="abbr-import" class="btn" style="font-size:var(--text-xs);">Import</button>
        <input type="file" id="abbr-file" accept=".json" hidden>
      </div>

      <h2>Text expander</h2>
      <p>Type in the box below. When you type an abbreviation followed by a space, it expands automatically.</p>
      <textarea id="abbr-pad" rows="8" style="width:100%;font-family:var(--font-body);font-size:var(--text-base);padding:var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);line-height:var(--leading-relaxed);resize:vertical;" placeholder="Start typing... abbreviations expand automatically."></textarea>

    </div>
  </div>
</div>

<script>
(function () {
  var SKEY = 'tft-abbreviations';
  var body = document.getElementById('abbr-body');
  var empty = document.getElementById('abbr-empty');
  var shortIn = document.getElementById('abbr-short');
  var fullIn = document.getElementById('abbr-full');
  var pad = document.getElementById('abbr-pad');

  function load() { try { return JSON.parse(localStorage.getItem(SKEY)) || {}; } catch (e) { return {}; } }
  function save(d) { try { localStorage.setItem(SKEY, JSON.stringify(d)); } catch (e) {} }

  function render() {
    var d = load();
    var keys = Object.keys(d).sort();
    empty.hidden = keys.length > 0;
    body.innerHTML = keys.map(function (k) {
      return '<tr style="border-bottom:1px solid var(--color-rule);"><td style="padding:var(--space-2);font-weight:600;">' + esc(k) + '</td><td style="padding:var(--space-2);">' + esc(d[k]) + '</td><td style="padding:var(--space-2);"><button type="button" class="abbr-del" data-key="' + esc(k) + '" style="background:none;border:none;color:var(--color-ink-faint);cursor:pointer;font-size:var(--text-sm);" title="Delete">&times;</button></td></tr>';
    }).join('');
    body.querySelectorAll('.abbr-del').forEach(function (btn) {
      btn.onclick = function () { var d = load(); delete d[btn.dataset.key]; save(d); render(); };
    });
  }

  function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  document.getElementById('abbr-add').onclick = function () {
    var s = shortIn.value.trim(), f = fullIn.value.trim();
    if (!s || !f) return;
    var d = load(); d[s] = f; save(d); render();
    shortIn.value = ''; fullIn.value = ''; shortIn.focus();
  };

  fullIn.addEventListener('keydown', function (e) { if (e.key === 'Enter') document.getElementById('abbr-add').click(); });

  // Text expander
  pad.addEventListener('input', function () {
    var d = load();
    var keys = Object.keys(d);
    if (!keys.length) return;
    var v = pad.value;
    var pos = pad.selectionStart;
    keys.forEach(function (k) {
      var pattern = k + ' ';
      var idx = v.lastIndexOf(pattern, pos);
      if (idx !== -1 && idx + pattern.length === pos) {
        var before = v.substring(0, idx);
        var after = v.substring(pos);
        pad.value = before + d[k] + ' ' + after;
        var newPos = before.length + d[k].length + 1;
        pad.setSelectionRange(newPos, newPos);
      }
    });
  });

  // Export/import
  document.getElementById('abbr-export').onclick = function () {
    var d = load();
    var blob = new Blob([JSON.stringify(d, null, 2)], { type: 'application/json' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob); a.download = 'abbreviations.json'; a.click();
  };

  document.getElementById('abbr-import').onclick = function () { document.getElementById('abbr-file').click(); };
  document.getElementById('abbr-file').onchange = function (e) {
    var file = e.target.files[0]; if (!file) return;
    var reader = new FileReader();
    reader.onload = function () {
      try {
        var imported = JSON.parse(reader.result);
        var d = load();
        Object.keys(imported).forEach(function (k) { d[k] = imported[k]; });
        save(d); render();
      } catch (err) { alert('Invalid JSON file.'); }
    };
    reader.readAsText(file);
  };

  render();
})();
</script>
