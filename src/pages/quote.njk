---
layout: base
pagination:
  data: quotes
  size: 1
  alias: q
  addAllPagesToCollections: true
eleventyComputed:
  title: "{{ q.author | safe }}"
  description: "A quote by {{ q.author | safe }} from the freethought tradition."
permalink: /quotes/{{ q | quoteSlug }}/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div style="max-width: var(--max-width-prose); margin: 0 auto;">

    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol class="breadcrumbs__list">
        <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
        <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/quotes/">Quotes</a></li>
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">{{ q.author }}</li>
      </ol>
    </nav>

    <article data-pagefind-body>
      <div aria-hidden="true" style="display:none">
        <span data-pagefind-meta="title">{{ q.author }}, &ldquo;{{ q.quote | truncate(80, true, "...") }}&rdquo;</span>
        <span data-pagefind-meta="section">Quotes</span>
        <span data-pagefind-filter="section">Quotes</span>
        <span data-pagefind-meta="author">{{ q.author }}</span>
        <span data-pagefind-filter="author">{{ q.author }}</span>
        {% for tag in q.tags %}
        <span data-pagefind-filter="topic">{{ tag }}</span>
        {% endfor %}
      </div>

      <blockquote style="margin:0;padding:var(--space-6) var(--space-8);border-left:4px solid var(--color-accent);font-style:normal;">
        <p style="font-family:var(--font-body);font-size:var(--text-lg);line-height:var(--leading-loose);margin:0;">
          &ldquo;{{ q.quote }}&rdquo;
        </p>
      </blockquote>

      <div style="margin-top:var(--space-6);">
        <p style="font-family:var(--font-headline);font-size:var(--text-md);font-weight:700;margin:0;">{{ q.author }}</p>
        {% if q.source %}<p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-muted);margin:var(--space-1) 0 0;">{{ q.source }}</p>{% endif %}
        {% if q.era %}<p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin:var(--space-1) 0 0;">{{ q.era }}</p>{% endif %}
      </div>

      {% if q.tags %}
      <div style="margin-top:var(--space-4);display:flex;flex-wrap:wrap;gap:var(--space-1);">
        {% for tag in q.tags %}
        <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);border:1px solid var(--color-rule);padding:1px var(--space-2);">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </article>

  </div>
</div>
